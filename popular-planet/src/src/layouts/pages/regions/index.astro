---
import Site from "../../layouts/Site.astro";
const regions = [
  { slug: "vancouver-island", name: "Vancouver Island" },
  { slug: "lower-mainland", name: "Lower Mainland" },
  { slug: "okanagan", name: "Okanagan" },
  { slug: "kootenays", name: "Kootenays" },
  { slug: "interior-bc", name: "Interior BC" },
  { slug: "northern-bc", name: "Northern BC" },
];
---
<Site title="BC Regions - bc.realestate" description="Explore BC regions and compare lifestyle tradeoffs and real estate realities.">
  <section class="hero">
    <p class="kicker">Start broad</p>
    <h1>BC regions</h1>
    <p class="lead">Choose a region to explore lifestyle reality, housing patterns, and what surprises newcomers.</p>
  </section>

  <section class="grid">
    {regions.map(r => (
      <div class="card">
        <h2>{r.name}</h2>
        <p>Overview coming - what it’s like, who it fits, and what to watch for.</p>
        <a href={`/regions/${r.slug}/`}>Explore</a>
      </div>
    ))}
  </section>
</Site>
