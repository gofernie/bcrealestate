---
// File: src/pages/living-in-bc/index.astro
import Site from "../../layouts/Site.astro";

const guides = [
  { slug: "buying-property", name: "Buying Property in BC", desc: "The process, due diligence, and what surprises buyers moving from out of province." },
  { slug: "taxes-and-fees", name: "Taxes and Fees", desc: "Transfer tax, property tax basics, closing costs, and recurring ownership expenses." },
  { slug: "short-term-rentals", name: "Short-Term Rentals", desc: "A plain-language overview of BC’s STR landscape and what varies locally." },
  { slug: "primary-vs-investment", name: "Primary vs Investment", desc: "How your intent changes risk, financing, and the rules you’ll care about." },
  { slug: "rural-property", name: "Rural Property", desc: "Water, septic, access, wildfire considerations, zoning, and reality checks." },
  { slug: "moving-to-bc", name: "Moving to BC", desc: "Planning, timelines, and practical tradeoffs - lifestyle, logistics, and costs." },
];
---

<Site
  title="Living in BC - Guides - bc.realestate"
  description="Practical guides to buying and living in British Columbia - rules, tradeoffs, and real-world planning."
>
  <section class="hero">
    <p class="kicker">Evergreen guides</p>
    <h1>Living in British Columbia</h1>
    <p class="lead">
      Plain-language guides for people relocating, buying, or investing in BC - built to stay useful over time.
    </p>
  </section>

  <section class="grid">
    {guides.map((g) => (
      <div class="card">
        <h2>{g.name}</h2>
        <p>{g.desc}</p>
        <a href={`/living-in-bc/${g.slug}/`}>Open guide</a>
      </div>
    ))}
  </section>
</Site>
