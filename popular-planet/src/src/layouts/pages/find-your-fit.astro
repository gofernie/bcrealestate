---
// File: src/pages/find-your-fit.astro
// Find Your Fit (v1) - simple, non-AI starter that routes people to Regions + Living in BC
import Site from "../layouts/Site.astro";

const regionOptions = [
  { value: "", label: "No preference yet" },
  { value: "vancouver-island", label: "Vancouver Island" },
  { value: "lower-mainland", label: "Lower Mainland" },
  { value: "okanagan", label: "Okanagan" },
  { value: "kootenays", label: "Kootenays" },
  { value: "interior-bc", label: "Interior BC" },
  { value: "northern-bc", label: "Northern BC" },
];

const timingOptions = [
  { value: "", label: "Not sure yet" },
  { value: "0-3", label: "0 - 3 months" },
  { value: "3-6", label: "3 - 6 months" },
  { value: "6-12", label: "6 - 12 months" },
  { value: "12+", label: "12+ months" },
];

const budgetOptions = [
  { value: "", label: "Prefer not to say" },
  { value: "<500", label: "Under $500k" },
  { value: "500-750", label: "$500k - $750k" },
  { value: "750-1m", label: "$750k - $1M" },
  { value: "1m-2m", label: "$1M - $2M" },
  { value: "2m+", label: "$2M+" },
];

const priorities = [
  { slug: "schools", label: "Schools and kids" },
  { slug: "walkability", label: "Walkability" },
  { slug: "skiing", label: "Skiing and winter" },
  { slug: "ocean", label: "Ocean access" },
  { slug: "mountains", label: "Mountains and trails" },
  { slug: "remote-work", label: "Remote work friendly" },
  { slug: "healthcare", label: "Healthcare access" },
  { slug: "quiet", label: "Quiet / privacy" },
  { slug: "investment", label: "Investment potential" },
  { slug: "str", label: "Short-term rental interest" },
];
---

<Site
  title="Find Your Fit - bc.realestate"
  description="Tell us what matters most - we’ll guide you toward BC regions and the right next reading."
>
  <section class="hero">
    <p class="kicker">Start here</p>
    <h1>Find your fit in BC</h1>
    <p class="lead">
      This is a simple starter - answer a few questions and you’ll get a clean next-step path. No account needed.
    </p>
  </section>

  <section class="grid">
    <div class="card" style="grid-column: span 12;">
      <h2>Your situation</h2>
      <p class="muted">Optional - but the more context you add, the better we can guide your next steps.</p>

      <form id="fit-form" class="fit-form">
        <div class="fit-row">
          <label>
            <span class="fit-label">Timing</span>
            <select name="timing">
              {timingOptions.map((o) => <option value={o.value}>{o.label}</option>)}
            </select>
          </label>

          <label>
            <span class="fit-label">Budget band</span>
            <select name="budget">
              {budgetOptions.map((o) => <option value={o.value}>{o.label}</option>)}
            </select>
          </label>

          <label>
            <span class="fit-label">Region lean</span>
            <select name="region">
              {regionOptions.map((o) => <option value={o.value}>{o.label}</option>)}
            </select>
          </label>
        </div>

        <label style="display:block; margin-top:12px;">
          <span class="fit-label">What matters most (pick a few)</span>
          <div class="pill-grid">
            {priorities.map((p) => (
              <label class="pill">
                <input type="checkbox" name="priorities" value={p.slug} />
                <span>{p.label}</span>
              </label>
            ))}
          </div>
        </label>

        <label style="display:block; margin-top:12px;">
          <span class="fit-label">Quick description (optional)</span>
          <textarea
            name="notes"
            rows="4"
            placeholder="Example: Family of four, want trails close by, prefer a quieter community, okay with winter, would like decent internet."
          ></textarea>
        </label>

        <div class="fit-actions">
          <button type="submit" class="btn">Show my next steps</button>
          <button type="button" id="fit-reset" class="btn btn-ghost">Reset</button>
        </div>
      </form>
    </div>

    <div class="card" id="fit-results" style="grid-column: span 12; display:none;">
      <h2>Your next steps</h2>
      <p class="muted" id="fit-summary"></p>

      <div class="grid" style="margin:12px 0 0;">
        <div class="card" style="grid-column: span 6;">
          <h2>Explore regions</h2>
          <p class="muted">Start broad - compare lifestyle tradeoffs before you go deep.</p>
          <a id="fit-region-link" href="/regions/">Browse regions</a>
        </div>

        <div class="card" style="grid-column: span 6;">
          <h2>Read Living in BC guides</h2>
          <p class="muted">Get clear on rules and planning - especially if you’re moving from out of province.</p>
          <a href="/living-in-bc/">Open guides</a>
        </div>

        <div class="card" style="grid-column: span 12;">
          <h2>When you’re ready</h2>
          <p class="muted">
            If you want help narrowing down options, you can reach a local expert. This will expand region-by-region.
          </p>
          <a href="/experts/">See experts</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .fit-form select,
    .fit-form textarea{
      width:100%;
      margin-top:6px;
      padding:10px 12px;
      border-radius:12px;
      border:1px solid var(--line);
      background: rgba(255,255,255,.03);
      color: var(--text);
      outline: none;
    }
    .fit-form textarea{ resize: vertical; }
    .fit-row{
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap:12px;
      margin-top:10px;
    }
    .fit-label{
      display:block;
      font-size:12px;
      letter-spacing:.08em;
      text-transform:uppercase;
      color: var(--muted);
    }
    .pill-grid{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin-top:10px;
    }
    .pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:10px 12px;
      border-radius:999px;
      border:1px solid var(--line);
      background: rgba(255,255,255,.03);
      cursor:pointer;
      user-select:none;
    }
    .pill input{ transform: translateY(1px); }
    .fit-actions{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:12px;
    }
    .btn{
      padding:10px 14px;
      border-radius:12px;
      border:1px solid var(--line);
      background: rgba(255,255,255,.06);
      color: var(--text);
      cursor:pointer;
    }
    .btn:hover{ background: rgba(255,255,255,.08); }
    .btn-ghost{
      background: transparent;
    }
    .btn-ghost:hover{
      background: rgba(255,255,255,.04);
    }
    @media (max-width: 900px){
      .fit-row{ grid-template-columns: 1fr; }
    }
  </style>

  <script is:inline>
    const form = document.getElementById("fit-form");
    const resetBtn = document.getElementById("fit-reset");
    const results = document.getElementById("fit-results");
    const summary = document.getElementById("fit-summary");
    const regionLink = document.getElementById("fit-region-link");

    function getCheckedValues(name) {
      return Array.from(form.querySelectorAll(`input[name="${name}"]:checked`)).map(i => i.value);
    }

    function humanList(arr) {
      if (!arr || !arr.length) return "";
      if (arr.length === 1) return arr[0];
      if (arr.length === 2) return `${arr[0]} and ${arr[1]}`;
      return `${arr.slice(0, -1).join(", ")}, and ${arr[arr.length - 1]}`;
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();

      const timing = form.elements.timing.value;
      const budget = form.elements.budget.value;
      const region = form.elements.region.value;
      const priorities = getCheckedValues("priorities");
      const notes = form.elements.notes.value.trim();

      const bits = [];
      if (timing) bits.push(`timing: ${timing} months`);
      if (budget) bits.push(`budget: ${form.elements.budget.selectedOptions[0].text}`);
      if (priorities.length) bits.push(`priorities: ${humanList(priorities)}`);
      if (notes) bits.push(`notes: "${notes}"`);

      summary.textContent = bits.length
        ? `Based on what you shared (${bits.join(" - ")}), here’s a clean next-step path:`
        : `Here’s a simple next-step path: start broad with regions, then read the BC-wide guides.`;

      if (region) {
        regionLink.href = `/regions/${region}/`;
        regionLink.textContent = `Explore ${form.elements.region.selectedOptions[0].text}`;
      } else {
        regionLink.href = `/regions/`;
        regionLink.textContent = `Browse regions`;
      }

      results.style.display = "block";
      results.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    resetBtn.addEventListener("click", () => {
      form.reset();
      results.style.display = "none";
      summary.textContent = "";
      regionLink.href = "/regions/";
      regionLink.textContent = "Browse regions";
    });
  </script>
</Site>
