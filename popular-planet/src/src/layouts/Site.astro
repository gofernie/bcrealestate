---
const { title = "bc.realestate", description = "A practical guide to buying and living in British Columbia.", canonical } = Astro.props;
const url = canonical || Astro.url?.toString?.();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {url ? <link rel="canonical" href={url} /> : null}
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <header class="header">
      <div class="wrap header-inner">
        <a class="brand" href="/">bc.realestate</a>
        <nav class="nav">
          <a href="/regions/">Regions</a>
          <a href="/living-in-bc/">Living in BC</a>
          <a href="/find-your-fit/">Find Your Fit</a>
          <a href="/experts/">Experts</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="footer">
      <div class="wrap footer-inner">
        <p>© {new Date().getFullYear()} bc.realestate</p>
        <p class="muted">Practical guidance - not legal or tax advice.</p>
      </div>
    </footer>
  </body>
</html>
