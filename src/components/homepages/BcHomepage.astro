---
import ListingCard from "../ListingCard.astro";
import IntentModalController from "../IntentModalController.astro";

interface CityCard {
  city: string;
  label: string;
  siteName?: string;
  href: string;
  areasHref?: string;
  count: number;
  accent?: string;
}

interface HomepageFilters {
  city?: string;
  type?: string;
  beds?: number | null;
  maxPrice?: number | null;
  sort?: string;
  page?: number;
}

interface Props {
  site?: any;
  cityCards?: CityCard[];
  listings?: any[];
  filters?: HomepageFilters;
  totalMatchingCount?: number;
  currentPage?: number;
  totalPages?: number;
  pageSize?: number;
  paginationStart?: number;
  paginationEnd?: number;
  hasPreviousPage?: boolean;
  hasNextPage?: boolean;
  previousPageHref?: string | null;
  nextPageHref?: string | null;
}

const {
  site,
  cityCards = [],
  listings = [],
  filters = {},
  totalMatchingCount = listings.length,
  currentPage = 1,
  totalPages = 1,
  pageSize = 24,
  paginationStart = listings.length > 0 ? 1 : 0,
  paginationEnd = listings.length,
  hasPreviousPage = false,
  hasNextPage = false,
  previousPageHref = null,
  nextPageHref = null,
} = Astro.props;

const accent =
  site?.accent_color || "#1f5a49";

const featuredCities =
  cityCards.slice(0, 6);

const listingCount =
  cityCards.reduce(
    (total, city) =>
      total + Number(city.count || 0),
    0
  );

const activeFilterCount = [
  filters.city,
  filters.type,
  filters.beds,
  filters.maxPrice,
  filters.sort &&
  filters.sort !== "newest"
    ? filters.sort
    : null,
].filter(Boolean).length;

const hasActiveFilters =
  activeFilterCount > 0;

const cityImages: Record<
  string,
  string
> = {
  nanaimo:
    "https://images.unsplash.com/photo-1559511260-66a654ae982a?auto=format&fit=crop&w=1200&q=78",

  parksville:
    "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1200&q=78",

  whistler:
    "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1200&q=78",

  tofino:
    "https://images.unsplash.com/photo-1500534314209-a25ddb2bd4297?auto=format&fit=crop&w=1200&q=78",

  fernie:
    "https://images.unsplash.com/photo-1486911278844-a81c5267e227?auto=format&fit=crop&w=1200&q=78",

  sparwood:
    "https://images.unsplash.com/photo-1464278533981-50106e6176b1?auto=format&fit=crop&w=1200&q=78",
};

const fallbackCityImages = [
  "https://images.unsplash.com/photo-1559511260-66a654ae982a?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1500534314209-a25ddb2bd4297?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1486911278844-a81c5267e227?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1464278533981-50106e6176b1?auto=format&fit=crop&w=1200&q=78",
];

const formatCount = (
  value: number
) =>
  Number(value || 0).toLocaleString();

const resultLabel =
  totalMatchingCount === 1
    ? "property"
    : "properties";

const resultSummary =
  totalMatchingCount > 0
    ? `Showing ${formatCount(
        paginationStart
      )}–${formatCount(
        paginationEnd
      )} of ${formatCount(
        totalMatchingCount
      )} ${resultLabel}`
    : hasActiveFilters
      ? "No properties match these filters"
      : "No active properties";

const pageNumbers: number[] = [];

if (totalPages > 1) {
  const firstVisiblePage =
    Math.max(
      1,
      Math.min(
        currentPage - 2,
        totalPages - 4
      )
    );

  const lastVisiblePage =
    Math.min(
      totalPages,
      firstVisiblePage + 4
    );

  for (
    let page = firstVisiblePage;
    page <= lastVisiblePage;
    page += 1
  ) {
    pageNumbers.push(page);
  }
}

const buildPaginationHref = (
  page: number
) => {
  const params =
    new URLSearchParams();

  if (filters.city) {
    params.set(
      "city",
      filters.city
    );
  }

  if (filters.type) {
    params.set(
      "type",
      filters.type
    );
  }

  if (
    filters.beds !== null &&
    filters.beds !== undefined
  ) {
    params.set(
      "beds",
      String(filters.beds)
    );
  }

  if (
    filters.maxPrice !== null &&
    filters.maxPrice !== undefined
  ) {
    params.set(
      "maxPrice",
      String(filters.maxPrice)
    );
  }

  if (
    filters.sort &&
    filters.sort !== "newest"
  ) {
    params.set(
      "sort",
      filters.sort
    );
  }

  if (page > 1) {
    params.set(
      "page",
      String(page)
    );
  }

  const queryString =
    params.toString();

  return queryString
    ? `/?${queryString}`
    : "/";
};
---

<div
  class="bc-homepage"
  style={`--bc-home-accent: ${accent};`}
>
  <section class="bc-hero">
    <div class="bc-hero__overlay"></div>

    <div class="bc-hero__inner">
      <div class="bc-hero__content">
        <p class="bc-eyebrow">
          Real estate across British Columbia
        </p>

        <h1>
          Find your place
          <br />
          in British Columbia.
        </h1>

        <p class="bc-hero__copy">
          Explore homes, condos, townhomes, and land
          across British Columbia’s most desirable
          communities.
        </p>
      </div>
    </div>
  </section>

  <div class="bc-search-wrap">
    <form
      class="bc-search"
      method="GET"
      action="/"
    >
      <label class="bc-search__field">
        <span class="bc-search__icon">
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M12 21s7-6.2 7-12A7 7 0 0 0 5 9c0 5.8 7 12 7 12Z"
            ></path>

            <circle
              cx="12"
              cy="9"
              r="2.4"
            ></circle>
          </svg>
        </span>

        <span class="bc-search__content">
          <strong>Market</strong>

          <select name="city">
            <option
              value=""
              selected={!filters.city}
            >
              All markets
            </option>

            {
              cityCards.map((city) => {
                const cityValue =
                  city.city
                    .toLowerCase()
                    .trim();

                return (
                  <option
                    value={cityValue}
                    selected={
                      filters.city ===
                      cityValue
                    }
                  >
                    {city.label}
                  </option>
                );
              })
            }
          </select>
        </span>
      </label>

      <label class="bc-search__field">
        <span class="bc-search__icon">
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M3 11.5 12 4l9 7.5"></path>
            <path d="M5.5 10.5V21h13V10.5"></path>
            <path d="M9.5 21v-6h5v6"></path>
          </svg>
        </span>

        <span class="bc-search__content">
          <strong>Property type</strong>

          <select name="type">
            <option
              value=""
              selected={!filters.type}
            >
              Any type
            </option>

            <option
              value="house"
              selected={
                filters.type === "house"
              }
            >
              Homes
            </option>

            <option
              value="condo"
              selected={
                filters.type === "condo"
              }
            >
              Condos
            </option>

            <option
              value="townhouse"
              selected={
                filters.type ===
                "townhouse"
              }
            >
              Townhomes
            </option>

            <option
              value="mobile"
              selected={
                filters.type === "mobile"
              }
            >
              Mobile homes
            </option>

            <option
              value="land"
              selected={
                filters.type === "land"
              }
            >
              Land
            </option>
          </select>
        </span>
      </label>

      <label class="bc-search__field">
        <span class="bc-search__icon">
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M3 18v-7h18v7"></path>
            <path d="M5 11V7h6v4"></path>
            <path d="M13 11V7h6v4"></path>
            <path d="M3 18v3"></path>
            <path d="M21 18v3"></path>
          </svg>
        </span>

        <span class="bc-search__content">
          <strong>Beds</strong>

          <select name="beds">
            <option
              value=""
              selected={
                filters.beds === null ||
                filters.beds === undefined
              }
            >
              Any
            </option>

            <option
              value="1"
              selected={filters.beds === 1}
            >
              1+
            </option>

            <option
              value="2"
              selected={filters.beds === 2}
            >
              2+
            </option>

            <option
              value="3"
              selected={filters.beds === 3}
            >
              3+
            </option>

            <option
              value="4"
              selected={filters.beds === 4}
            >
              4+
            </option>

            <option
              value="5"
              selected={filters.beds === 5}
            >
              5+
            </option>
          </select>
        </span>
      </label>

      <label class="bc-search__field">
        <span class="bc-search__icon">
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <circle
              cx="12"
              cy="12"
              r="9"
            ></circle>

            <path d="M15 8.5c-.7-.7-1.7-1-3-1-1.7 0-3 .9-3 2.2 0 1.4 1.2 2 3.2 2.5 1.8.5 2.8 1.1 2.8 2.3 0 1.3-1.2 2.2-3 2.2-1.3 0-2.5-.4-3.3-1.2"></path>
            <path d="M12 5.5v13"></path>
          </svg>
        </span>

        <span class="bc-search__content">
          <strong>Price</strong>

          <select name="maxPrice">
            <option
              value=""
              selected={
                filters.maxPrice === null ||
                filters.maxPrice ===
                  undefined
              }
            >
              Any price
            </option>

            <option
              value="500000"
              selected={
                filters.maxPrice ===
                500000
              }
            >
              Under $500,000
            </option>

            <option
              value="700000"
              selected={
                filters.maxPrice ===
                700000
              }
            >
              Under $700,000
            </option>

            <option
              value="900000"
              selected={
                filters.maxPrice ===
                900000
              }
            >
              Under $900,000
            </option>

            <option
              value="1200000"
              selected={
                filters.maxPrice ===
                1200000
              }
            >
              Under $1.2M
            </option>

            <option
              value="1600000"
              selected={
                filters.maxPrice ===
                1600000
              }
            >
              Under $1.6M
            </option>

            <option
              value="2000000"
              selected={
                filters.maxPrice ===
                2000000
              }
            >
              Under $2M
            </option>
          </select>
        </span>
      </label>

      <label class="bc-search__field">
        <span class="bc-search__icon">
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M7 6h10"></path>
            <path d="M9 12h6"></path>
            <path d="M11 18h2"></path>
          </svg>
        </span>

        <span class="bc-search__content">
          <strong>Sort</strong>

          <select name="sort">
            <option
              value="newest"
              selected={
                !filters.sort ||
                filters.sort === "newest"
              }
            >
              Newest
            </option>

            <option
              value="price-low"
              selected={
                filters.sort ===
                "price-low"
              }
            >
              Price: low to high
            </option>

            <option
              value="price-high"
              selected={
                filters.sort ===
                "price-high"
              }
            >
              Price: high to low
            </option>
          </select>
        </span>
      </label>

      <button
        class="bc-search__submit"
        type="submit"
      >
        <svg
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <circle
            cx="11"
            cy="11"
            r="7"
          ></circle>

          <path d="m20 20-4-4"></path>
        </svg>

        <span>Search</span>
      </button>
    </form>
  </div>

  <section class="bc-search-results">
    <div class="bc-search-results__heading">
      <div>
        <p class="bc-eyebrow">
          Homes across BC
        </p>

        <h2>
          {formatCount(totalMatchingCount)}{" "}
          {resultLabel}
        </h2>

        <p class="bc-listing-description">
          {resultSummary}
        </p>
      </div>

      {
        hasActiveFilters && (
          <a
            class="bc-clear-search"
            href="/"
          >
            Clear filters
          </a>
        )
      }
    </div>

    {
      listings.length > 0 ? (
        <>
          <div class="bc-listing-grid">
            {
              listings.map(
                (listing, index) => (
                  <div class="bc-listing-item">
                    <ListingCard
                      listing={listing}
                      priority={index < 4}
                    />
                  </div>
                )
              )
            }
          </div>

          {
            totalPages > 1 && (
              <nav
                class="bc-pagination"
                aria-label="Listing pages"
              >
                <div class="bc-pagination__summary">
                  Page{" "}
                  <strong>
                    {currentPage}
                  </strong>{" "}
                  of{" "}
                  <strong>
                    {totalPages}
                  </strong>
                </div>

                <div class="bc-pagination__links">
                  {
                    hasPreviousPage &&
                    previousPageHref ? (
                      <a
                        class="bc-pagination__direction"
                        href={
                          previousPageHref
                        }
                        rel="prev"
                      >
                        <span
                          aria-hidden="true"
                        >
                          ←
                        </span>

                        Previous
                      </a>
                    ) : (
                      <span
                        class="bc-pagination__direction bc-pagination__direction--disabled"
                        aria-disabled="true"
                      >
                        <span
                          aria-hidden="true"
                        >
                          ←
                        </span>

                        Previous
                      </span>
                    )
                  }

                  <div class="bc-pagination__numbers">
                    {
                      pageNumbers.map(
                        (page) =>
                          page ===
                          currentPage ? (
                            <span
                              class="bc-pagination__page bc-pagination__page--current"
                              aria-current="page"
                            >
                              {page}
                            </span>
                          ) : (
                            <a
                              class="bc-pagination__page"
                              href={buildPaginationHref(
                                page
                              )}
                            >
                              {page}
                            </a>
                          )
                      )
                    }
                  </div>

                  {
                    hasNextPage &&
                    nextPageHref ? (
                      <a
                        class="bc-pagination__direction"
                        href={nextPageHref}
                        rel="next"
                      >
                        Next

                        <span
                          aria-hidden="true"
                        >
                          →
                        </span>
                      </a>
                    ) : (
                      <span
                        class="bc-pagination__direction bc-pagination__direction--disabled"
                        aria-disabled="true"
                      >
                        Next

                        <span
                          aria-hidden="true"
                        >
                          →
                        </span>
                      </span>
                    )
                  }
                </div>
              </nav>
            )
          }
        </>
      ) : (
        <div class="bc-search-results__empty">
          <h3>
            {hasActiveFilters
              ? "No matching listings"
              : "No active listings"}
          </h3>

          <p>
            {hasActiveFilters
              ? "Try changing the market, property type, bedroom count, or maximum price."
              : "New listings will appear here when available."}
          </p>

          {
            hasActiveFilters && (
              <a href="/">
                Clear filters
              </a>
            )
          }
        </div>
      )
    }
  </section>

  <main class="bc-main">
    <section
      id="bc-markets"
      class="bc-markets"
    >
      <div class="bc-section-heading">
        <div>
          <p class="bc-eyebrow">
            Browse by city
          </p>

          <h2>Explore BC markets</h2>
        </div>

        <p>
          Start with a city, then explore
          neighbourhoods, listings, and local guides.
        </p>

        <a href="/explore">
          View all markets
          <span aria-hidden="true">
            →
          </span>
        </a>
      </div>

      <div class="bc-market-grid">
        {
          featuredCities.map(
            (city, index) => {
              const key =
                city.city
                  .toLowerCase()
                  .replace(/\s+/g, "-");

              const image =
                cityImages[key] ||
                fallbackCityImages[
                  index %
                    fallbackCityImages.length
                ];

              return (
                <a
                  class="bc-market-card"
                  href={city.href}
                  style={`--market-image: url('${image}')`}
                >
                  <div class="bc-market-card__shade"></div>

                  <div class="bc-market-card__content">
                    <strong>
                      {city.label}
                    </strong>

                    <span>
                      {formatCount(
                        city.count
                      )}{" "}
                      active{" "}
                      {city.count === 1
                        ? "listing"
                        : "listings"}
                    </span>
                  </div>

                  <span
                    class="bc-market-card__arrow"
                    aria-hidden="true"
                  >
                    →
                  </span>
                </a>
              );
            }
          )
        }
      </div>
    </section>

    <section class="bc-benefits">
      <article class="bc-benefit">
        <span class="bc-benefit__icon">
          <svg viewBox="0 0 24 24">
            <path d="M3 11.5 12 4l9 7.5"></path>
            <path d="M5.5 10.5V21h13V10.5"></path>
            <path d="M9.5 21v-6h5v6"></path>
          </svg>
        </span>

        <div>
          <h3>Local knowledge</h3>

          <p>
            Detailed insights into communities across
            British Columbia.
          </p>
        </div>
      </article>

      <article class="bc-benefit">
        <span class="bc-benefit__icon">
          <svg viewBox="0 0 24 24">
            <path d="M4 20V10"></path>
            <path d="M10 20V4"></path>
            <path d="M16 20v-7"></path>
            <path d="M22 20V7"></path>
            <path d="m3 8 6-5 6 7 7-6"></path>
          </svg>
        </span>

        <div>
          <h3>Real-time listings</h3>

          <p>
            Fresh listings updated throughout the day,
            every day.
          </p>
        </div>
      </article>

      <article class="bc-benefit">
        <span class="bc-benefit__icon">
          <svg viewBox="0 0 24 24">
            <path d="m3 5 6-2 6 2 6-2v16l-6 2-6-2-6 2Z"></path>
            <path d="M9 3v16"></path>
            <path d="M15 5v16"></path>
          </svg>
        </span>

        <div>
          <h3>Neighbourhood guides</h3>

          <p>
            Explore areas, amenities, schools, and
            lifestyle.
          </p>
        </div>
      </article>

      <article class="bc-benefit">
        <span class="bc-benefit__icon">
          <svg viewBox="0 0 24 24">
            <path d="M20.8 5.8a5.5 5.5 0 0 0-7.8 0L12 6.9l-1.1-1.1a5.5 5.5 0 0 0-7.8 7.8L12 22l8.8-8.4a5.5 5.5 0 0 0 0-7.8Z"></path>
          </svg>
        </span>

        <div>
          <h3>BC lifestyle</h3>

          <p>
            From mountains to ocean, find the lifestyle
            that fits you.
          </p>
        </div>
      </article>
    </section>

    <section class="bc-cta">
      <div class="bc-cta__copy">
        <p class="bc-eyebrow bc-eyebrow--light">
          Start exploring
        </p>

        <h2>
          Let’s find the right
          <br />
          property for you.
        </h2>

        <p>
          Whether you’re buying your first home,
          upgrading, relocating, or investing, begin
          with the market that interests you.
        </p>

        <a href="/explore">
          View homes for sale

          <span aria-hidden="true">
            →
          </span>
        </a>
      </div>

      <div class="bc-cta__stats">
        <div class="bc-stat">
          <strong>
            {formatCount(listingCount)}+
          </strong>

          <span>
            Active listings across BC
          </span>
        </div>

        <div class="bc-stat">
          <strong>
            {cityCards.length}+
          </strong>

          <span>
            Communities to explore
          </span>
        </div>

        <div class="bc-stat">
          <strong>Local</strong>

          <span>
            Market information and area expertise
          </span>
        </div>
      </div>
    </section>

    <section class="bc-resource-strip">
      <a href="/buying-guide">
        <span>01</span>

        <div>
          <strong>Buying guide</strong>
          <small>Tips for buyers</small>
        </div>
      </a>

      <a href="/market-insights">
        <span>02</span>

        <div>
          <strong>Market insights</strong>
          <small>Local trends and data</small>
        </div>
      </a>

      <a href="/explore">
        <span>03</span>

        <div>
          <strong>Explore BC</strong>
          <small>Browse homes on the map</small>
        </div>
      </a>

      <a href="/contact">
        <span>04</span>

        <div>
          <strong>Contact</strong>
          <small>Get local help</small>
        </div>
      </a>
    </section>
  </main>
</div>

<IntentModalController listings={listings} />

<style>
  .bc-homepage {
    --bc-ink: #14201c;
    --bc-muted: #65716c;
    --bc-line: rgba(20, 32, 28, 0.11);
    --bc-cream: #f8f7f3;
    overflow: hidden;
    background: #fff;
    color: var(--bc-ink);
  }

  .bc-hero {
    position: relative;
    min-height: 590px;
    background-image: url("https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=2200&q=90");
    background-position: center;
    background-size: cover;
  }

  .bc-hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.08),
        rgba(255, 255, 255, 0)
      );
    pointer-events: none;
  }

  .bc-hero__inner {
    position: relative;
    z-index: 1;
    width: min(1240px, calc(100% - 48px));
    margin: 0 auto;
