---
import { createClient } from "@supabase/supabase-js";
import Layout from "../../layouts/Layout.astro";
import SiteNav from "../SiteNav.astro";
import RealEstateHomepage from "./RealEstateHomepage.astro";
import { getSite } from "../../lib/getSite";
import { getNavIntentPages } from "../../lib/getNavIntentPages";

export const prerender = false;

interface Props {
  city?: string;
  site?: any;
}

const {
  city: cityProp = "",
  site: suppliedSite = null,
} = Astro.props;

const requestedCity =
  Astro.url.searchParams.get("city") ||
  cityProp ||
  "nanaimo";

const city = String(requestedCity)
  .toLowerCase()
  .trim()
  .replace(/\s+/g, "-");

const databaseCity = city.replace(/-/g, " ");

const cityLabel = databaseCity.replace(
  /\b\w/g,
  (letter) => letter.toUpperCase()
);

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const hostname = Astro.url.hostname
  .toLowerCase()
  .replace(/^www\./, "");

const site =
  suppliedSite ||
  (await getSite(hostname, city));

const accentColor =
  site?.accent_color ||
  "#2f6f73";

const areaToSlug = (value: unknown) =>
  String(value || "")
    .toLowerCase()
    .replace(/^pq[\s-]+/i, "")
    .replace(/&/g, "and")
    .replace(/\//g, "-")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const titleCase = (value: unknown) =>
  String(value || "")
    .replace(/^pq[\s-]+/i, "")
    .replace(/[-_]/g, " ")
    .replace(/\s+/g, " ")
    .trim()
    .replace(/\b\w/g, (letter) => letter.toUpperCase());

const normalizeListingImageUrl = (value: any) => {
  if (!value) return "";

  const raw =
    typeof value === "string"
      ? value
      : value.highRes ||
        value.mediumRes ||
        value.lowRes ||
        value.url ||
        value.src ||
        value.href ||
        value.path ||
        "";

  if (!raw) return "";

  if (
    raw.startsWith("http://") ||
    raw.startsWith("https://")
  ) {
    return raw;
  }

  const cleaned = raw.startsWith("/")
    ? raw
    : `/${raw}`;

  return `https://cdn.repliers.io${cleaned}`;
};

const getListingImage = (listing: any) =>
  normalizeListingImageUrl(
    listing?.image_url ||
      listing?.image ||
      listing?.photo ||
      listing?.images?.[0] ||
      listing?.images?.[1] ||
      listing?.raw?.images?.[0] ||
      listing?.raw?.images?.[1] ||
      listing?.raw?.images?.[0]?.url ||
      listing?.raw?.images?.[1]?.url ||
      listing?.raw?.images?.[0]?.mediumRes ||
      listing?.raw?.images?.[1]?.mediumRes ||
      listing?.raw?.images?.[0]?.highRes ||
      listing?.raw?.images?.[1]?.highRes
  );

const {
  data: listingRows = [],
  error: listingsError,
} = await supabase
  .from("listing_rows")
  .select("*")
.eq("normalized_city", databaseCity)
  .eq("status", "A")
  .order("listed_at", { ascending: false });

if (listingsError) {
  console.error(
    `Unable to load ${cityLabel} listings:`,
    listingsError
  );
}

const listings = (listingRows || [])
  .map((listing: any) => ({
    ...listing,
    image_url:
      getListingImage(listing) ||
      listing.image_url ||
      "",
  }))
  .sort((a: any, b: any) => {
    const aDate = new Date(
      a.listed_at ||
        a.updated_at ||
        a.created_at ||
        0
    ).getTime();

    const bDate = new Date(
      b.listed_at ||
        b.updated_at ||
        b.created_at ||
        0
    ).getTime();

    return bDate - aDate;
  });

const {
  data: areaMetaRows = [],
  error: areasError,
} = await supabase
  .from("area_boundaries")
  .select(`
    area_slug,
    area_name,
    short_description
  `)
.ilike("city", databaseCity);

if (areasError) {
  console.error(
    `Unable to load ${cityLabel} areas:`,
    areasError
  );
}

const listingCountByArea = listings.reduce(
  (counts: Record<string, number>, listing: any) => {
    const areaSlug = areaToSlug(
      listing.normalized_area ||
        listing.area
    );

    if (!areaSlug) return counts;

    counts[areaSlug] =
      (counts[areaSlug] || 0) + 1;

    return counts;
  },
  {}
);

const knownAreaSlugs = new Set(
  (areaMetaRows || [])
    .map((row: any) =>
      areaToSlug(
        row.area_slug ||
          row.area_name
      )
    )
    .filter(Boolean)
);

const locationCards = (areaMetaRows || [])
  .map((row: any) => {
    const areaSlug = areaToSlug(
      row.area_slug ||
        row.area_name
    );

    return {
      area: areaSlug,
      label:
        row.area_name ||
        titleCase(areaSlug),
      href: `/${city}/${areaSlug}`,
      count:
        listingCountByArea[areaSlug] ||
        0,
    };
  })
  .filter((location: any) => location.area)
  .sort(
    (a: any, b: any) =>
      b.count - a.count ||
      a.label.localeCompare(b.label)
  );

const missingAreaCards = Object.entries(
  listingCountByArea
)
  .filter(
    ([areaSlug]) =>
      !knownAreaSlugs.has(areaSlug)
  )
  .map(([areaSlug, count]) => ({
    area: areaSlug,
    label: titleCase(areaSlug),
    href: `/${city}/${areaSlug}`,
    count: Number(count || 0),
  }))
  .sort(
    (a, b) =>
      b.count - a.count ||
      a.label.localeCompare(b.label)
  );

const allLocationCards = [
  ...locationCards,
  ...missingAreaCards,
];

const navAreas = allLocationCards.map(
  (location) => location.label
);

const navTypes = [
  "house",
  "condo",
  "townhouse",
  "mobile",
  "land",
];

const navIntentPages =
  await getNavIntentPages(
    supabase,
    site?.id
  );

const pageTitle =
  `${cityLabel} Real Estate | Homes for Sale`;

const pageDescription =
  `Explore homes, condos, townhomes, mobile homes, land, and neighbourhoods across ${cityLabel}, British Columbia.`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  accentColor={accentColor}
  city={city}
>
  <SiteNav
    city={city}
    site={site}
    areas={navAreas}
    types={navTypes}
    intentPages={navIntentPages}
    showAreaNav={false}
  />

  <RealEstateHomepage
    mode="city"
    site={site}
    city={city}
    listings={listings}
    locationCards={allLocationCards}
  />
</Layout>
