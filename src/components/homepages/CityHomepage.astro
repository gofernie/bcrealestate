}

.type-button--secondary {
  border: 1px solid rgba(18, 58, 90, 0.16);
  background: #fff;
  color: var(--accent);
}

.market-page-hero__dashboard {
  min-width: 0;
  min-height: 390px;
}

@media (max-width: 980px) {
  .type-hero {
    grid-template-columns: 1fr;
    gap: 22px;
  }

  .type-hero__copy {
    min-height: 0;
