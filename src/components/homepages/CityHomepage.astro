  }
}

@media (max-width: 640px) {
  .is-type-page .intent-content-shell {
    width: 100%;
    padding: 16px 14px 0;
  }



  .type-hero {
    gap: 18px;
  }

  .type-hero__copy {
    padding: 5px 2px 0;
  }

  .type-hero h1 {
    max-width: 340px;
    font-size: clamp(2.45rem, 12vw, 3.4rem);
  }

  .type-hero__copy > p:not(.type-hero__eyebrow) {
    margin-top: 17px;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .type-hero__actions {
    margin-top: 22px;
  }

  .type-button {
    min-height: 42px;
    padding: 0 15px;
    font-size: 0.79rem;
  }
}
/* =========================================================
   AREAS PAGE DASHBOARD — REFINED
   ========================================================= */

.market-summary-card {
  min-height: 390px;
  overflow: hidden;
  border: 1px solid rgba(18, 58, 90, 0.08);
  border-radius: 14px;
  background: #fff;
  box-shadow: 0 14px 40px rgba(24, 45, 68, 0.055);
}

.market-summary-card__inner {
  min-height: 390px;
  display: flex;
  flex-direction: column;
  padding: 26px;
}

.market-dashboard__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
  padding-bottom: 18px;
  border-bottom: 1px solid rgba(18, 58, 90, 0.07);
}

.market-dashboard__head div > span,
.market-dashboard__head div > strong {
  display: block;
}

.market-dashboard__head div > span {
  margin-bottom: 5px;
  color: var(--accent);
  font-size: 0.66rem;
  font-weight: 850;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.market-dashboard__head div > strong {
  color: var(--ink);
  font-size: 1rem;
  font-weight: 850;
  letter-spacing: -0.015em;
}

.market-dashboard__live {
  flex: none;
  padding: 6px 10px;
  border-radius: 999px;
  background: color-mix(in srgb, var(--accent) 7%, white);
  color: var(--accent);
  font-size: 0.63rem;
  font-weight: 800;
}

.market-dashboard__primary {
  padding: 24px 4px 20px;
}

.market-dashboard__primary span,
.market-dashboard__primary strong,
.market-dashboard__primary small {
  display: block;
}

.market-dashboard__primary span {
  margin-bottom: 7px;
  color: var(--muted);
  font-size: 0.72rem;
  font-weight: 700;
}

.market-dashboard__primary strong {
  color: var(--ink);
  font-size: clamp(2.15rem, 3vw, 3rem);
  font-weight: 900;
  line-height: 0.98;
  letter-spacing: -0.055em;
}

.market-dashboard__primary small {
  margin-top: 8px;
  color: var(--muted);
  font-size: 0.68rem;
}

.market-dashboard__grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.market-dashboard__grid article {
  min-width: 0;
  min-height: 84px;
  display: flex;
  align-items: center;
  gap: 13px;
  padding: 15px 16px;
  border: 1px solid rgba(18, 58, 90, 0.075);
  border-radius: 11px;
  background: #fbfcfd;
}

.market-dashboard__icon {
  width: 38px;
  height: 38px;
  display: grid;
  place-items: center;
  flex: none;
  border-radius: 50%;
  background: color-mix(in srgb, var(--accent) 7%, white);
  color: color-mix(in srgb, var(--accent) 72%, #7f8a96);
  line-height: 0;
}

.market-dashboard__icon svg {
  display: block;
  width: 18px;
  height: 18px;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.45;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.market-dashboard__grid strong,
.market-dashboard__grid small {
  display: block;
}

.market-dashboard__grid strong {
  overflow: hidden;
  margin-bottom: 3px;
  color: var(--ink);
  font-size: 1rem;
  font-weight: 850;
  letter-spacing: -0.025em;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.market-dashboard__grid small {
  color: var(--muted);
  font-size: 0.67rem;
  line-height: 1.35;
}

.market-dashboard__explore {
  min-height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  margin-top: 12px;
  padding: 15px 17px;
  border-radius: 10px;
  background: var(--accent);
  color: #fff !important;
  text-decoration: none;
}

.market-dashboard__explore strong,
.market-dashboard__explore small {
  display: block;
}

.market-dashboard__explore strong {
  margin-bottom: 4px;
  font-size: 0.8rem;
  font-weight: 850;
}

.market-dashboard__explore small {
  color: rgba(255, 255, 255, 0.72);
  font-size: 0.64rem;
}

.market-dashboard__explore b {
  flex: none;
  font-size: 0.95rem;
  transition: transform 160ms ease;
}

.market-dashboard__explore:hover b {
  transform: translateX(3px);
}

