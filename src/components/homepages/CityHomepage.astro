  <ShortlistReviewModal />
  <IntentModalController />

 <script is:inline define:vars={{ chartData }}>
  window.addEventListener("DOMContentLoaded", () => {
      if (!window.Chart) {
        console.error("Chart.js did not load");
        return;
      }

      const priceCanvas = document.getElementById("priceChart");
      const areaCanvas  = document.getElementById("areaChart");
      if (!priceCanvas || !areaCanvas) return;

      const sharedOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { displayColors: false },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { maxRotation: 0, minRotation: 0, font: { size: 10 } },
          },
          y: {
            beginAtZero: true,
            border: { display: false },
            grid: { color: "rgba(28,25,23,0.08)" },
            ticks: { precision: 0, font: { size: 10 } },
          },
        },
      };

      new Chart(priceCanvas, {
        type: "bar",
        data: {
          labels: chartData.priceLabels,
          datasets: [{ label: "Listings", data: chartData.priceCounts }],
        },
        options: sharedOptions,
      });

      new Chart(areaCanvas, {
        type: "bar",
        data: {
          labels: chartData.areaLabels,
          datasets: [{ label: "Listings", data: chartData.areaCounts }],
        },
        options: sharedOptions,
      });
    });
  </script>
  <script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const select = document.getElementById("area-nav-select");

    select?.addEventListener("change", (e) => {
      const value = e.target.value;
      if (value) {
        window.location.href = value;
      }
    });
  });
</script>
</Layout>

<style>
  /* ── Shell / layout ── */
.shell {
  width: min(1220px, calc(100% - 64px));
  margin: 0 auto;
  padding: 0;
}

@media (max-width: 640px) {
  .shell {
    width: 100%;
    padding-right: 14px;
    padding-left: 14px;
  }
}

  /* ── Area browse nav ── */
  .area-browse-nav {
    background: #fff;
    border-bottom: 1px solid rgba(28,25,23,0.1);
    position: sticky;
    top: 0;
    z-index: 40;
  }

.area-browse-nav__inner {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 18px 0 20px;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none;
  }

  .area-browse-nav__inner::-webkit-scrollbar { display: none; }

.area-browse-nav__inner > span {
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    flex-shrink: 0;
    margin-right: 8px;
  }

.area-browse-nav a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 0 15px;
    border-radius: 6px;
    background: color-mix(in srgb, var(--accent) 7%, white);
    border: 0.5px solid rgba(0,0,0,0.12);
    font-size: 0.84rem;
    font-weight: 750;
    color: var(--muted);
    text-decoration: none;
    transition: all 0.15s ease;
    flex-shrink: 0;
  }

  .area-browse-nav a:hover,
  .area-browse-nav a.active {
    background: var(--accent-soft);
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
  }

  .area-browse-nav select {
    appearance: none;
    border: 1px solid rgba(28,25,23,0.22);
    border-radius: 6px;
    background: #fff;
    color: #332f2b;
    font: inherit;
    font-size: 0.78rem;
    font-weight: 700;
    padding: 7px 34px 7px 14px;
    cursor: pointer;
    background-image: linear-gradient(45deg, transparent 50%, currentColor 50%), linear-gradient(135deg, currentColor 50%, transparent 50%);
    background-position: calc(100% - 17px) 50%, calc(100% - 12px) 50%;
    background-size: 5px 5px, 5px 5px;
    background-repeat: no-repeat;
  }

  /* ── Main shell spacing ── */
  main.shell { padding-top: 40px; padding-bottom: 100px; }

  /* ── Section heading ── */
  .section-heading { margin-bottom: 28px; }
  .section-heading .eyebrow {
    display: block;
    margin-bottom: 8px;
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .section-heading h2 {
    margin: 0 0 8px;
    font-family: var(--f-display, Georgia, serif);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    line-height: 1.0;
    letter-spacing: -0.045em;
    font-weight: 500;
  }
  .section-heading p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
    max-width: 560px;
  }

  /* ── Stats row ── */
  .area-stats {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
    margin-bottom: 40px;
  }

  .stat-card {
    background: #fff;
    border: 0.5px solid rgba(0,0,0,0.1);
    border-radius: 12px;
    padding: 16px 18px;
  }

  .stat-card strong {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 4px;
    letter-spacing: -0.03em;
  }

  .stat-card span {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ── Listings section ── */
  .listings-section { margin-bottom: 54px; }

  .listing-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
   
  }

  /* ── Market insights (mi-*) — matches area slug ── */
  .market-row { display: flex; flex-direction: column; gap: 12px; margin-bottom: 54px; }

  .mi-stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .mi-stat { background: #fff; border: 0.5px solid rgba(0,0,0,0.1); border-radius: 8px; padding: 12px 16px; }
  .mi-stat-label { font-size: 11px; color: #888; margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.06em; }
  .mi-stat-val { font-size: 24px; font-weight: 700; color: #1a1a1a; margin: 0 0 2px; }
  .mi-stat-sub { font-size: 11px; color: #aaa; margin: 0; }

  .mi-top { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .mi-bottom-row { display: flex; flex-direction: column; gap: 12px; }

  .mi-card {
    background: #fff;
    border: 0.5px solid rgba(0,0,0,0.1);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .mi-card .eyebrow {
    display: block;
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 6px;
  }

  .mi-card h2 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 1rem;
    color: #1a1a1a;
  }

  /* ── Area card grid (Browse by Area) ── */
  .content-card { padding: 0 0 54px; }

  .area-picker { padding-top: 0; }
  .area-picker .section-heading { max-width: 720px; margin-bottom: 22px; }

  .area-card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

.area-pick-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 18px;
    border-radius: 8px;
    border: 1px solid rgba(0,0,0,0.08);
    background: color-mix(in srgb, var(--accent) calc(var(--card-tint, 6%)), white);
    color: inherit;
    text-decoration: none;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }

  .area-pick-card:hover {
    transform: translateY(-2px);
    border-color: rgba(0,0,0,0.18);
    box-shadow: 0 6px 18px rgba(0,0,0,0.07);
  }

  .area-pick-card strong {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
    font-family: inherit;
    letter-spacing: normal;
    padding: 0;
    background: none;
    border: none;
  }

.area-pick-count {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--muted);
  }

  .area-card-link {
    margin-top: 4px;
    color: var(--accent);
    font-size: 0.84rem;
    font-weight: 700;
  }

  /* ── Charts ── */
  .chart-card {
    background: #fff;
    border: 0.5px solid rgba(0,0,0,0.1);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .chart-card .eyebrow {
    display: block;
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 4px;
  }

  .chart-card h2 {
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    color: #1a1a1a;
  }

  .chart-wrap {
    position: relative;
    height: 220px;
    min-height: 220px;
  }

  .chart-wrap canvas {
    width: 100% !important;
    height: 100% !important;
  }

  /* ── Intent interrupter ── */
  .intent-interrupter { margin: 0 0 54px; }

 .intent-interrupter__inner {
    padding: 48px;
    border-radius: 10px;
    background: #181614;
    color: #fff;
  }

  .intent-interrupter h2 {
    margin: 0 0 12px;
    font-family: var(--f-display, Georgia, serif);
    font-size: clamp(2.4rem, 4vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
    font-weight: 500;
    color: #fff;
  }

  .intent-interrupter p {
    max-width: 620px;
    margin-bottom: 30px;
    color: rgba(255,255,255,0.72);
  }

  .intent-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

.intent-tile {
    display: block;
    padding: 22px;
    border-radius: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .intent-tile:hover {
    transform: translateY(-3px);
    background: rgba(255,255,255,0.1);
  }

  .intent-tile strong { display: block; margin-bottom: 8px; font-size: 1rem; color: #fff; }
  .intent-tile span { display: block; color: rgba(255,255,255,0.68); font-size: 0.9rem; line-height: 1.5; }

  /* ── Popular searches ── */
  .content-card h2 {
    font-family: var(--f-display, Georgia, serif);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
    font-weight: 500;
    margin-bottom: 20px;
  }

  .content-card ul {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
    list-style: none;
    margin-top: 18px;
    padding: 0;
  }

.content-card li a {
    display: block;
    padding: 18px;
    border-radius: 6px;
    background: #fff;
    border: 1px solid rgba(28,25,23,0.1);
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .content-card li a:hover {
    transform: translateY(-2px);
    border-color: var(--accent-light);
    box-shadow: 0 12px 28px rgba(28,25,23,0.08);
  }
.listing-grid {
  margin-bottom: 32px;
}
  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .area-stats { grid-template-columns: repeat(3, 1fr); }
    .listing-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .area-card-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  @media (max-width: 760px) {
    .area-stats { grid-template-columns: repeat(2, 1fr); }
    .listing-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .area-card-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .mi-top { grid-template-columns: 1fr; }
    .intent-grid { grid-template-columns: 1fr; }
    .intent-interrupter__inner { padding: 28px; }
    .mi-stats-row { grid-template-columns: 1fr; }
  }

  @media (max-width: 500px) {
    .area-stats { grid-template-columns: 1fr; }
    .listing-grid { grid-template-columns: 1fr; }
    .area-card-grid { grid-template-columns: 1fr; }
  }

  @media (min-width: 760px) {
    .area-card-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  @media (min-width: 1100px) {
    .area-card-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }
/* =========================================================
   SAME GEOMETRY AS SLUG PAGES
   ========================================================= */

.page {
  width: 100%;
  max-width: none;
  margin: 0;
  padding: 0 0 80px;
}

.is-type-page {
  background:
    radial-gradient(
      circle at 50% 0%,
      rgba(18, 58, 90, 0.025),
      transparent 36%
    ),
    #fbfcfd;
}

.is-type-page .intent-content-shell {
  width: min(1220px, calc(100% - 80px));
  margin: 0 auto;
  padding: 24px 20px 0;
}



.type-hero {
  display: grid;
  grid-template-columns:
    minmax(0, 0.88fr)
    minmax(460px, 1.12fr);
  gap: 44px;
  align-items: stretch;
  margin-bottom: 26px;
}

.type-hero__copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
  min-height: 390px;
  padding: 28px 0;
}

.type-hero__eyebrow {
  margin: 0 0 16px;
  color: var(--accent);
  font-size: 0.72rem;
  font-weight: 850;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.type-hero h1 {
  max-width: 630px;
  margin: 0;
  color: var(--ink);
  font-family: Georgia, "Times New Roman", serif;
  font-size: clamp(2.9rem, 5vw, 5rem);
  font-weight: 500;
  letter-spacing: -0.058em;
  line-height: 0.98;
}

.type-hero h1 > span {
  color: var(--accent);
}

.type-hero__copy > p:not(.type-hero__eyebrow) {
  max-width: 590px;
