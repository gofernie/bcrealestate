          "function"
      ) {
        window.openSheet(card);
      }
    };
  }
);

     

      homeListingMarkers.push(
        marker
      );

      bounds.extend([
        listing.lat,
        listing.lng,
      ]);
    }
  );

  if (bounds.isValid()) {
    homeListingMap.fitBounds(
      bounds,
      {
        padding: [36, 36],
        maxZoom: 14,
      }
    );
  }

  window.setTimeout(
    () => {
      homeListingMap?.invalidateSize();
    },
    100
  );
};

const setHomepageView = (
  view
) => {
  const listView =
    document.querySelector(
      "[data-home-list-view]"
    );

  const mapView =
    document.querySelector(
      "[data-home-map-view]"
    );

    const pagination =
  document.querySelector(
    ".bc-pagination"
  );

  document
    .querySelectorAll(
      "[data-home-view]"
    )
    .forEach(
      (button) => {
        const isActive =
          button.dataset.homeView ===
          view;

        button.classList.toggle(
          "is-active",
          isActive
        );

        button.setAttribute(
          "aria-pressed",
          String(isActive)
        );
      }
    );

  if (
    listView instanceof HTMLElement
  ) {
    listView.hidden =
      view !== "list";

    listView.classList.toggle(
      "is-active",
      view === "list"
    );
  }

  if (
    mapView instanceof HTMLElement
  ) {
    mapView.hidden =
      view !== "map";

    mapView.classList.toggle(
      "is-active",
      view === "map"
    );
  }
if (
  pagination instanceof HTMLElement
) {
  pagination.style.display =
    view === "map"
      ? "none"
      : "";
}
  if (view === "map") {
    requestAnimationFrame(
      initializeHomepageMap
    );
  }
};

document.addEventListener(
  "click",
  (event) => {
    const target =
      event.target;

    if (
      !(target instanceof Element)
    ) {
      return;
    }

    const viewButton =
      target.closest(
        "[data-home-view]"
      );

    if (
      !(
        viewButton instanceof
        HTMLButtonElement
      )
    ) {
      return;
    }

    setHomepageView(
      viewButton.dataset
        .homeView || "list"
    );
  }
);
window.addEventListener(
  "popstate",
    () => {
      loadSearchUrl(
        new URL(
          window.location.href
        ),
        {
          updateHistory: false,
          scrollToResults: false,
        }
      );
    }
  );
