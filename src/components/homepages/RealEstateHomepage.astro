---
import ListingCard from "../ListingCard.astro";
import IntentModalController from "../IntentModalController.astro";

interface LocationCard {
  city?: string;
  area?: string;
  label: string;
  href: string;
  count: number;
  image?: string;
}

interface Filters {
  city?: string;
  type?: string;
  areas?: string[];

  beds?: number | null;
  baths?: number | null;

  minPrice?: number | null;
  maxPrice?: number | null;

  minSqft?: number | null;
  maxSqft?: number | null;

  sort?: string;
  page?: number;
}

interface Props {
  site?: any;
  listings?: any[];
  locationCards?: LocationCard[];
  mode?: "province" | "city";
  city?: string;

  filters?: Filters;
  totalMatchingCount?: number;
  currentPage?: number;
  totalPages?: number;
  pageSize?: number;
  paginationStart?: number;
  paginationEnd?: number;
  hasPreviousPage?: boolean;
  hasNextPage?: boolean;
  previousPageHref?: string | null;
  nextPageHref?: string | null;
}

const {
  site,
  listings = [],
  locationCards = [],
  mode = "province",
  city = "",

  filters = {},
  totalMatchingCount = listings.length,
  currentPage = 1,
  totalPages = 1,
  paginationStart = listings.length > 0 ? 1 : 0,
  paginationEnd = listings.length,
  hasPreviousPage = false,
  hasNextPage = false,
  previousPageHref = null,
  nextPageHref = null,
} = Astro.props;

const isCityMode =
  mode === "city";

const locationName =
  isCityMode
    ? city
        .replace(/-/g, " ")
        .replace(
          /\b\w/g,
          (letter) =>
            letter.toUpperCase()
        )
    : "British Columbia";

const heroEyebrow =
  isCityMode
    ? `Real estate in ${locationName}, British Columbia`
    : "Real estate across British Columbia";

const heroTitle =
  isCityMode
    ? `Find your place in ${locationName}.`
    : "Find your place in British Columbia.";

const heroCopy =
  isCityMode
    ? `Explore homes, condos, townhomes, and land across ${locationName}’s neighbourhoods.`
    : "Explore homes, condos, townhomes, and land across British Columbia’s most desirable communities.";

const browseEyebrow =
  isCityMode
    ? "Browse by neighbourhood"
    : "Browse by city";

const browseHeading =
  isCityMode
    ? `Explore ${locationName} neighbourhoods`
    : "Explore BC markets";

const accent =
  site?.accent_color ||
  "#1f5a49";

const featuredLocations =
  locationCards.slice(0, 6);

const totalListings =
  locationCards.reduce(
    (total, location) =>
      total +
      Number(
        location.count || 0
      ),
    0
  ) ||
  totalMatchingCount;

const selectedAreas =
  Array.isArray(
    filters.areas
  )
    ? filters.areas
    : [];

const hasActiveFilters =
  Boolean(
    filters.city ||
    filters.type ||
    selectedAreas.length ||
    filters.beds !== null &&
      filters.beds !== undefined ||
    filters.baths !== null &&
      filters.baths !== undefined ||
    filters.minPrice !== null &&
      filters.minPrice !== undefined ||
    filters.maxPrice !== null &&
      filters.maxPrice !== undefined ||
    filters.minSqft !== null &&
      filters.minSqft !== undefined ||
    filters.maxSqft !== null &&
      filters.maxSqft !== undefined ||
    filters.sort &&
      filters.sort !== "newest"
  );
  const formatPrice = (
  value: number
) => {
  if (value >= 1000000) {
    return `$${Number(
      (value / 1000000).toFixed(1)
    )}M`;
  }

  return `$${Math.round(
    value / 1000
  )}k`;
};

const priceFilterLabel = (() => {
  const min =
    filters.minPrice;

  const max =
    filters.maxPrice;

  if (
    min !== null &&
    min !== undefined &&
    max !== null &&
    max !== undefined
  ) {
    return `${formatPrice(
      min
    )}–${formatPrice(max)}`;
  }

  if (
    min !== null &&
    min !== undefined
  ) {
    return `${formatPrice(
      min
    )}+`;
  }

  if (
    max !== null &&
    max !== undefined
  ) {
    return `Under ${formatPrice(
      max
    )}`;
  }

  return "";
})();

const clearHref =
  isCityMode
    ? `/${city}`
    : "/";

const formAction =
  isCityMode
    ? `/${city}`
    : "/";

const fallbackLocationImages = [
  "https://images.unsplash.com/photo-1559511260-66a654ae982a?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1500534314209-a25ddb2bd4297?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1486911278844-a81c5267e227?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1464278533981-50106e6176b1?auto=format&fit=crop&w=1200&q=78",
];

const formatCount = (
  value: number
) =>
  Number(value || 0)
    .toLocaleString();

const visiblePages = (() => {
  const pages: number[] = [];
  const start = Math.max(
    1,
    currentPage - 2
  );
  const end = Math.min(
    totalPages,
    currentPage + 2
  );

  for (
    let page = start;
    page <= end;
    page += 1
  ) {
    pages.push(page);
  }

  return pages;
})();

const buildPageHref = (
  page: number
) => {
  const params =
    new URLSearchParams();

  if (filters.city) {
    params.set(
      "city",
      filters.city
    );
  }

  if (filters.type) {
    params.set(
      "type",
      filters.type
    );
  }

  for (
    const area of selectedAreas
  ) {
    params.append(
      "area",
      area
    );
  }

  if (
  filters.beds !== null &&
  filters.beds !== undefined
) {
  params.set(
    "beds",
    String(filters.beds)
  );
}

if (
  filters.baths !== null &&
  filters.baths !== undefined
) {
  params.set(
    "baths",
    String(filters.baths)
  );
}

if (
  filters.minPrice !== null &&
  filters.minPrice !== undefined
) {
  params.set(
    "minPrice",
    String(
      filters.minPrice
    )
  );
}

if (
  filters.maxPrice !== null &&
  filters.maxPrice !== undefined
) {
  params.set(
    "maxPrice",
    String(
      filters.maxPrice
    )
  );
}

if (
  filters.minSqft !== null &&
  filters.minSqft !== undefined
) {
  params.set(
    "minSqft",
    String(
      filters.minSqft
    )
  );
}

if (
  filters.maxSqft !== null &&
  filters.maxSqft !== undefined
) {
  params.set(
    "maxSqft",
    String(
      filters.maxSqft
    )
  );
}

  if (
    filters.sort &&
    filters.sort !== "newest"
  ) {
    params.set(
      "sort",
      filters.sort
    );
  }

  if (page > 1) {
    params.set(
      "page",
      String(page)
    );
  }

  const queryString =
    params.toString();

  return queryString
    ? `${formAction}?${queryString}`
    : formAction;
};
---

<div
  class:list={[
    "bc-homepage",
    {
      "bc-homepage--city":
        isCityMode,
    },
  ]}
  style={`--bc-home-accent: ${accent};`}
>
  <section class="bc-hero">
    <div
      class="bc-hero__overlay"
    ></div>

    <div
      class="bc-hero__inner"
    >
      <div
        class="bc-hero__content"
      >
        <p class="bc-eyebrow">
          {heroEyebrow}
        </p>

        <h1>{heroTitle}</h1>

        <p
          class="bc-hero__copy"
        >
          {heroCopy}
        </p>
      </div>
    </div>
  </section>

  <div class="bc-search-wrap">
    <form
      class:list={[
        "bc-search",
        {
          "bc-search--city":
            isCityMode,
        },
      ]}
      method="GET"
      action={formAction}
    >
    {
  filters.baths !== null &&
  filters.baths !== undefined && (
    <input
      type="hidden"
      name="baths"
      value={filters.baths}
    />
  )
}

{
  filters.minPrice !== null &&
  filters.minPrice !== undefined && (
    <input
      type="hidden"
      name="minPrice"
      value={filters.minPrice}
    />
  )
}

{
  filters.minSqft !== null &&
  filters.minSqft !== undefined && (
    <input
      type="hidden"
      name="minSqft"
      value={filters.minSqft}
    />
  )
}

{
  filters.maxSqft !== null &&
  filters.maxSqft !== undefined && (
    <input
      type="hidden"
      name="maxSqft"
      value={filters.maxSqft}
    />
  )
}
      {
        !isCityMode && (
          <label class="bc-search__field">
            <span class="bc-search__icon">
              <svg
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d="M12 21s7-6.2 7-12A7 7 0 0 0 5 9c0 5.8 7 12 7 12Z"></path>
                <circle
                  cx="12"
                  cy="9"
                  r="2.4"
                ></circle>
              </svg>
            </span>

            <span class="bc-search__content">
              <strong>
                Market
              </strong>

              <select
                name="city"
              >
                <option value="">
                  All markets
                </option>

                {
                  locationCards
                    .filter(
                      (location) =>
                        location.city
                    )
                    .map(
                      (location) => (
                        <option
                          value={String(
                            location.city
                          ).toLowerCase()}
                          selected={
                            filters.city ===
                            String(
                              location.city
                            ).toLowerCase()
                          }
                        >
                          {
                            location.label
                          }
                        </option>
                      )
                    )
                }
              </select>
            </span>
          </label>
        )
      }

      <label
        class="bc-search__field"
      >
        <span
          class="bc-search__icon"
        >
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M3 11.5 12 4l9 7.5"></path>
            <path d="M5.5 10.5V21h13V10.5"></path>
            <path d="M9.5 21v-6h5v6"></path>
          </svg>
        </span>

        <span
          class="bc-search__content"
        >
          <strong>
            Property type
          </strong>

          <select name="type">
            <option value="">
              Any type
            </option>
            <option
              value="house"
              selected={
                filters.type ===
                "house"
              }
            >
              Homes
            </option>
            <option
              value="condo"
              selected={
                filters.type ===
                "condo"
              }
            >
              Condos
            </option>
            <option
              value="townhouse"
              selected={
                filters.type ===
                "townhouse"
              }
            >
              Townhomes
            </option>
            <option
              value="mobile"
              selected={
                filters.type ===
                "mobile"
              }
            >
              Mobile homes
            </option>
            <option
              value="land"
              selected={
                filters.type ===
                "land"
              }
            >
              Land
            </option>
          </select>
        </span>
      </label>

      <label
        class="bc-search__field"
      >
        <span
          class="bc-search__icon"
        >
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M12 21s7-6.2 7-12A7 7 0 0 0 5 9c0 5.8 7 12 7 12Z"></path>
            <circle
              cx="12"
              cy="9"
              r="2.4"
            ></circle>
          </svg>
        </span>

        <span
          class="bc-search__content"
        >
          <strong>
            Area
          </strong>

          <select
            name="area"
            multiple
            size="1"
            aria-label="Neighbourhoods"
          >
            {
              locationCards
                .filter(
                  (location) =>
                    location.area
                )
                .map(
                  (location) => (
                    <option
                      value={
                        location.area
                      }
                      selected={selectedAreas.includes(
                        String(
                          location.area
                        )
                      )}
                    >
                      {
                        location.label
                      }
                    </option>
                  )
                )
            }
          </select>
        </span>
      </label>

      <label
        class="bc-search__field"
      >
        <span
          class="bc-search__icon"
        >
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M3 18v-7h18v7"></path>
            <path d="M5 11V7h6v4"></path>
            <path d="M13 11V7h6v4"></path>
            <path d="M3 18v3"></path>
            <path d="M21 18v3"></path>
          </svg>
        </span>

        <span
          class="bc-search__content"
        >
          <strong>
            Beds
          </strong>

          <select name="beds">
            <option value="">
              Any
            </option>
            {
              [1, 2, 3, 4, 5].map(
                (beds) => (
                  <option
                    value={beds}
                    selected={
                      filters.beds ===
                      beds
                    }
                  >
                    {beds}+
                  </option>
                )
              )
            }
          </select>
        </span>
      </label>

      <label
        class="bc-search__field"
      >
        <span
          class="bc-search__icon"
        >
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <circle
              cx="12"
              cy="12"
              r="9"
            ></circle>
            <path d="M15 8.5c-.7-.7-1.7-1-3-1-1.7 0-3 .9-3 2.2 0 1.4 1.2 2 3.2 2.5 1.8.5 2.8 1.1 2.8 2.3 0 1.3-1.2 2.2-3 2.2-1.3 0-2.5-.4-3.3-1.2"></path>
            <path d="M12 5.5v13"></path>
          </svg>
        </span>

        <span
          class="bc-search__content"
        >
          <strong>
            Price
          </strong>

         <select
  name="maxPrice"
>
  {
    priceFilterLabel && (
      <option
        value={
          filters.maxPrice ??
          ""
        }
        selected
      >
        {priceFilterLabel}
      </option>
    )
  }

  <option
    value=""
    selected={
      !priceFilterLabel
    }
  >
    Any price
  </option>

  {
    [
      [
        500000,
        "Under $500,000",
      ],
      [
        700000,
        "Under $700,000",
      ],
      [
        900000,
        "Under $900,000",
      ],
      [
        1200000,
        "Under $1.2M",
      ],
      [
        1600000,
        "Under $1.6M",
      ],
      [
        2000000,
        "Under $2M",
      ],
    ].map(
      ([
        value,
        label,
      ]) => (
        <option
          value={value}
          selected={
            !filters.minPrice &&
            filters.maxPrice ===
              value
          }
        >
          {label}
        </option>
      )
    )
  }
</select>
        </span>
      </label>

      <label
        class="bc-search__field"
      >
        <span
          class="bc-search__icon"
        >
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M7 6h10"></path>
            <path d="M9 12h6"></path>
            <path d="M11 18h2"></path>
          </svg>
        </span>

        <span
          class="bc-search__content"
        >
          <strong>
            Sort
          </strong>

          <select name="sort">
            <option
              value="newest"
              selected={
                !filters.sort ||
                filters.sort ===
                  "newest"
              }
            >
              Newest
            </option>

            <option
              value="price-low"
              selected={
                filters.sort ===
                "price-low"
              }
            >
              Price: low to high
            </option>

            <option
              value="price-high"
              selected={
                filters.sort ===
                "price-high"
              }
            >
              Price: high to low
            </option>
          </select>
        </span>
      </label>

      <div
        class="bc-search__submit"
      >
        <button type="submit">
          Search
        </button>
      </div>
      </form>

    {
  hasActiveFilters && (
    <div class="bc-active-filters">
      {
        filters.baths !== null &&
        filters.baths !== undefined && (
          <span>
            {filters.baths}+ baths
          </span>
        )
      }

      {
        filters.minSqft !== null &&
        filters.minSqft !== undefined && (
          <span>
            {Number(
              filters.minSqft
            ).toLocaleString()}+ sq. ft.
          </span>
        )
      }

      {
        filters.maxSqft !== null &&
        filters.maxSqft !== undefined && (
          <span>
            Up to{" "}
            {Number(
              filters.maxSqft
            ).toLocaleString()}{" "}
            sq. ft.
          </span>
        )
      }

      <a href={clearHref}>
        Clear filters
      </a>
    </div>
  )
}
    <div
      class="bc-search-results__heading"
    >
      <div>
        <p class="bc-eyebrow">
          {
            isCityMode
              ? `Homes for sale in ${locationName}`
              : "Homes across BC"
          }
        </p>

        <h2>
          {formatCount(
            totalMatchingCount
          )}{" "}
          {
            totalMatchingCount ===
            1
              ? "property"
              : "properties"
          }
        </h2>

        <p
          class="bc-listing-description"
        >
          {
            totalMatchingCount >
            0
              ? `Showing ${formatCount(
                  paginationStart
                )}–${formatCount(
                  paginationEnd
                )} of ${formatCount(
                  totalMatchingCount
                )} properties`
              : "No matching properties"
          }
        </p>
      </div>

      {
        hasActiveFilters && (
          <a
            class="bc-clear-search"
            href={clearHref}
          >
            Clear filters
          </a>
        )
      }
    </div>

    {
      listings.length > 0 ? (
        <>
          <div
            class="bc-listing-grid"
          >
            {
              listings.map(
                (
                  listing,
                  index
                ) => (
                  <div class="bc-filterable-listing">
                    <ListingCard
                      listing={
                        listing
                      }
                      priority={
                        index < 4
                      }
                    />
                  </div>
                )
              )
            }
          </div>

          {
            totalPages > 1 && (
              <nav
                class="bc-pagination"
                aria-label="Listing pages"
              >
                {hasPreviousPage &&
                  previousPageHref && (
                    <a
                      class="bc-pagination__direction"
                      href={
                        previousPageHref
                      }
                    >
                      ← Previous
                    </a>
                  )}

                <div
                  class="bc-pagination__pages"
                >
                  {
                    visiblePages.map(
                      (page) => (
                        <a
                          class:list={[
                            "bc-pagination__page",
                            {
                              "is-active":
                                page ===
                                currentPage,
                            },
                          ]}
                          href={buildPageHref(
                            page
                          )}
                          aria-current={
                            page ===
                            currentPage
                              ? "page"
                              : undefined
                          }
                        >
                          {page}
