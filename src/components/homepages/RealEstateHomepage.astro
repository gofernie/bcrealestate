        </p>

        <a
          href={
            isCityMode
              ? `/${city}/areas`
              : "/explore"
          }
        >
          {
            isCityMode
              ? "View all neighbourhoods"
              : "View all markets"
          }
          <span aria-hidden="true">
            →
          </span>
        </a>
      </div>

      <div
        class="bc-market-grid"
      >
        {
          featuredLocations.map(
            (
              location,
              index
            ) => {
              const image =
                location.image ||
                fallbackLocationImages[
                  index %
                    fallbackLocationImages.length
                ];

              return (
                <a
                  class="bc-market-card"
                  href={
                    location.href
                  }
                  style={`--market-image: url('${image}')`}
                >
                  <div class="bc-market-card__shade"></div>

                  <div class="bc-market-card__content">
                    <strong>
                      {
                        location.label
                      }
                    </strong>

                    <span>
                      {formatCount(
                        location.count
                      )}{" "}
                      active{" "}
                      {
                        location.count ===
                        1
                          ? "listing"
                          : "listings"
                      }
                    </span>
                  </div>

                  <span
                    class="bc-market-card__arrow"
                    aria-hidden="true"
                  >
                    →
                  </span>
                </a>
              );
            }
          )
        }
      </div>
    </section>

    <section class="bc-benefits">
      <article class="bc-benefit">
        <span class="bc-benefit__icon">
          <svg viewBox="0 0 24 24">
            <path d="M3 11.5 12 4l9 7.5"></path>
            <path d="M5.5 10.5V21h13V10.5"></path>
            <path d="M9.5 21v-6h5v6"></path>
          </svg>
        </span>

        <div>
          <h3>Local knowledge</h3>
          <p>
            {
              isCityMode
                ? `Detailed insights into neighbourhoods across ${locationName}.`
                : "Detailed insights into communities across British Columbia."
            }
          </p>
        </div>
      </article>

      <article class="bc-benefit">
        <span class="bc-benefit__icon">
