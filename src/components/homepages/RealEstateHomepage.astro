          </p>

          <a href={clearHref}>
            Clear filters
          </a>
        </div>
      )
    }
  </section>

  <main class="bc-main">
    <section
      id="bc-markets"
      class="bc-markets"
    >
      <div
        class="bc-section-heading"
      >
        <div>
          <p class="bc-eyebrow">
            {browseEyebrow}
          </p>
          <h2>
            {browseHeading}
          </h2>
        </div>

        <p>
          {
            isCityMode
              ? `Explore ${locationName} neighbourhoods, listings, and local area guides.`
              : "Start with a city, then explore neighbourhoods, listings, and local guides."
