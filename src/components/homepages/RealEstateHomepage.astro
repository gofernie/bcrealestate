const initializeHomepageMap = async () => {
  const mapElement =
    document.querySelector(
      "[data-home-listing-map]"
    );

  const emptyElement =
    document.querySelector(
      "[data-home-map-empty]"
    );

  if (
    !(mapElement instanceof HTMLElement)
  ) {
    return;
  }

  const listings =
    getHomepageMapListings();

  if (!listings.length) {
    mapElement.hidden = true;

    if (
      emptyElement instanceof HTMLElement
    ) {
      emptyElement.hidden = false;
    }

    return;
  }

  mapElement.hidden = false;

  if (
    emptyElement instanceof HTMLElement
  ) {
    emptyElement.hidden = true;
  }

  await loadHomepageLeaflet();

  const accent =
    mapElement.dataset.accent ||
    "#1f5a49";

  if (!homeListingMap) {
    homeListingMap =
      window.L.map(
        mapElement,
        {
          zoomControl: true,
          scrollWheelZoom: false,
          attributionControl: true,
        }
      );

    window.L
      .tileLayer(
        "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
        {
          maxZoom: 19,
          attribution:
            "© OpenStreetMap contributors",
        }
      )
      .addTo(homeListingMap);
  }

  homeListingMarkers.forEach(
    (marker) =>
      marker.remove()
  );

  homeListingMarkers = [];

  const bounds =
    window.L.latLngBounds([]);

  const icon =
    createHomepageMapIcon(
      accent
    );

  listings.forEach(
    (listing) => {
     const marker =
  window.L.marker(
    [
      listing.lat,
      listing.lng,
    ],
    {
      icon,
    }
  )
    .addTo(
      homeListingMap
    )
    .bindPopup(
      buildHomepageMapPopup(
        listing
      ),
      {
        maxWidth: 220,
        closeButton: false,
        className:
          "bc-home-map-popup-shell",
      }
    );

marker.on(
