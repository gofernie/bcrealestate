---
import ListingCard from "../ListingCard.astro";
import IntentModalController from "../IntentModalController.astro";
import AreaMultiSelect from "../listings/AreaMultiSelect.astro";
import SingleSelectDropdown from "../listings/SingleSelectDropdown.astro";
interface LocationCard {
  city?: string;
  area?: string;
  label: string;
  href: string;
  count: number;
  image?: string;
}

interface Filters {
  city?: string;
  type?: string;
  areas?: string[];

  beds?: number | null;
  baths?: number | null;

  minPrice?: number | null;
  maxPrice?: number | null;

  minSqft?: number | null;
  maxSqft?: number | null;

  sort?: string;
  page?: number;
}

interface Props {
  site?: any;
  heroImageUrl?: string;
  listings?: any[];
  mapListings?: any[];
  locationCards?: LocationCard[];
  mode?: "province" | "city";
  city?: string;

  filters?: Filters;
  totalMatchingCount?: number;
  currentPage?: number;
  totalPages?: number;
  pageSize?: number;
  paginationStart?: number;
  paginationEnd?: number;
  hasPreviousPage?: boolean;
  hasNextPage?: boolean;
  previousPageHref?: string | null;
  nextPageHref?: string | null;
}

const {
  site,
  heroImageUrl = "",
  listings = [],
  mapListings = listings,
  locationCards = [],
  mode = "province",
  city = "",

  filters = {},
  totalMatchingCount = listings.length,
  currentPage = 1,
  totalPages = 1,
  paginationStart = listings.length > 0 ? 1 : 0,
  paginationEnd = listings.length,
  hasPreviousPage = false,
  hasNextPage = false,
  previousPageHref = null,
  nextPageHref = null,
} = Astro.props;
const visibleListingIds = new Set(
  listings
    .map((listing) =>
      String(
        listing?.id ||
        listing?.mls_number ||
        ""
      )
    )
    .filter(Boolean)
);

const modalOnlyListings =
  mapListings.filter((listing) => {
    const listingId = String(
      listing?.id ||
      listing?.mls_number ||
      ""
    );

    return (
      listingId &&
      !visibleListingIds.has(listingId)
    );
  });
const isCityMode =
  mode === "city";

const locationName =
  isCityMode
    ? city
        .replace(/-/g, " ")
        .replace(
          /\b\w/g,
          (letter) =>
            letter.toUpperCase()
        )
    : "British Columbia";

const heroEyebrow =
  isCityMode
    ? `Real estate in ${locationName}, British Columbia`
    : "Real estate across British Columbia";

const heroTitle =
  isCityMode
    ? `Find your place in ${locationName}.`
    : "Find your place in British Columbia.";

const heroCopy =
  isCityMode
    ? `Explore homes, condos, townhomes, and land across ${locationName}’s neighbourhoods.`
    : "Explore homes, condos, townhomes, and land across British Columbia’s most desirable communities.";

const browseEyebrow =
  isCityMode
    ? "Browse by neighbourhood"
    : "Browse by city";

const browseHeading =
  isCityMode
    ? `Explore ${locationName} neighbourhoods`
    : "Explore BC markets";

const accent =
  site?.accent_color ||
  "#1f5a49";

const featuredLocations =
  locationCards.slice(0, 6);

const totalListings =
  locationCards.reduce(
    (total, location) =>
      total +
      Number(
        location.count || 0
      ),
    0
  ) ||
  totalMatchingCount;

const selectedAreas =
  Array.isArray(
    filters.areas
  )
    ? filters.areas
    : [];

const hasActiveFilters =
  Boolean(
    filters.city ||
    filters.type ||
    selectedAreas.length ||
    filters.beds !== null &&
      filters.beds !== undefined ||
    filters.baths !== null &&
      filters.baths !== undefined ||
    filters.minPrice !== null &&
      filters.minPrice !== undefined ||
    filters.maxPrice !== null &&
      filters.maxPrice !== undefined ||
    filters.minSqft !== null &&
      filters.minSqft !== undefined ||
    filters.maxSqft !== null &&
      filters.maxSqft !== undefined ||
    filters.sort &&
      filters.sort !== "newest"
  );
  const formatPrice = (
  value: number
) => {
  if (value >= 1000000) {
    return `$${Number(
      (value / 1000000).toFixed(1)
    )}M`;
  }

  return `$${Math.round(
    value / 1000
  )}k`;
};

const priceFilterLabel = (() => {
  const min =
    filters.minPrice;

  const max =
    filters.maxPrice;

  if (
    min !== null &&
    min !== undefined &&
    max !== null &&
    max !== undefined
  ) {
    return `${formatPrice(
      min
    )}–${formatPrice(max)}`;
  }

  if (
    min !== null &&
    min !== undefined
  ) {
    return `${formatPrice(
      min
    )}+`;
  }

  if (
    max !== null &&
    max !== undefined
  ) {
    return `Under ${formatPrice(
      max
    )}`;
  }

  return "";
})();

const marketOptions = locationCards
  .filter(
    (
      location
    ): location is LocationCard & {
      city: string;
    } => Boolean(location.city)
  )
  .filter(
    (location, index, all) =>
      all.findIndex(
        (candidate) =>
          candidate.city ===
          location.city
      ) === index
  )
  .map((location) => ({
    value: String(
      location.city
    ).toLowerCase(),
    label: location.label,
  }));
const propertyTypeResultLabels: Record<
  string,
  string
> = {
  house: "Homes",
  condo: "Condos",
  townhouse: "Townhomes",
  mobile: "Mobile homes",
  land: "Land",
};

const resultPropertyLabel =
  propertyTypeResultLabels[
    String(filters.type || "")
      .toLowerCase()
  ] || "Homes";

const selectedAreaLabels =
  selectedAreas.map((areaSlug) => {
    const matchingLocation =
      locationCards.find(
        (location) =>
          String(location.area || "")
            .toLowerCase() ===
          String(areaSlug || "")
            .toLowerCase()
      );

    return (
      matchingLocation?.label ||
      String(areaSlug || "")
        .replace(/-/g, " ")
        .replace(
          /\b\w/g,
          (letter) =>
            letter.toUpperCase()
        )
    );
  });

const resultLocationLabel =
  selectedAreaLabels.length === 1
    ? selectedAreaLabels[0]
    : locationName;

const resultsEyebrow =
  isCityMode
    ? `${resultPropertyLabel} for sale in ${resultLocationLabel}`
    : `${resultPropertyLabel} for sale across British Columbia`;

const propertyTypeOptions = [
  {
    value: "house",
    label: "Homes",
  },
  {
    value: "condo",
    label: "Condos",
  },
  {
    value: "townhouse",
    label: "Townhomes",
  },
  {
    value: "mobile",
    label: "Mobile homes",
  },
  {
    value: "land",
    label: "Land",
  },
];

const bedOptions = [
  {
    value: "1",
    label: "1+ beds",
  },
  {
    value: "2",
    label: "2+ beds",
  },
  {
    value: "3",
    label: "3+ beds",
  },
  {
    value: "4",
    label: "4+ beds",
  },
  {
    value: "5",
    label: "5+ beds",
  },
];

const priceOptions = [
  {
    value: "500000",
    label: "Under $500,000",
  },
  {
    value: "700000",
    label: "Under $700,000",
  },
  {
    value: "900000",
    label: "Under $900,000",
  },
  {
    value: "1200000",
    label: "Under $1.2M",
  },
  {
    value: "1600000",
    label: "Under $1.6M",
  },
  {
    value: "2000000",
    label: "Under $2M",
  },
];

const sortOptions = [
  {
    value: "newest",
    label: "Newest",
  },
  {
    value: "price-low",
    label: "Price: low to high",
  },
  {
    value: "price-high",
    label: "Price: high to low",
  },
];

const clearHref =
  isCityMode
    ? `/${city}`
    : "/";

const formAction =
  isCityMode
    ? `/${city}`
    : "/";

const fallbackLocationImages = [
  "https://images.unsplash.com/photo-1559511260-66a654ae982a?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1500534314209-a25ddb2bd4297?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1486911278844-a81c5267e227?auto=format&fit=crop&w=1200&q=78",
  "https://images.unsplash.com/photo-1464278533981-50106e6176b1?auto=format&fit=crop&w=1200&q=78",
];

const formatCount = (
  value: number
) =>
  Number(value || 0)
    .toLocaleString();

const visiblePages = (() => {
  const pages: number[] = [];
  const start = Math.max(
    1,
    currentPage - 2
  );
  const end = Math.min(
    totalPages,
    currentPage + 2
  );

  for (
    let page = start;
    page <= end;
    page += 1
  ) {
    pages.push(page);
  }

  return pages;
})();

const buildPageHref = (
  page: number
) => {
  const params =
    new URLSearchParams();

  if (filters.city) {
    params.set(
      "city",
      filters.city
    );
  }

  if (filters.type) {
    params.set(
      "type",
      filters.type
    );
  }

  for (
    const area of selectedAreas
  ) {
    params.append(
      "area",
      area
    );
  }

  if (
  filters.beds !== null &&
  filters.beds !== undefined
) {
  params.set(
    "beds",
    String(filters.beds)
  );
}

if (
  filters.baths !== null &&
  filters.baths !== undefined
) {
  params.set(
    "baths",
    String(filters.baths)
  );
}

if (
  filters.minPrice !== null &&
  filters.minPrice !== undefined
) {
  params.set(
    "minPrice",
    String(
      filters.minPrice
    )
  );
}

if (
  filters.maxPrice !== null &&
  filters.maxPrice !== undefined
) {
  params.set(
    "maxPrice",
    String(
      filters.maxPrice
    )
  );
}

if (
  filters.minSqft !== null &&
  filters.minSqft !== undefined
) {
  params.set(
    "minSqft",
    String(
      filters.minSqft
    )
  );
}

if (
  filters.maxSqft !== null &&
  filters.maxSqft !== undefined
) {
  params.set(
    "maxSqft",
    String(
      filters.maxSqft
    )
  );
}

  if (
    filters.sort &&
    filters.sort !== "newest"
  ) {
    params.set(
      "sort",
      filters.sort
    );
  }

  if (page > 1) {
    params.set(
      "page",
      String(page)
    );
  }

  const queryString =
    params.toString();

  return queryString
    ? `${formAction}?${queryString}`
    : formAction;
};
---

<div
  class:list={[
    "bc-homepage",
    {
      "bc-homepage--city":
        isCityMode,
    },
  ]}
  style={`--bc-home-accent: ${accent};`}
>
  <section
  class="bc-hero"
  style={
    heroImageUrl
      ? `--bc-hero-image: url("${heroImageUrl}");`
      : undefined
  }
>
    

    <div
      class="bc-hero__inner"
    >
      <div
        class="bc-hero__content"
      >
        <p class="bc-eyebrow">
          {heroEyebrow}
        </p>

        <h1>{heroTitle}</h1>

        <p
          class="bc-hero__copy"
        >
          {heroCopy}
        </p>
      </div>
    </div>
  </section>

  <div class="bc-search-wrap">
    <form
      class:list={[
        "bc-search",
        {
          "bc-search--city":
            isCityMode,
        },
      ]}
         method="GET"
      action={formAction}
      data-async-search-form
    >
    {
  filters.baths !== null &&
  filters.baths !== undefined && (
    <input
      type="hidden"
      name="baths"
      value={filters.baths}
    />
  )
}

{
  filters.minPrice !== null &&
  filters.minPrice !== undefined && (
    <input
      type="hidden"
      name="minPrice"
      value={filters.minPrice}
    />
  )
}

{
  filters.minSqft !== null &&
  filters.minSqft !== undefined && (
    <input
      type="hidden"
      name="minSqft"
      value={filters.minSqft}
    />
  )
}

{
  filters.maxSqft !== null &&
  filters.maxSqft !== undefined && (
    <input
      type="hidden"
      name="maxSqft"
      value={filters.maxSqft}
    />
  )
}
           {
        !isCityMode && (
          <SingleSelectDropdown
            label="Market"
            name="city"
            icon="location"
            defaultLabel="All markets"
            options={marketOptions}
            value={filters.city}
          />
        )
      }

      <SingleSelectDropdown
        label="Property type"
        name="type"
        icon="home"
        defaultLabel="Any type"
        options={propertyTypeOptions}
        value={filters.type}
      />

   {
  isCityMode && (
    <AreaMultiSelect
      locationCards={locationCards}
      selectedAreas={selectedAreas}
    />
  )
}

      <SingleSelectDropdown
        label="Beds"
        name="beds"
        icon="beds"
        defaultLabel="Any beds"
        options={bedOptions}
        value={filters.beds}
      />

      <SingleSelectDropdown
        label="Price"
        name="maxPrice"
        icon="price"
        defaultLabel="Any price"
        options={priceOptions}
        value={filters.maxPrice}
        summary={
          priceFilterLabel ||
          undefined
        }
        clearNames={[
          "minPrice",
        ]}
      />

      <SingleSelectDropdown
        label="Sort"
        name="sort"
        icon="sort"
        defaultLabel="Newest"
        options={sortOptions}
        value={
          filters.sort ||
          "newest"
        }
      />
     
         </form>

    <div data-async-search-results>
    {
  hasActiveFilters && (
    <div class="bc-active-filters">
      {
        filters.baths !== null &&
        filters.baths !== undefined && (
          <span>
            {filters.baths}+ baths
          </span>
        )
      }

      {
        filters.minSqft !== null &&
        filters.minSqft !== undefined && (
          <span>
            {Number(
              filters.minSqft
            ).toLocaleString()}+ sq. ft.
          </span>
        )
      }

      {
        filters.maxSqft !== null &&
        filters.maxSqft !== undefined && (
          <span>
            Up to{" "}
            {Number(
              filters.maxSqft
            ).toLocaleString()}{" "}
            sq. ft.
          </span>
        )
      }

      <a href={clearHref}>
        Clear filters
      </a>
    </div>
  )
}
    <div
  class:list={[
    "bc-search-results__heading",
    {
      "bc-search-results__heading--no-filters":
        !hasActiveFilters,
    },
  ]}
>
  <div>
    <p class="bc-eyebrow">
      {resultsEyebrow}
    </p>

    <h2>
      {formatCount(totalMatchingCount)}{" "}
      {totalMatchingCount === 1
        ? "property"
        : "properties"}
    </h2>

    <p class="bc-listing-description">
      {
        totalMatchingCount > 0
          ? `Showing ${formatCount(
              paginationStart
            )}–${formatCount(
              paginationEnd
            )} of ${formatCount(
              totalMatchingCount
            )} properties`
          : "No matching properties"
      }
    </p>
  </div>

  <div class="bc-results-heading__actions">
    {
      hasActiveFilters && (
        <a
          class="bc-clear-search"
          href={clearHref}
        >
          Clear filters
        </a>
      )
    }

    <div
      class="bc-view-toggle"
      role="group"
      aria-label="Choose listing view"
    >
      <button
        type="button"
        class="bc-view-toggle__button is-active"
        data-home-view="list"
        aria-pressed="true"
      >
        <span aria-hidden="true">☷</span>
        Listings
      </button>

      <button
        type="button"
        class="bc-view-toggle__button"
        data-home-view="map"
        aria-pressed="false"
      >
        <span aria-hidden="true">⌖</span>
        Map
      </button>
    </div>
  </div>
</div>

   {
      listings.length > 0 ? (
        <>
         

          <div
  class="bc-home-list-view is-active"
  data-home-list-view
>
<div class="bc-listing-grid">
  {
    listings.map(
      (listing, index) => (
        <div class="bc-filterable-listing">
          <ListingCard
            listing={listing}
            priority={index < 4}
          />
        </div>
      )
    )
  }
</div>

<div
  class="bc-modal-listing-sources"
  aria-hidden="true"
>
  {
    modalOnlyListings.map(
      (listing) => (
        <ListingCard
          listing={listing}
        />
      )
    )
  }
</div>

                </div>
<script
  id="homepage-map-data"
  type="application/json"
  set:html={JSON.stringify(
 mapListings.map((listing) => ({
  id:
    listing?.id ||
    listing?.mls_number ||
    "",

  href:
    listing?.listing_url ||
    listing?.href ||
    listing?.url ||
    "",

  lat: listing?.lat ?? null,
      lng: listing?.lng ?? null,
      price: listing?.price ?? null,
      address:
        typeof listing?.address ===
        "string"
          ? listing.address
          : [
              listing?.address
                ?.streetNumber,
              listing?.address
                ?.streetName ||
                listing?.address
                  ?.streetAddress,
              listing?.address
                ?.streetSuffix,
              listing?.address
                ?.unitNumber
                ? `#${listing.address.unitNumber}`
                : "",
            ]
              .filter(Boolean)
              .join(" "),
      beds: listing?.beds ?? null,
      baths: listing?.baths ?? null,
      image:
        listing?.image_url ||
        listing?.images?.[0]
          ?.highRes ||
        listing?.images?.[0]
          ?.mediumRes ||
        listing?.images?.[0]?.url ||
        listing?.images?.[0] ||
        "",
    }))
  ).replace(/</g, "\\u003c")}
/>
<div
  class="bc-home-map-view"
          data-home-map-view
          hidden
        >
          <div
            class="bc-home-listing-map"
            data-home-listing-map
            data-accent={accent}
            data-city={city}
          ></div>

          <div
            class="bc-home-map-empty"
            data-home-map-empty
            hidden
          >
            Map locations are not available for these listings.
          </div>
        </div>

          {
            totalPages > 1 && (
              <nav
                class="bc-pagination"
                aria-label="Listing pages"
              >
                {hasPreviousPage &&
                  previousPageHref && (
                    <a
                      class="bc-pagination__direction"
                      href={
                        previousPageHref
                      }
                    >
                      ← Previous
                    </a>
                  )}

                <div
                  class="bc-pagination__pages"
                >
                  {
                    visiblePages.map(
                      (page) => (
                        <a
                          class:list={[
                            "bc-pagination__page",
                            {
                              "is-active":
                                page ===
                                currentPage,
                            },
                          ]}
                          href={buildPageHref(
                            page
                          )}
                          aria-current={
                            page ===
                            currentPage
                              ? "page"
                              : undefined
                          }
                        >
                          {page}
                        </a>
                      )
                    )
                  }
                </div>

                {hasNextPage &&
                  nextPageHref && (
                    <a
                      class="bc-pagination__direction"
                      href={
                        nextPageHref
                      }
                    >
                      Next →
                    </a>
                  )}
              </nav>
            )
          }
        </>
      ) : (
        <div
          class="bc-search-results__empty"
        >
          <h3>
            No matching listings
          </h3>

          <p>
            {
              isCityMode
                ? "Try changing the neighbourhood, property type, bedroom count, or maximum price."
                : "Try changing the market, property type, bedroom count, or maximum price."
            }
          </p>

          <a href={clearHref}>
            Clear filters
          </a>
        </div>
      )
      }
    </div>
  </div>

  <main class="bc-main">
    <section
      id="bc-markets"
      class="bc-markets"
    >
      <div
        class="bc-section-heading"
      >
        <div>
          <p class="bc-eyebrow">
            {browseEyebrow}
          </p>
          <h2>
            {browseHeading}
          </h2>
        </div>

        <p>
          {
            isCityMode
              ? `Explore ${locationName} neighbourhoods, listings, and local area guides.`
              : "Start with a city, then explore neighbourhoods, listings, and local guides."
          }
        </p>

        <a
          href={
            isCityMode
              ? `/${city}/areas`
              : "/explore"
          }
        >
          {
            isCityMode
              ? "View all neighbourhoods"
              : "View all markets"
          }
          <span aria-hidden="true">
            →
          </span>
        </a>
      </div>

      <div
        class="bc-market-grid"
      >
        {
          featuredLocations.map(
            (
              location,
              index
            ) => {
              const image =
                location.image ||
                fallbackLocationImages[
                  index %
                    fallbackLocationImages.length
                ];

              return (
                <a
                  class="bc-market-card"
                  href={
                    location.href
                  }
                  style={`--market-image: url('${image}')`}
                >
                  <div class="bc-market-card__shade"></div>

                  <div class="bc-market-card__content">
                    <strong>
                      {
                        location.label
                      }
                    </strong>

                    <span>
                      {formatCount(
                        location.count
                      )}{" "}
                      active{" "}
                      {
                        location.count ===
                        1
                          ? "listing"
                          : "listings"
                      }
                    </span>
                  </div>

                  <span
                    class="bc-market-card__arrow"
                    aria-hidden="true"
                  >
                    →
                  </span>
                </a>
              );
            }
          )
        }
      </div>
    </section>

    <section class="bc-benefits">
      <article class="bc-benefit">
        <span class="bc-benefit__icon">
          <svg viewBox="0 0 24 24">
            <path d="M3 11.5 12 4l9 7.5"></path>
            <path d="M5.5 10.5V21h13V10.5"></path>
            <path d="M9.5 21v-6h5v6"></path>
          </svg>
        </span>

        <div>
          <h3>Local knowledge</h3>
          <p>
            {
              isCityMode
                ? `Detailed insights into neighbourhoods across ${locationName}.`
                : "Detailed insights into communities across British Columbia."
            }
          </p>
        </div>
      </article>

      <article class="bc-benefit">
        <span class="bc-benefit__icon">
          <svg viewBox="0 0 24 24">
            <path d="M4 20V10"></path>
