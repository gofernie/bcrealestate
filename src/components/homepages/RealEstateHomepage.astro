<script>
  const SEARCH_FORM_SELECTOR =
    "[data-async-search-form]";

  const RESULTS_SELECTOR =
    "[data-async-search-results]";

  const FILTER_SELECTOR =
    "[data-single-select], [data-area-multi-select]";

  let activeRequest:
    AbortController | null =
    null;

  const getSearchForm = () =>
    document.querySelector(
      SEARCH_FORM_SELECTOR
    );

  const getResultsContainer = () =>
    document.querySelector(
      RESULTS_SELECTOR
    );

  const closeAllSearchMenus = (
    except: Element | null = null
  ) => {
    document
      .querySelectorAll(
        FILTER_SELECTOR
      )
      .forEach((element) => {
        if (element === except) {
          return;
        }

        element.removeAttribute(
          "data-open"
        );

        const trigger =
          element.querySelector(
            "[data-single-trigger], [data-area-trigger]"
          );

        const menu =
          element.querySelector(
            "[data-single-menu], [data-area-menu]"
          );

        trigger?.setAttribute(
          "aria-expanded",
          "false"
        );

        if (
          menu instanceof HTMLElement
        ) {
          menu.hidden = true;
        }
      });
  };

  const buildSearchUrl = (
    form: HTMLFormElement
  ) => {
    const url =
      new URL(
        form.action,
        window.location.origin
      );

    const formData =
      new FormData(form);

    for (
      const [key, rawValue]
      of formData.entries()
    ) {
      const value =
        String(rawValue).trim();

      if (!value) {
        continue;
      }

      url.searchParams.append(
        key,
        value
      );
    }

    return url;
  };

  const setLoadingState = (
    loading: boolean
  ) => {
    const results =
      getResultsContainer();

    const form =
      getSearchForm();

    results?.classList.toggle(
      "is-loading",
      loading
    );

    form?.toggleAttribute(
      "aria-busy",
      loading
    );
  };

  const replaceResults = (
    html: string
  ) => {
    const parser =
      new DOMParser();

    const nextDocument =
      parser.parseFromString(
        html,
        "text/html"
      );

    const nextResults =
      nextDocument.querySelector(
        RESULTS_SELECTOR
      );

    const currentResults =
      getResultsContainer();

    if (
      !nextResults ||
      !currentResults
    ) {
      throw new Error(
        "Search results container was not found."
      );
    }

    currentResults.innerHTML =
      nextResults.innerHTML;
  };

  const loadSearchUrl = async (
    url: URL,
    options: {
      updateHistory?: boolean;
      scrollToResults?: boolean;
    } = {}
  ) => {
    const {
      updateHistory = true,
      scrollToResults = false,
    } = options;

    activeRequest?.abort();

    activeRequest =
      new AbortController();

    setLoadingState(true);

    try {
      const response =
        await fetch(
          url.toString(),
          {
            headers: {
              "X-Requested-With":
                "async-search",
            },
            signal:
              activeRequest.signal,
          }
        );

      if (!response.ok) {
        throw new Error(
          `Search request failed with status ${response.status}.`
        );
      }

      const html =
        await response.text();

      replaceResults(html);

      if (updateHistory) {
        window.history.pushState(
          {
            asyncSearch: true,
          },
          "",
          url
        );
      }

      if (scrollToResults) {
        const results =
          getResultsContainer();

        results?.scrollIntoView({
          behavior: "smooth",
          block: "start",
        });
      }
    } catch (error) {
      if (
        error instanceof DOMException &&
        error.name === "AbortError"
      ) {
        return;
      }

      console.error(
        "Async listing search failed:",
        error
      );

      window.location.assign(
        url.toString()
      );
    } finally {
      setLoadingState(false);
    }
  };

  const submitSearchForm = (
    scrollToResults = false
  ) => {
    const form =
      getSearchForm();

    if (
      !(form instanceof HTMLFormElement)
    ) {
      return;
    }

    const url =
      buildSearchUrl(form);

    loadSearchUrl(url, {
      updateHistory: true,
      scrollToResults,
    });
  };

  document
    .querySelectorAll(
      "[data-single-select]"
    )
    .forEach((group) => {
      const trigger =
        group.querySelector(
          "[data-single-trigger]"
        );

      const menu =
        group.querySelector(
          "[data-single-menu]"
        );

      const summary =
        group.querySelector(
          "[data-single-summary]"
        );

      const input =
        group.querySelector(
          "[data-single-input]"
        );

      const options =
        group.querySelectorAll(
          "[data-single-option]"
        );

      if (
        !(
          trigger instanceof
          HTMLButtonElement
        ) ||
        !(
          menu instanceof
          HTMLElement
        ) ||
        !(
          input instanceof
          HTMLInputElement
        )
      ) {
        return;
      }

      trigger.addEventListener(
        "click",
        () => {
          const willOpen =
            group.getAttribute(
              "data-open"
            ) !== "true";

          closeAllSearchMenus(
            willOpen
              ? group
              : null
          );

          if (willOpen) {
            group.setAttribute(
              "data-open",
              "true"
            );

            trigger.setAttribute(
              "aria-expanded",
              "true"
            );

            menu.hidden = false;
          }
        }
      );

      options.forEach(
        (option) => {
          if (
            !(
              option instanceof
              HTMLButtonElement
            )
          ) {
            return;
          }

          option.addEventListener(
            "click",
            () => {
              input.value =
                option.dataset.value ||
                "";

              if (
                summary instanceof
                HTMLElement
              ) {
                summary.textContent =
                  option.dataset.label ||
                  "";
              }

              options.forEach(
                (candidate) => {
                  candidate.classList.toggle(
                    "is-selected",
                    candidate ===
                      option
                  );
                }
              );

              const clearNames =
                group
                  .getAttribute(
                    "data-clear-names"
                  )
                  ?.split(",")
                  .map((name) =>
                    name.trim()
                  )
                  .filter(Boolean) ||
                [];

              const form =
                group.closest(
                  "form"
                );

              clearNames.forEach(
                (name) => {
                  const companion =
                    form?.querySelector(
                      `input[name="${CSS.escape(
                        name
                      )}"]`
                    );

                  if (
                    companion instanceof
                    HTMLInputElement
                  ) {
                    companion.value =
                      "";
                  }
                }
              );

              closeAllSearchMenus();

              submitSearchForm();
            }
          );
        }
      );
    });

  document
    .querySelectorAll(
      "[data-area-multi-select]"
    )
    .forEach((group) => {
      const trigger =
        group.querySelector(
          "[data-area-trigger]"
        );

      const menu =
        group.querySelector(
          "[data-area-menu]"
        );

      const summary =
        group.querySelector(
          "[data-area-summary]"
        );

      const clearButton =
        group.querySelector(
          "[data-area-clear]"
        );

      const doneButton =
        group.querySelector(
          "[data-area-done]"
        );

      const checkboxes =
        group.querySelectorAll(
          "[data-area-option]"
        );

      if (
        !(
          trigger instanceof
          HTMLButtonElement
        ) ||
        !(
          menu instanceof
          HTMLElement
        )
      ) {
        return;
      }

      const updateSummary =
        () => {
          const selected =
            Array.from(
              checkboxes
            ).filter(
              (
                checkbox
              ): checkbox is HTMLInputElement =>
                checkbox instanceof
                  HTMLInputElement &&
                checkbox.checked
            );

          const labels =
            selected.map(
              (checkbox) =>
                checkbox.dataset.label ||
                checkbox.value
            );

          if (
            summary instanceof
            HTMLElement
          ) {
            summary.textContent =
              labels.length === 0
                ? "All areas"
                : labels.length === 1
                  ? labels[0]
                  : `${labels.length} areas`;
          }
        };

      trigger.addEventListener(
        "click",
        () => {
          const willOpen =
            group.getAttribute(
              "data-open"
            ) !== "true";

          closeAllSearchMenus(
            willOpen
              ? group
              : null
          );

          if (willOpen) {
            group.setAttribute(
              "data-open",
              "true"
            );

            trigger.setAttribute(
              "aria-expanded",
              "true"
            );

            menu.hidden = false;
          }
        }
      );

      checkboxes.forEach(
        (checkbox) => {
          checkbox.addEventListener(
            "change",
            updateSummary
          );
        }
      );

      clearButton?.addEventListener(
        "click",
        () => {
          checkboxes.forEach(
            (checkbox) => {
              if (
                checkbox instanceof
                HTMLInputElement
              ) {
                checkbox.checked =
                  false;
              }
            }
          );

          updateSummary();
        }
      );

      doneButton?.addEventListener(
        "click",
        () => {
          updateSummary();
          closeAllSearchMenus();
          submitSearchForm();
        }
      );
    });

  document.addEventListener(
    "submit",
    (event) => {
      const form =
        event.target;

      if (
        !(
          form instanceof
          HTMLFormElement
        ) ||
        !form.matches(
          SEARCH_FORM_SELECTOR
        )
      ) {
        return;
      }

      event.preventDefault();

      submitSearchForm();
    }
  );

  document.addEventListener(
    "click",
    (event) => {
      const target =
        event.target;

      if (
        !(target instanceof Element)
      ) {
        return;
      }

      const paginationLink =
        target.closest(
          `${RESULTS_SELECTOR} .bc-pagination a`
        );

      if (
        paginationLink instanceof
        HTMLAnchorElement
      ) {
        event.preventDefault();

        const url =
          new URL(
            paginationLink.href,
            window.location.origin
          );

        loadSearchUrl(url, {
          updateHistory: true,
          scrollToResults: true,
        });

        return;
      }

      if (
        !target.closest(
          FILTER_SELECTOR
        )
      ) {
        closeAllSearchMenus();
      }
    }
  );

  document.addEventListener(
    "keydown",
    (event) => {
      if (
        event.key === "Escape"
      ) {
        closeAllSearchMenus();
      }
    }
  );

  window.addEventListener(
    "popstate",
    () => {
      loadSearchUrl(
        new URL(
          window.location.href
        ),
        {
          updateHistory: false,
          scrollToResults: false,
        }
      );
    }
  );
</script>

