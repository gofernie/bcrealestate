---
import IntentModalController from "../IntentModalController.astro";
import ListingCard from "../ListingCard.astro";
import "../../styles/intent-modal.css";

type Site = {
  city?: string;
  site_name?: string;
  domain?: string;
  accent_color?: string;
  heroImageUrl?: string;
  hero_image_url?: string;
};

type Props = {
  site?: Site;
  listings?: any[];
};

const {
  site,
  listings = [],
} = Astro.props;

const city = site?.city || "nanaimo";

const cityLabel = city
  .replace(/-/g, " ")
  .replace(/\b\w/g, (letter) => letter.toUpperCase());

const accent = site?.accent_color || "#176b63";

const heroImage =
  site?.heroImageUrl ||
  site?.hero_image_url ||
  "";

const activeListings = listings.filter((listing) => {
  const status = String(listing?.status || "").toUpperCase();
  const type = String(
    listing?.normalized_type ||
    listing?.property_type ||
    ""
  ).toLowerCase();

  return (
    (!status || status === "A") &&
    type.includes("mobile")
  );
});

const listingCount = activeListings.length || 41;

const newestListings = [...activeListings]
  .sort((a, b) => {
    const dateA = new Date(
      a?.listed_at ||
      a?.created_at ||
      a?.updated_at ||
      0
    ).getTime();

    const dateB = new Date(
      b?.listed_at ||
      b?.created_at ||
      b?.updated_at ||
      0
    ).getTime();

    return dateB - dateA;
  })
  .slice(0, 12);



const formatAddress = (listing: any) =>
  String(
    listing?.address ||
    listing?.area ||
    `${cityLabel} mobile home`
  ).trim();

const formatListingPrice = (value: unknown) => {
  const price = Number(value);

  return Number.isFinite(price) && price > 0
    ? new Intl.NumberFormat("en-CA", {
        style: "currency",
        currency: "CAD",
        maximumFractionDigits: 0,
      }).format(price)
    : "Price unavailable";
};

const prices = activeListings
  .map((listing) => Number(listing?.price))
  .filter((price) => Number.isFinite(price) && price > 0)
  .sort((a, b) => a - b);

const medianPrice = prices.length
  ? prices[Math.floor(prices.length / 2)]
  : 349900;

const recentListings = activeListings.filter((listing) => {
  const rawDate =
    listing?.listed_at ||
    listing?.created_at ||
    listing?.updated_at;

  if (!rawDate) return false;

  const listedAt = new Date(rawDate);
  const thirtyDaysAgo = new Date();

  thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

  return listedAt >= thirtyDaysAgo;
}).length || 15;

const areaCounts = new Map<string, number>();

for (const listing of activeListings) {
  const area = String(listing?.area || "").trim();

  if (!area) continue;

  areaCounts.set(area, (areaCounts.get(area) || 0) + 1);
}

const areaCount = areaCounts.size || 9;

const formatPrice = (value: number) =>
  new Intl.NumberFormat("en-CA", {
    style: "currency",
    currency: "CAD",
    maximumFractionDigits: 0,
  }).format(value);

const quickLinks = [
  {
    label: "Under $300,000",
    icon: "home",
    href: `/${city}/mobile-homes?price_max=300000`,
  },
  {
    label: "55+ Communities",
    icon: "people",
    href: "/parks?age=55-plus",
  },
  {
    label: "Family Parks",
    icon: "family",
    href: "/parks?type=family",
  },
  {
    label: "Pet Friendly",
    icon: "paw",
    href: "/parks?pets=true",
  },
  {
    label: "Lowest Pad Fees",
    icon: "dollar",
    href: "/parks?sort=pad-fee",
  },
  {
    label: "Near the Ocean",
    icon: "water",
    href: "/parks?feature=ocean",
  },
  {
    label: "Transit Friendly",
    icon: "bus",
    href: `/explore?city=${city}&layer=transit`,
  },
  {
    label: "Walkable Parks",
    icon: "walk",
    href: "/parks?feature=walkable",
  },
];

const parks = [
  {
    name: "Seabreeze Mobile Home Park",
    image: "",
    tags: ["55+", "Pet friendly"],
    padFee: "$650",
    homes: 4,
  },
  {
    name: "Sharman Mobile Home Park",
    image: "",
    tags: ["Family friendly"],
    padFee: "$710",
    homes: 5,
  },
  {
    name: "Lakeside Estates",
    image: "",
    tags: ["55+", "Near the ocean"],
    padFee: "$680",
    homes: 2,
  },
  {
    name: "Crestview Park",
    image: "",
    tags: ["55+"],
    padFee: "$595",
    homes: 2,
  },
  {
    name: "Pinegrove Estates",
    image: "",
    tags: ["Family friendly", "Pet friendly"],
    padFee: "$750",
    homes: 6,
  },
];

const guides = [
  {
    title: "Financing Guide",
    copy: "Can I get a mortgage? How mobile-home financing works.",
    href: "/guides/mobile-home-financing",
    icon: "calculator",
  },
  {
    title: "Pad Fees Explained",
    copy: "What is included, what to expect, and typical costs.",
    href: "/guides/mobile-home-pad-fees",
    icon: "receipt",
  },
  {
    title: "Ownership 101",
    copy: "Understand leased land, strata, and what you actually own.",
    href: "/guides/mobile-home-ownership",
    icon: "key",
  },
  {
    title: "Inspection Checklist",
    copy: "Important things to check before purchasing a mobile home.",
    href: "/guides/mobile-home-inspections",
    icon: "checklist",
  },
];

const resources = [
  "Can mobile homes increase in value?",
  "Manufactured vs. modular homes",
  "How pad rent works",
  "Can I rent my mobile home?",
  "Insurance for mobile homes",
  "Electrical certification",
];

const iconPaths: Record<string, string> = {
  home: "M3 11.5 12 4l9 7.5M5.5 10v10h13V10M9 20v-6h6v6",
  people:
    "M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm13 10v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75",
  family:
    "M8 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm8 0a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM2 21v-2a5 5 0 0 1 5-5h2a5 5 0 0 1 5 5v2m0-6h2a5 5 0 0 1 5 5v1",
  paw:
    "M8.5 12.5c-2.5 0-4.5 2-4.5 4.5 0 2 1.5 3 3.2 3 1.2 0 2-.7 2.8-.7s1.6.7 2.8.7c1.7 0 3.2-1 3.2-3 0-2.5-2-4.5-4.5-4.5h-3ZM6 9c1.1 0 2-1.1 2-2.5S7.1 4 6 4 4 5.1 4 6.5 4.9 9 6 9Zm6-2.5C12 5.1 11.1 4 10 4S8 5.1 8 6.5 8.9 9 10 9s2-1.1 2-2.5ZM16 10c1.1 0 2-1.1 2-2.5S17.1 5 16 5s-2 1.1-2 2.5 0.9 2.5 2 2.5Z",
  dollar:
    "M12 2v20m5-16.5C15.8 4.5 14.2 4 12.5 4 9.5 4 7 5.6 7 8s2 3.4 5.5 4c3.5.8 5.5 1.6 5.5 4s-2.5 4-5.5 4c-2 0-4-.7-5.5-2",
  water:
    "M2 18c2 0 2-1.5 4-1.5S8 18 10 18s2-1.5 4-1.5S16 18 18 18s2-1.5 4-1.5M3 13l4-4 3 3 5-6 6 7",
  bus:
    "M6 3h12a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm-2 9h16M8 21v-3m8 3v-3M8 7h8",
  walk:
    "M13 5a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm-3 16 2-6 2 2 2 4m-8-8 3-5 3 2 3 1m-6-3-2 5-4 3",
  calculator:
    "M6 2h12v20H6zM8 5h8v4H8zm0 8h2m3 0h2m-7 4h2m3 0h2",
  receipt:
    "M6 3h12v18l-3-2-3 2-3-2-3 2V3Zm3 5h6m-6 4h6",
  key:
    "M14 8a5 5 0 1 1-2 4l-7 7H2v-3l7-7a5 5 0 0 1 5-1Z",
  checklist:
    "M7 3h10v18H7zM9 7h6m-6 4h6m-6 4h6M4 7h.01M4 11h.01M4 15h.01",
};
---

<div
  class="mobile-home-homepage"
  data-city={city}
  style={`--mh-accent:${accent};`}
>
<section
  class:list={[
    "mh-hero",
    { "mh-hero--image": !!heroImage }
  ]}
  style={
    heroImage
      ? `--hero-image:url('${heroImage}')`
      : undefined
  }
>
    <div class="mh-hero-glow"></div>

    <div class="mh-shell mh-hero-grid">
      <div class="mh-hero-copy">
        <div class="mh-eyebrow">Nanaimo Mobile Homes</div>

        <h1>
          Everything you need to buy a mobile home in Nanaimo.
        </h1>

        <div class="mh-benefits">
          <span>Every listing</span>
          <span>Every park</span>
          <span>Pad fees</span>
          <span>Financing</span>
          <span>55+ communities</span>
          <span>Family parks</span>
          <span>Expert guidance</span>
        </div>

        <div class="mh-actions">
          <a
            class="mh-button mh-button-primary"
            href={`/${city}/mobile-homes`}
          >
            Browse homes for sale
          </a>

          <a class="mh-button mh-button-secondary" href="/parks">
            Find your park
          </a>
        </div>
      </div>

      <aside class="mh-market-card">
        <div class="mh-market-label">Current market</div>

        <div class="mh-market-grid">
          <div class="mh-market-stat">
            <strong>{listingCount}</strong>
            <span>Homes for sale</span>
          </div>

          <div class="mh-market-stat">
            <strong>{formatPrice(medianPrice)}</strong>
            <span>Median asking price</span>
          </div>

          <div class="mh-market-stat">
            <strong>{recentListings}</strong>
            <span>New this month</span>
          </div>

          <div class="mh-market-stat">
            <strong>{areaCount}</strong>
            <span>Areas represented</span>
          </div>
        </div>

        <a class="mh-card-link" href={`/${city}/mobile-homes`}>
          View all mobile homes
          <span aria-hidden="true">→</span>
        </a>
      </aside>
    </div>
  </section>

  <main>
    <section class="mh-section mh-quick-section">
      <div class="mh-shell">
        <div class="mh-section-label">I’m looking for...</div>

        <div class="mh-quick-grid">
          {
            quickLinks.map((item) => (
              <a class="mh-quick-card" href={item.href}>
                <span class="mh-icon-wrap">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d={iconPaths[item.icon]} />
                  </svg>
                </span>

                <strong>{item.label}</strong>
              </a>
            ))
          }
        </div>
      </div>
    </section>

       <section class="mh-section">
      <div class="mh-shell">
        <div class="mh-heading-row">
          <div>
            <div class="mh-section-label">
              Just listed
            </div>

            <h2>Newest mobile homes for sale.</h2>
          </div>

          <a
            class="mh-text-link"
            href={`/${city}/mobile-homes`}
          >
            View all mobile homes →
          </a>
        </div>

        {
  newestListings.length > 0 ? (
    <div class="mh-listing-grid">
  {
    newestListings.map((listing, index) => (
     <ListingCard
  listing={listing}
  priority={index < 4}
/>
    ))
  }
</div>
  ) : (
    <div class="mh-listing-empty">
      New mobile-home listings will appear here.
    </div>
  )
}

    <section class="mh-section">
      <div class="mh-shell mh-guide-panel">
        <div class="mh-guide-intro">
          <div class="mh-section-label">Expert guidance</div>
          <h2>Everything you need to know.</h2>
          <p>
            Clear answers to the most common questions about mobile-home
            living and ownership.
          </p>

          <a class="mh-text-link" href="/guides">
            View all guides →
          </a>
        </div>

        <div class="mh-guide-grid">
          {
            guides.map((guide) => (
              <a class="mh-guide-card" href={guide.href}>
                <span class="mh-guide-icon">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.45"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d={iconPaths[guide.icon]} />
                  </svg>
                </span>

                <h3>{guide.title}</h3>
                <p>{guide.copy}</p>
                <span class="mh-guide-link">Learn more →</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mh-section">
      <div class="mh-shell">
        <div class="mh-section-label">
          Nanaimo mobile home market snapshot
        </div>

        <div class="mh-dashboard">
          <div class="mh-dashboard-stat">
            <strong>{listingCount}</strong>
            <span>Homes available</span>
          </div>

          <div class="mh-dashboard-stat">
            <strong>{recentListings}</strong>
            <span>New this month</span>
          </div>

          <div class="mh-dashboard-stat">
            <strong>{formatPrice(medianPrice)}</strong>
            <span>Median price</span>
          </div>

          <div class="mh-dashboard-stat">
            <strong>8</strong>
            <span>Price reductions</span>
          </div>

          <div class="mh-dashboard-stat">
            <strong>7</strong>
            <span>Parks with listings</span>
          </div>

          <div class="mh-dashboard-stat">
            <strong>92%</strong>
            <span>On leased land</span>
          </div>
        </div>
      </div>
    </section>

    <section class="mh-section">
      <div class="mh-shell mh-feature-grid">
        <article class="mh-spotlight">
          <div class="mh-spotlight-content">
            <div class="mh-spotlight-label">★ Park spotlight</div>

            <h2>Seabreeze Mobile Home Park</h2>

            <div class="mh-tags mh-tags-light">
              <span>55+ community</span>
              <span>Pet friendly</span>
              <span>Ocean nearby</span>
            </div>

            <p>
              A quiet, established community with mature landscaping and
              convenient access to shopping and services.
            </p>

            <div class="mh-spotlight-stats">
              <div>
                <strong>4</strong>
                <span>Homes for sale</span>
              </div>

              <div>
                <strong>$650</strong>
                <span>Monthly pad fee</span>
              </div>

              <div>
                <strong>2 pets</strong>
                <span>Allowed</span>
              </div>
            </div>

            <a class="mh-button mh-button-light" href="/parks">
              View park guide
            </a>
          </div>
        </article>

        <article class="mh-comparison-card">
          <div class="mh-heading-row">
            <div>
              <div class="mh-section-label">Compare parks</div>
              <h2>See the differences.</h2>
            </div>

            <a class="mh-text-link" href="/parks">
              Full comparison →
            </a>
          </div>

          <div class="mh-table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Park</th>
                  <th>55+</th>
                  <th>Pets</th>
                  <th>Pad fee</th>
                </tr>
              </thead>

              <tbody>
                {
                  parks.slice(0, 5).map((park, index) => (
                    <tr>
                      <td>{park.name}</td>
                      <td>{index === 1 || index === 4 ? "—" : "✓"}</td>
                      <td>{park.tags.some((tag) => tag.includes("Pet")) ? "✓" : "1 pet"}</td>
                      <td>{park.padFee}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>

          <p class="mh-disclaimer">
            Pad fees and park rules can change. Confirm current information
            with park management before purchasing.
          </p>
        </article>
      </div>
    </section>

    <section class="mh-section">
      <div class="mh-shell">
        <div class="mh-heading-row">
          <div>
            <div class="mh-section-label">
              Mobile home living resources
            </div>

            <h2>Learn before you buy.</h2>
          </div>

          <a class="mh-text-link" href="/guides">
            View all resources →
          </a>
        </div>

        <div class="mh-resource-grid">
          {
            resources.map((resource) => (
              <a class="mh-resource-card" href="/guides">
                <span class="mh-resource-mark">?</span>
                <strong>{resource}</strong>
                <span>→</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mh-section mh-alert-section">
      <div class="mh-shell">
        <div class="mh-alert-card">
          <div class="mh-alert-copy">
            <div class="mh-alert-icon">↗</div>

            <div>
              <h2>Never miss a new mobile home.</h2>
              <p>
                Get an alert when a listing matches your price, park, age,
                or pet preferences.
              </p>
            </div>
          </div>

          <form class="mh-alert-form">
            <label>
              <span>Email address</span>
              <input
                type="email"
                name="email"
                placeholder="you@example.com"
              />
            </label>

            <button type="submit">Create alert</button>
          </form>
        </div>
      </div>
    </section>
</main>

<IntentModalController listings={activeListings} />

</div>

<script is:inline>
  function openMobileListingCard(card) {
    if (!(card instanceof HTMLElement)) return;

if (typeof window.openSheet !== "function") {
  console.warn("IntentModalController not loaded.");
  return;
}

window.openSheet(card);
  }

  document.addEventListener("click", (event) => {
    const card = event.target.closest(
     ".mh-listing-grid [data-listing-id]"
    );

    if (!card) return;

    event.preventDefault();
    openMobileListingCard(card);
  });

  document.addEventListener("keydown", (event) => {
    if (
      event.key !== "Enter" &&
      event.key !== " "
    ) {
      return;
    }

    const card = event.target.closest(
      ".mh-listing-grid [data-listing-id]"
    );

    if (!card) return;

    event.preventDefault();
    openMobileListingCard(card);
  });
</script>

<style>
  .mobile-home-homepage {
    --mh-ink: #17201d;
    --mh-muted: #66706c;
    --mh-line: rgba(23, 32, 29, 0.12);
    --mh-soft: #f4f5f2;
    --mh-warm: #f8f4ed;
    --mh-radius: 22px;
    color: var(--mh-ink);
    background: #fff;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  .mobile-home-homepage * {
    box-sizing: border-box;
  }

  .mobile-home-homepage h1,
  .mobile-home-homepage h2,
  .mobile-home-homepage h3,
  .mobile-home-homepage p {
    margin-top: 0;
  }

  .mobile-home-homepage h1,
  .mobile-home-homepage h2 {
    font-family:
      Georgia,
      "Times New Roman",
      serif;
    font-weight: 500;
    letter-spacing: -0.04em;
  }

  .mh-shell {
    width: min(1460px, calc(100% - 64px));
    margin-inline: auto;
  }

.mh-hero {
  position: relative;
  overflow: hidden;
  padding: 72px 0 64px;
  background:
    radial-gradient(
      circle at 74% 38%,
      color-mix(in srgb, var(--mh-accent) 18%, transparent),
      transparent 38%
    ),
    linear-gradient(110deg, #faf7f1 0%, #f8f7f2 46%, #eef4f0 100%);
  border-bottom: 1px solid var(--mh-line);
}

.mh-hero--image {
  background:
    linear-gradient(
      90deg,
      rgba(248, 247, 242, 0.96) 0%,
      rgba(248, 247, 242, 0.86) 42%,
      rgba(248, 247, 242, 0.42) 72%,
      rgba(248, 247, 242, 0.15) 100%
    ),
    var(--hero-image) center center / cover no-repeat;
}

  .mh-hero-glow {
    position: absolute;
    width: 560px;
    height: 560px;
    right: 7%;
    top: -210px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--mh-accent) 12%, transparent);
    filter: blur(45px);
    pointer-events: none;
  }

  .mh-hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(340px, 0.7fr);
    gap: 72px;
    align-items: center;
  }

  .mh-eyebrow,
  .mh-section-label,
  .mh-market-label,
  .mh-spotlight-label {
    margin-bottom: 16px;
    color: var(--mh-accent);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .mh-hero h1 {
    max-width: 820px;
    margin-bottom: 24px;
    font-size: clamp(3.2rem, 6vw, 6.3rem);
    line-height: 0.93;
  }

  .mh-benefits {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 22px;
    max-width: 760px;
    margin-bottom: 32px;
    color: #46534e;
    font-size: 0.92rem;
  }

  .mh-benefits span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .mh-benefits span::before {
    content: "✓";
    display: grid;
    width: 18px;
    height: 18px;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--mh-accent) 45%, transparent);
    border-radius: 999px;
    color: var(--mh-accent);
    font-size: 0.68rem;
    font-weight: 800;
  }

  .mh-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .mh-button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    padding: 0 22px;
    border: 1px solid transparent;
    border-radius: 12px;
    font-size: 0.88rem;
    font-weight: 750;
    text-decoration: none;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      background 160ms ease;
  }

  .mh-button:hover {
    transform: translateY(-2px);
  }

  .mh-button-primary {
    color: #fff;
    background: var(--mh-accent);
    box-shadow: 0 12px 28px
      color-mix(in srgb, var(--mh-accent) 24%, transparent);
  }

  .mh-button-secondary {
    color: var(--mh-accent);
    background: rgba(255, 255, 255, 0.68);
