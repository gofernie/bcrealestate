---
const {
  site = null,
  city = "nanaimo",
} = Astro.props;

const areas = [
  {
    name: "North Nanaimo",
    slug: "north-nanaimo",
    description:
      "North Nanaimo has several established manufactured home communities close to shopping, transit, and everyday services.",
    features: ["55+ communities", "Shopping nearby", "Transit access"],
  },
  {
    name: "Central Nanaimo",
    slug: "central-nanaimo",
    description:
      "Central Nanaimo offers convenient access to services, parks, and established mobile home communities.",
    features: ["Central location", "Everyday services", "Established parks"],
  },
  {
    name: "South Nanaimo",
    slug: "south-nanaimo",
    description:
      "South Nanaimo includes a mix of adult-oriented and all-ages manufactured home communities.",
    features: ["Adult communities", "Family options", "Highway access"],
  },
  {
    name: "Chase River",
    slug: "chase-river",
    description:
      "Chase River is close to shopping, transportation routes, and several manufactured home communities.",
    features: ["Shopping nearby", "Transit access", "South Nanaimo"],
  },
  {
    name: "Cedar",
    slug: "cedar",
    description:
      "Cedar offers a more rural setting with manufactured home communities and access to south Nanaimo.",
    features: ["Rural setting", "Larger surroundings", "South Nanaimo access"],
  },
  {
    name: "Pleasant Valley",
    slug: "pleasant-valley",
    description:
      "Pleasant Valley has established adult-oriented parks close to north Nanaimo shopping and services.",
    features: ["55+ options", "Shopping nearby", "North Nanaimo"],
  },
  {
    name: "University District",
    slug: "university-district",
    description:
      "The University District provides central access to parks, services, and nearby manufactured home communities.",
    features: ["Central access", "Parks nearby", "Services nearby"],
  },
  {
    name: "Departure Bay",
    slug: "departure-bay",
    description:
      "Departure Bay offers convenient access to central Nanaimo, transit, recreation, and everyday services.",
    features: ["Transit access", "Recreation nearby", "Central Nanaimo"],
  },
];

const totalAreas = areas.length;
const { data: mobileRows = [] } = await supabase
  .from("listing_rows")
  .select("normalized_area")
  .eq("status", "A")
  .eq("normalized_city", city)
  .eq("normalized_type", "mobile");

const listingCounts = mobileRows.reduce((acc, row) => {
  const slug = String(row.normalized_area || "")
    .toLowerCase()
    .trim()
    .replace(/\s+/g, "-");

  acc[slug] = (acc[slug] || 0) + 1;
  return acc;
}, {});
---

<div class="mobile-areas-page">
  <header class="mobile-areas-hero">
    <div class="mobile-areas-shell">
      <a class="mobile-areas-back" href="/">
        ← Nanaimo Mobile Homes
      </a>

      <div class="mobile-areas-hero-grid">
        <div>
          <div class="mobile-areas-eyebrow">
            Nanaimo mobile home areas
          </div>

          <h1>Explore Nanaimo by area.</h1>

          <p class="mobile-areas-intro">
            Browse the parts of Nanaimo where mobile homes,
            manufactured home parks, and active listings are
            commonly found.
          </p>
        </div>

        <aside class="mobile-areas-summary">
          <div>
            <strong>{totalAreas}</strong>
            <span>Featured areas</span>
          </div>

          <div>
          <strong>{mobileRows.length}</strong>
<span>Active mobile homes</span>
          </div>

          <div>
            <strong>55+</strong>
            <span>Adult communities</span>
          </div>

          <div>
            <strong>All ages</strong>
            <span>Family options</span>
          </div>
        </aside>
      </div>
    </div>
  </header>

  <main>
    <section class="mobile-areas-directory">
      <div class="mobile-areas-shell">
        <div class="mobile-areas-heading-row">
          <div>
            <div class="mobile-areas-eyebrow">
              Browse by location
            </div>

            <h2>Nanaimo mobile home areas</h2>
          </div>

          <a
            class="mobile-areas-listing-link"
            href="/nanaimo/nanaimo-mobile-homes"
          >
            View mobile homes for sale →
          </a>
        </div>

        <div class="mobile-areas-grid">
          {
          areas
  .filter((area) => (listingCounts[area.slug] || 0) > 0)
  .map((area) => (
              <a
                class="mobile-area-card"
            href={`/${city}/${area.slug}-mobile-homes`}
              >
                <div class="mobile-area-icon" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 21s6-5.2 6-11a6 6 0 1 0-12 0c0 5.8 6 11 6 11Z" />
                    <circle cx="12" cy="10" r="2.2" />
                  </svg>
                </div>

                <h3>{area.name}</h3>
                <p>{area.description}</p>

              <div class="mobile-area-features">
  <span>
    {listingCounts[area.slug] || 0} active listing{
      (listingCounts[area.slug] || 0) === 1 ? "" : "s"
    }
  </span>

  {
    area.features.map((feature) => (
      <span>{feature}</span>
    ))
  }
</div>

                <div class="mobile-area-link">
                  Explore {area.name}
                  <span aria-hidden="true">→</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mobile-areas-help">
      <div class="mobile-areas-shell">
        <div class="mobile-areas-help-card">
          <div>
            <div class="mobile-areas-eyebrow">
              Prefer to browse by park?
            </div>

            <h2>Compare Nanaimo mobile home parks.</h2>

            <p>
              Review age restrictions, pet policies, locations,
              and community details across Nanaimo.
            </p>
          </div>

          <a
            class="mobile-areas-primary-button"
            href="/park-directory"
          >
            Open Park Directory
          </a>
        </div>
      </div>
    </section>
  </main>
</div>

<style>
  :root {
    --mobile-areas-accent: var(--accent, #58736a);
    --mobile-areas-ink: #17201d;
    --mobile-areas-muted: #69736f;
    --mobile-areas-line: rgba(23, 32, 29, 0.12);
    --mobile-areas-warm: #faf7f1;
  }

  .mobile-areas-page {
    color: var(--mobile-areas-ink);
    background: #fff;
  }



  .mobile-areas-hero {
    padding: 34px 0 76px;
    border-bottom: 1px solid var(--mobile-areas-line);
    background:
      radial-gradient(
        circle at 82% 20%,
        color-mix(in srgb, var(--mobile-areas-accent) 20%, transparent),
        transparent 32%
      ),
      linear-gradient(115deg, var(--mobile-areas-warm), #eef4f0);
  }

  .mobile-areas-back {
    display: inline-flex;
    margin-bottom: 64px;
    color: var(--mobile-areas-accent);
    font-size: 0.78rem;
    font-weight: 750;
    text-decoration: none;
  }

  .mobile-areas-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(360px, 0.7fr);
    gap: 72px;
    align-items: end;
  }

  .mobile-areas-eyebrow {
    margin-bottom: 16px;
    color: var(--mobile-areas-accent);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .mobile-areas-hero h1,
  .mobile-areas-directory h2,
  .mobile-areas-help-card h2,
  .mobile-area-card h3 {
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 500;
    letter-spacing: -0.04em;
  }

  .mobile-areas-hero h1 {
    max-width: 850px;
    margin: 0 0 24px;
    font-size: clamp(3.3rem, 7vw, 6.8rem);
    line-height: 0.91;
  }

  .mobile-areas-intro {
    max-width: 720px;
    margin: 0;
    color: #52605b;
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.7;
  }

  .mobile-areas-summary {
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 24px 60px rgba(31, 49, 42, 0.1);
    backdrop-filter: blur(16px);
  }

  .mobile-areas-summary div {
    min-height: 126px;
    padding: 24px;
    border-right: 1px solid var(--mobile-areas-line);
    border-bottom: 1px solid var(--mobile-areas-line);
  }

  .mobile-areas-summary div:nth-child(even) { border-right: 0; }
  .mobile-areas-summary div:nth-child(n + 3) { border-bottom: 0; }
  .mobile-areas-summary strong,
  .mobile-areas-summary span { display: block; }

  .mobile-areas-summary strong {
    margin-bottom: 8px;
    font-family: Georgia, serif;
    font-size: 2rem;
    font-weight: 500;
  }

  .mobile-areas-summary span {
    color: var(--mobile-areas-muted);
    font-size: 0.73rem;
  }

  .mobile-areas-directory { padding: 74px 0 68px; }

  .mobile-areas-heading-row {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 28px;
    margin-bottom: 26px;
  }

  .mobile-areas-directory h2 {
    margin: 0;
    font-size: clamp(2.3rem, 4vw, 4rem);
  }

  .mobile-areas-listing-link {
    color: var(--mobile-areas-accent);
    font-size: 0.8rem;
    font-weight: 750;
    text-decoration: none;
  }

  .mobile-areas-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .mobile-area-card {
    display: flex;
    min-width: 0;
    min-height: 330px;
    flex-direction: column;
    padding: 24px;
    border: 1px solid var(--mobile-areas-line);
    border-radius: 19px;
    background: #fff;
    color: inherit;
    text-decoration: none;
    box-shadow: 0 8px 26px rgba(27, 41, 35, 0.04);
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }

  .mobile-area-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--mobile-areas-accent) 42%, transparent);
    box-shadow: 0 18px 38px rgba(27, 41, 35, 0.09);
  }

  .mobile-area-icon {
    display: grid;
    width: 50px;
    height: 50px;
    margin-bottom: 18px;
    place-items: center;
    border-radius: 15px;
    color: var(--mobile-areas-accent);
    background: color-mix(in srgb, var(--mobile-areas-accent) 9%, white);
  }

  .mobile-area-icon svg { width: 27px; height: 27px; }

  .mobile-area-card h3 {
    margin: 0 0 12px;
    font-size: 1.65rem;
    line-height: 1.08;
  }

  .mobile-area-card p {
    margin: 0 0 22px;
    color: var(--mobile-areas-muted);
    font-size: 0.82rem;
    line-height: 1.65;
  }

  .mobile-area-features {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 24px;
  }

  .mobile-area-features span {
    padding: 6px 9px;
    border: 1px solid var(--mobile-areas-line);
    border-radius: 999px;
    color: #59635f;
    font-size: 0.63rem;
  }

  .mobile-area-link {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    margin-top: auto;
    padding-top: 17px;
    border-top: 1px solid var(--mobile-areas-line);
    color: var(--mobile-areas-accent);
    font-size: 0.73rem;
    font-weight: 800;
  }

  .mobile-areas-help { padding: 0 0 68px; }

  .mobile-areas-help-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 50px;
    align-items: center;
    padding: 42px;
    border-radius: 24px;
    background:
      radial-gradient(circle at 15% 50%, rgba(255, 255, 255, 0.68), transparent 25%),
      color-mix(in srgb, var(--mobile-areas-accent) 10%, white);
  }

  .mobile-areas-help-card h2 {
    margin: 0 0 13px;
    font-size: clamp(2.2rem, 4vw, 4rem);
  }

  .mobile-areas-help-card p {
    max-width: 720px;
    margin: 0;
    color: var(--mobile-areas-muted);
    line-height: 1.7;
  }

  .mobile-areas-primary-button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    padding: 0 20px;
    border: 1px solid var(--mobile-areas-accent);
    border-radius: 11px;
    color: #fff;
    background: var(--mobile-areas-accent);
    font-size: 0.78rem;
    font-weight: 800;
    text-decoration: none;
  }

  @media (max-width: 1040px) {
    .mobile-areas-hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .mobile-areas-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .mobile-areas-help-card { grid-template-columns: 1fr; gap: 28px; }
  }

@media (max-width: 720px) {

    .mobile-areas-hero { padding: 24px 0 54px; }
    .mobile-areas-back { margin-bottom: 40px; }
    .mobile-areas-hero h1 { font-size: clamp(3rem, 15vw, 4.8rem); }
    .mobile-areas-heading-row { align-items: flex-start; flex-direction: column; }
    .mobile-areas-grid { grid-template-columns: 1fr; }
    .mobile-area-card { min-height: 0; padding: 21px; }
    .mobile-areas-help-card { padding: 28px; }
    .mobile-areas-primary-button { width: 100%; }
  }
</style>
