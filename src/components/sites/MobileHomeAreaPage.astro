---
import SiteNav from "../SiteNav.astro";
import ShortlistReviewModal from "../ShortlistReviewModal.astro";
import IntentModalController from "../IntentModalController.astro";

const {
  site,
  city = "nanaimo",
  page,
  listings = [],
  navIntentPages = [],
  areas = [],
} = Astro.props;

const accentColor = site?.accent_color || "#58736a";

const mobileListings = listings.filter((listing: any) => {
  const normalizedType = String(
    listing?.normalized_type || ""
  )
    .toLowerCase()
    .trim();

  const propertyType = String(
    listing?.property_type || ""
  )
    .toLowerCase()
    .trim();

  return (
    normalizedType === "mobile" ||
    propertyType === "mobile" ||
    propertyType === "manufactured home" ||
    propertyType === "manufactured"
  );
});

const titleCase = (value = "") =>
  String(value || "")
    .replace(/-/g, " ")
    .replace(/\s+/g, " ")
    .trim()
    .split(" ")
    .filter(Boolean)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");

const areaName = titleCase(page?.area || page?.slug || city);
const cityName = titleCase(city);

const formatPrice = (value: unknown) => {
  const price = Number(value || 0);

  if (!price) return "Price unavailable";

  return `$${price.toLocaleString()}`;
};

const formatAddress = (value: unknown) => {
  if (!value) return "";

  if (typeof value === "string") {
    const trimmed = value.trim();

    if (!trimmed.startsWith("{")) {
      return trimmed;
    }

    try {
      value = JSON.parse(trimmed);
    } catch {
      return trimmed;
    }
  }

  if (!value || typeof value !== "object" || Array.isArray(value)) {
    return "";
  }

  const address = value as Record<string, unknown>;

  return [
    address.streetNumber,
    address.streetName || address.streetAddress,
    address.streetSuffix,
    address.unitNumber ? `#${address.unitNumber}` : "",
  ]
    .filter(Boolean)
    .join(" ")
    .trim();
};

const normalizeImageUrl = (value: unknown) => {
  const url = String(value || "").trim();

  if (!url) return "";

  if (url.startsWith("http://") || url.startsWith("https://")) {
    return url;
  }

  if (url.startsWith("/")) {
    return `https://cdn.repliers.io${url}`;
  }

  if (url.startsWith("vreb/")) {
    return `https://cdn.repliers.io/${url}`;
  }

  return url;
};

const getListingImages = (listing: any) => {
  const images = Array.isArray(listing?.images)
    ? listing.images
        .map((image: any) =>
          normalizeImageUrl(
            image?.highRes ||
              image?.mediumRes ||
              image?.lowRes ||
              image?.url ||
              image
          )
        )
        .filter(Boolean)
    : [];

  const primaryImage = normalizeImageUrl(listing?.image_url);

  return Array.from(
    new Set([primaryImage, ...images].filter(Boolean))
  );
};

const listingPrices = mobileListings
  .map((listing: any) => Number(listing?.price || 0))
  .filter((price: number) => price > 0)
  .sort((a: number, b: number) => a - b);

const medianPrice = listingPrices.length
  ? listingPrices[Math.floor(listingPrices.length / 2)]
  : 0;

const sevenDaysAgo = Date.now() - 7 * 24 * 60 * 60 * 1000;

const newThisWeek = mobileListings.filter((listing: any) => {
  const listedAt = new Date(
    listing?.listed_at || listing?.created_at || ""
  ).getTime();

  return Number.isFinite(listedAt) && listedAt >= sevenDaysAgo;
}).length;

const exploreHref =
  `/explore?city=${encodeURIComponent(city)}` +
  `&area=${encodeURIComponent(page?.area || "")}` +
  `&type=mobile`;

const heroHeading =
  page?.hero_heading ||
  `Mobile Homes for Sale in ${areaName}`;

const heroIntro =
  page?.intro_copy ||
  page?.seo_intro ||
  `Browse mobile homes currently for sale in ${areaName}. Compare prices, park locations, home features and new listings as they reach the market.`;
---

<div
  class="mobile-area-page"
  style={`--mobile-area-accent:${accentColor};`}
  data-city={city}
  data-area={page?.area || ""}
  data-page-id={page?.id || ""}
>
  <SiteNav
    city={city}
    site={site}
    areas={areas}
    intentPages={navIntentPages}
  />

  <main>
    <section class="mobile-area-hero">
      <div class="mobile-area-hero__copy">
        <p class="eyebrow">{cityName} Mobile Homes</p>

        <h1>
          {heroHeading}<span>.</span>
        </h1>

        <p class="hero-intro">{heroIntro}</p>

        <div class="hero-actions">
          <a class="primary-button" href="#mobile-area-listings">
            Browse {mobileListings.length} listings
          </a>

          <a class="secondary-button" href={exploreHref}>
            Open in Explorer
          </a>
        </div>
      </div>

      <aside class="area-summary-card">
        <p class="summary-label">Area overview</p>

        <h2>{areaName}</h2>

        <p>
          See active mobile-home inventory in {areaName}, compare current
          pricing and open the area in Explorer to understand park locations
          and nearby amenities.
        </p>

        <a href={exploreHref}>Explore {areaName} →</a>
      </aside>
    </section>

    <section class="market-stats" aria-label="Mobile home market snapshot">
      <article>
        <strong>{listings.length}</strong>
        <span>Mobile homes for sale</span>
        <small>Active MLS® listings</small>
      </article>

      <article>
        <strong>
          {medianPrice ? formatPrice(medianPrice) : "—"}
        </strong>
        <span>Median asking price</span>
        <small>Current inventory</small>
      </article>

      <article>
        <strong>{newThisWeek}</strong>
        <span>New this week</span>
        <small>Recently listed</small>
      </article>

      <article>
        <strong>{areaName}</strong>
        <span>Search area</span>
        <small>{cityName}, BC</small>
      </article>
    </section>

    <section class="area-guide">
      <div>
        <p class="eyebrow">Buying in this area</p>

        <h2>Compare more than the home itself.</h2>
      </div>

      <div class="guide-grid">
        <article>
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M3 11.5 12 4l9 7.5" />
              <path d="M5.5 10.5V20h13v-9.5" />
              <path d="M9.5 20v-6h5v6" />
            </svg>
          </span>

          <div>
            <strong>Park location</strong>
            <p>
              Compare the park, surrounding neighbourhood and access to
              everyday services.
            </p>
          </div>
        </article>

        <article>
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M12 3v18" />
              <path d="M17 7c0-2-2-3-5-3S7 5 7 7s2 3 5 4 5 2 5 4-2 3-5 3-5-1-5-3" />
            </svg>
          </span>

          <div>
            <strong>Pad fees</strong>
            <p>
              Review the monthly pad fee, included services and possible
              future increases.
            </p>
          </div>
        </article>

        <article>
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <circle cx="7" cy="7" r="2" />
              <circle cx="17" cy="7" r="2" />
              <circle cx="5" cy="13" r="2" />
              <circle cx="19" cy="13" r="2" />
              <path d="M8.5 18c0-2.2 1.6-4 3.5-4s3.5 1.8 3.5 4c0 1.7-1.5 2.5-3.5 2.5S8.5 19.7 8.5 18Z" />
            </svg>
          </span>

          <div>
            <strong>Park rules</strong>
            <p>
              Confirm age restrictions, pet policies, rental rules and park
              approval requirements.
            </p>
          </div>
        </article>
      </div>
    </section>

    <section id="mobile-area-listings" class="listings-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Current listings</p>
          <h2>Mobile homes in {areaName}</h2>
        </div>

        <p>
          {listings.length} active listing{listings.length === 1 ? "" : "s"}
        </p>
      </div>

      {listings.length > 0 ? (
        <div class="listing-grid">
         {mobileListings.map((listing: any, index: number) => {
            const images = getListingImages(listing);

            const image =
              images[0] ||
              "https://placehold.co/800x600?text=Mobile+Home";

            const listingId = String(
              listing?.id ||
                listing?.mls_number ||
                `mobile-area-${index}`
            );

            return (
              <article
                class="listing-card"
                data-item-id={listingId}
                data-card-id={listingId}
                data-listing-id={listingId}
                data-mls={String(
                  listing?.mls_number || listing?.id || ""
                )}
                data-image={image}
                data-images={JSON.stringify(images)}
                data-price={formatPrice(listing?.price)}
                data-raw-price={String(listing?.price || 0)}
                data-address={formatAddress(listing?.address)}
                data-meta={`${listing?.beds || "-"} bed · ${
                  listing?.baths || "-"
                } bath`}
                data-beds={String(listing?.beds || "-")}
                data-baths={String(listing?.baths || "-")}
                data-sqft={String(listing?.sqft || "")}
                data-type="mobile"
                data-year={String(listing?.year_built || "")}
                data-dom={String(
                  listing?.days_on_market || listing?.dom || ""
                )}
                data-description={String(
                  listing?.description || ""
                ).replace(/"/g, "&quot;")}
                data-liked-tags="[]"
                data-is-favourite="false"
                data-decision=""
                data-lat={listing?.lat || ""}
                data-lng={listing?.lng || ""}
                data-city={String(
                  listing?.normalized_city ||
                    listing?.city ||
                    city
                )}
                data-area={String(
                  listing?.normalized_area ||
                    listing?.area ||
                    page?.area ||
                    ""
                ).toLowerCase()}
                tabindex="0"
                role="button"
              >
                <div class="listing-card__image">
                  <img
                    src={image}
                    alt={
                      formatAddress(listing?.address) ||
                      `Mobile home in ${areaName}`
                    }
                    width="800"
                    height="600"
                    loading={index === 0 ? "eager" : "lazy"}
                    fetchpriority={index === 0 ? "high" : "auto"}
                    decoding="async"
                  />
                </div>

                <div class="listing-card__body">
                  <strong class="listing-price">
                    {formatPrice(listing?.price)}
                  </strong>

                  <p class="listing-address">
                    {formatAddress(listing?.address) ||
                      `Mobile home in ${areaName}`}
                  </p>

                  <p class="listing-location">
                    {areaName}, {cityName}
                  </p>

                  <div class="listing-meta">
                    <span>{listing?.beds || "—"} bd</span>
                    <span>{listing?.baths || "—"} ba</span>

                    {listing?.sqft ? (
                      <span>
                        {Number(listing.sqft).toLocaleString()} sq ft
                      </span>
                    ) : null}
                  </div>
                </div>

                <div class="card-decision-badge" hidden></div>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="empty-state">
          <h3>No active mobile-home listings in {areaName}</h3>

          <p>
            Inventory changes regularly. You can still explore the area,
            review nearby parks or browse mobile homes elsewhere in
            {cityName}.
          </p>

          <a class="primary-button" href={exploreHref}>
            Open Explorer
          </a>
        </div>
      )}
    </section>

    <section class="bottom-cta">
      <div>
        <p class="eyebrow">Explore the area</p>
        <h2>See where each mobile home is located.</h2>
        <p>
          Open Explorer to compare listings, mobile-home park locations,
          neighbourhoods and nearby amenities across {areaName}.
        </p>
      </div>

      <a class="primary-button" href={exploreHref}>
        Explore {areaName}
      </a>
    </section>
  </main>

  <ShortlistReviewModal />
  <IntentModalController loadMapScript={false} />
</div>

<style>
  .mobile-area-page {
    --ink: #17201d;
    --muted: #66706c;
    --line: rgba(23, 32, 29, 0.11);
    --soft: #f4f7f5;
    --warm: #faf7f1;
    --accent: var(--mobile-area-accent);

    min-height: 100vh;
    background: #fff;
    color: var(--ink);
    font-family: "DM Sans", system-ui, sans-serif;
  }

  main {
    width: min(1160px, calc(100% - 48px));
    margin: 0 auto;
    padding: 58px 0 88px;
  }

  .eyebrow {
    margin: 0 0 11px;
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 850;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .mobile-area-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(310px, 0.75fr);
    gap: 62px;
    align-items: center;
  }

  .mobile-area-hero__copy {
    padding: 20px 0;
  }

  h1 {
    max-width: 760px;
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3rem, 6.4vw, 5.7rem);
    font-weight: 500;
    line-height: 0.94;
    letter-spacing: -0.067em;
  }

  h1 span {
    color: var(--accent);
  }

  .hero-intro {
    max-width: 650px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.72;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 11px;
    margin-top: 29px;
  }

  .primary-button,
  .secondary-button {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 19px;
    border-radius: 7px;
    font-size: 0.8rem;
    font-weight: 800;
    text-decoration: none;
  }

  .primary-button {
    border: 1px solid var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .secondary-button {
    border: 1px solid var(--line);
    background: #fff;
    color: var(--accent);
  }

  .area-summary-card {
    padding: 30px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--accent) 8%, white),
        #fff 66%
      );
  }

  .summary-label {
    margin: 0 0 9px;
    color: var(--accent);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .area-summary-card h2 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2rem;
    font-weight: 500;
    letter-spacing: -0.045em;
  }

  .area-summary-card > p:not(.summary-label) {
    margin: 16px 0 22px;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.65;
  }

  .area-summary-card a {
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 850;
    text-decoration: none;
  }

  .market-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    overflow: hidden;
    margin-top: 50px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: #fff;
  }

  .market-stats article {
    min-width: 0;
    padding: 22px;
  }

  .market-stats article + article {
    border-left: 1px solid var(--line);
  }

  .market-stats strong,
  .market-stats span,
  .market-stats small {
    display: block;
  }

  .market-stats strong {
    overflow: hidden;
    margin-bottom: 5px;
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .market-stats span {
    font-size: 0.74rem;
    font-weight: 750;
  }

  .market-stats small {
    margin-top: 4px;
    color: var(--muted);
    font-size: 0.65rem;
  }

  .area-guide {
    display: grid;
    grid-template-columns: minmax(250px, 0.7fr) minmax(0, 1.3fr);
    gap: 48px;
    margin-top: 66px;
    padding: 38px;
    border-radius: 18px;
    background: var(--warm);
  }

  .area-guide h2 {
    max-width: 390px;
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .guide-grid {
    display: grid;
    gap: 1px;
    border: 1px solid var(--line);
    background: var(--line);
  }

  .guide-grid article {
    display: grid;
    grid-template-columns: 38px minmax(0, 1fr);
    gap: 14px;
    padding: 18px;
    background: rgba(255, 255, 255, 0.94);
  }

  .guide-grid article > span {
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--soft);
    color: var(--accent);
  }

  .guide-grid svg {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .guide-grid strong {
    display: block;
    font-size: 0.84rem;
  }

  .guide-grid p {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.55;
  }

  .listings-section {
    margin-top: 78px;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 22px;
  }

  .section-heading h2 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.1rem, 4vw, 3.4rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .section-heading > p {
    margin: 0;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 750;
  }

  .listing-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 15px;
  }

  .listing-card {
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 11px;
    background: #fff;
    cursor: pointer;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .listing-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 36%, transparent);
    box-shadow: 0 14px 34px rgba(23, 32, 29, 0.08);
  }

  .listing-card__image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--soft);
  }

  .listing-card__image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .listing-card__body {
    padding: 14px;
  }

  .listing-price {
    display: block;
    margin-bottom: 7px;
    font-size: 1.05rem;
    font-weight: 850;
    letter-spacing: -0.03em;
  }

  .listing-address {
    overflow: hidden;
    margin: 0;
    font-size: 0.76rem;
    font-weight: 700;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .listing-location {
    margin: 3px 0 11px;
    color: var(--muted);
    font-size: 0.67rem;
  }

  .listing-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    color: var(--muted);
    font-size: 0.68rem;
  }

  .listing-meta span + span::before {
    content: "·";
    margin-right: 6px;
  }

  .empty-state {
    padding: 48px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--soft);
    text-align: center;
  }

  .empty-state h3 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2rem;
    font-weight: 500;
  }

  .empty-state p {
    max-width: 620px;
    margin: 14px auto 24px;
    color: var(--muted);
    line-height: 1.65;
  }

  .bottom-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 34px;
    margin-top: 76px;
    padding: 38px;
    border-radius: 18px;
    background: var(--soft);
  }

  .bottom-cta h2 {
    max-width: 670px;
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .bottom-cta p:not(.eyebrow) {
    max-width: 660px;
    margin: 15px 0 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .bottom-cta > .primary-button {
    flex: none;
  }

  @media (max-width: 1050px) {
    .listing-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .mobile-area-hero,
    .area-guide {
      grid-template-columns: 1fr;
    }

    .market-stats,
    .listing-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .market-stats article:nth-child(3) {
      border-left: 0;
      border-top: 1px solid var(--line);
    }

    .market-stats article:nth-child(4) {
      border-top: 1px solid var(--line);
    }

    .bottom-cta {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    main {
      width: 100%;
      padding: 34px 14px 68px;
    }

    h1 {
      font-size: clamp(2.7rem, 14vw, 4rem);
    }

    .area-summary-card,
    .area-guide,
    .bottom-cta {
      padding: 24px 20px;
    }

    .market-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .market-stats article {
      padding: 17px 14px;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
    }

    .listing-grid {
      grid-template-columns: 1fr;
    }

    .listing-card__body {
      padding: 15px;
    }
  }
</style>

<script is:inline>
  document.querySelectorAll(".listing-card").forEach((card) => {
    card.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        card.click();
      }
    });
  });
</script>