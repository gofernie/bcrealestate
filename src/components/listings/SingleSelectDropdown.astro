---
interface Option {
  value: string;
  label: string;
}

interface Props {
  label: string;
  name: string;
  filterKey?: string;
  urlParameter?: string;
  options: Option[];
  defaultLabel: string;
  mode?: "filter" | "sort";
  filterMode?: "exact" | "minimum" | "maximum" | "includes";
  icon?: "home" | "beds" | "price" | "sort";
}

const {
  label,
  name,
  filterKey = name,
  urlParameter = name,
  options = [],
  defaultLabel,
  mode = "filter",
  filterMode = "exact",
  icon = "home",
} = Astro.props;
---

<div
  class="single-filter"
  data-single-filter-group
>
  <button
    class="single-filter__trigger"
    type="button"
    aria-haspopup="true"
    aria-expanded="false"
    data-single-filter-trigger
  >
    <span
      class="single-filter__icon"
      aria-hidden="true"
    >
      {
        icon === "home" && (
          <svg viewBox="0 0 24 24">
            <path d="M3 11.5 12 4l9 7.5"></path>
            <path d="M5.5 10.5V21h13V10.5"></path>
            <path d="M9.5 21v-6h5v6"></path>
          </svg>
        )
      }

      {
        icon === "beds" && (
          <svg viewBox="0 0 24 24">
            <path d="M3 18v-7h18v7"></path>
            <path d="M5 11V7h6v4"></path>
            <path d="M13 11V7h6v4"></path>
            <path d="M3 18v3"></path>
            <path d="M21 18v3"></path>
          </svg>
        )
      }

      {
        icon === "price" && (
          <svg viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M15 8.5c-.7-.7-1.7-1-3-1-1.7 0-3 .9-3 2.2 0 1.4 1.2 2 3.2 2.5 1.8.5 2.8 1.1 2.8 2.3 0 1.3-1.2 2.2-3 2.2-1.3 0-2.5-.4-3.3-1.2"></path>
            <path d="M12 5.5v13"></path>
          </svg>
        )
      }

      {
        icon === "sort" && (
          <svg viewBox="0 0 24 24">
            <path d="M7 6h10"></path>
            <path d="M9 12h6"></path>
            <path d="M11 18h2"></path>
          </svg>
        )
      }
    </span>

    <span class="single-filter__content">
      <strong>{label}</strong>

      <span data-single-filter-summary>
        {defaultLabel}
      </span>
    </span>

    <svg
      class="single-filter__chevron"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path d="m7 9 5 5 5-5"></path>
    </svg>
  </button>

  <div
    class="single-filter__menu"
    data-single-filter-menu
    hidden
  >
    <button
      type="button"
      class="single-filter__option"
      data-single-filter-option
      data-value=""
      data-label={defaultLabel}
    >
      <span>{defaultLabel}</span>
      <span
        class="single-filter__check"
        aria-hidden="true"
      >
        ✓
      </span>
    </button>

    {
      options.map((option) => (
        <button
          type="button"
          class="single-filter__option"
          data-single-filter-option
          data-value={option.value}
          data-label={option.label}
        >
          <span>{option.label}</span>

          <span
            class="single-filter__check"
            aria-hidden="true"
          >
            ✓
          </span>
        </button>
      ))
    }
  </div>

  {
    mode === "sort" ? (
      <input
        type="hidden"
        name={name}
        value=""
        data-listing-sort
        data-url-parameter={urlParameter}
        data-single-filter-input
      />
    ) : (
      <input
        type="hidden"
        name={name}
        value=""
        data-listing-filter
        data-filter-key={filterKey}
        data-filter-mode={filterMode}
        data-url-parameter={urlParameter}
        data-single-filter-input
      />
    )
  }
</div>

<style>
  .single-filter {
    position: relative;
    min-width: 0;
    border-right: 1px solid var(--bc-line);
  }

  .single-filter__trigger {
    display: flex;
    width: 100%;
    min-height: 98px;
    align-items: center;
    gap: 13px;
    padding: 22px;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    text-align: left;
    cursor: pointer;
  }

  .single-filter__icon {
    display: block;
    width: 31px;
    height: 31px;
    flex: 0 0 31px;
  }

  .single-filter__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.65;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .single-filter__content {
    display: flex;
    min-width: 0;
    flex: 1;
    flex-direction: column;
    gap: 4px;
  }

  .single-filter__content strong {
    font-size: 0.77rem;
  }

  .single-filter__content > span {
    overflow: hidden;
    color: var(--bc-muted);
    font-size: 0.78rem;
    font-weight: 400;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .single-filter__chevron {
    width: 17px;
    height: 17px;
    flex: 0 0 17px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 0.18s ease;
  }

  .single-filter[data-open="true"]
    .single-filter__chevron {
    transform: rotate(180deg);
  }

.single-filter__menu {
  position: absolute;
  z-index: 40;
  top: calc(100% + 6px);
  left: 0;
  width: 100%;
  min-width: 240px;
  overflow: hidden;
  border: 1px solid var(--bc-line);
  border-radius: 12px;
  background: #fff;
  box-shadow: 0 18px 45px rgba(20, 32, 28, 0.16);
}

  .single-filter__option {
    display: flex;
    width: 100%;
    min-height: 44px;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 14px;
    border: 0;
    border-bottom: 1px solid var(--bc-line);
    background: #fff;
    color: inherit;
    font: inherit;
    font-size: 0.82rem;
    text-align: left;
    cursor: pointer;
  }

  .single-filter__option:last-child {
    border-bottom: 0;
  }

  .single-filter__option:hover {
    background: var(--bc-cream);
  }

  .single-filter__option.is-selected {
    background:
      color-mix(
        in srgb,
        var(--bc-home-accent) 8%,
        white
      );
    color: var(--bc-home-accent);
    font-weight: 750;
  }

  .single-filter__check {
    opacity: 0;
    color: var(--bc-home-accent);
    font-weight: 900;
  }

  .single-filter__option.is-selected
    .single-filter__check {
    opacity: 1;
  }

@media (max-width: 760px) {
  .single-filter {
    border-right: 0;
    border-bottom: 1px solid var(--bc-line);
  }

  .single-filter__trigger {
    min-height: auto;
  }

  .single-filter__menu {
    top: calc(100% - 1px);
    left: 16px;
    right: 16px;
    width: auto;
    min-width: 0;
    border-radius: 0 0 12px 12px;
    box-shadow: 0 16px 35px rgba(20, 32, 28, 0.15);
  }
}
</style>