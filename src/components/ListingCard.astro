---
type Props = {
  listing: any;
  priority?: boolean;
};

const { listing, priority = false } = Astro.props;
const normalizeListingImageUrl = (value: any) => {
  if (!value) return "";

  const raw =
    typeof value === "string"
      ? value
      : value.highRes ||
        value.mediumRes ||
        value.lowRes ||
        value.url ||
        value.src ||
        value.href ||
        value.path ||
        "";

  if (!raw) return "";

  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;

  const cleaned = raw.startsWith("/") ? raw : `/${raw}`;

return `https://cdn.repliers.io${cleaned}`;
};
const listingImages = [
  normalizeListingImageUrl(listing.image_url),

  ...(Array.isArray(listing.images)
    ? listing.images.map((item: any) =>
        normalizeListingImageUrl(item)
      )
    : []),
].filter(Boolean);

const images = [...new Set(listingImages)];

const image =
  images[0] ||
  "https://placehold.co/800x600?text=Listing";

const price = `$${Number(listing.price || 0).toLocaleString()}`;
const formatAddress = (value: any) => {
  if (!value) return "";

  let addressObj = value;

  if (typeof value === "string") {
    const trimmed = value.trim();
    if (!trimmed.startsWith("{")) return trimmed;
    try {
      addressObj = JSON.parse(trimmed);
    } catch {
      return "";
    }
  }

  if (typeof addressObj !== "object" || Array.isArray(addressObj)) return "";

  const result = [
    addressObj.streetNumber,
    addressObj.streetName || addressObj.streetAddress || "",
    addressObj.streetSuffix,
    addressObj.unitNumber ? `#${addressObj.unitNumber}` : "",
  ]
    .filter(Boolean)
    .join(" ")
    .trim();

  return result;
};

const address =
  formatAddress(listing.address_text) ||
  formatAddress(listing.full_address) ||
  formatAddress(listing.address) ||
  "Address available";
const beds = listing.beds || 0;
const baths = listing.baths || 0;
const sqft = listing.sqft || "";
const city = listing.normalized_city || listing.city || "nanaimo";
const cityLabel = String(city).replace(/\b\w/g, (char) => char.toUpperCase());
const normalizeArea = (value: any) =>
  String(value || "")
    .toLowerCase()
    .trim()
    .replace(/^pq[\s-]+/i, "")
    .replace(/&/g, "and")
    .replace(/\//g, "-")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const area =
  listing.normalized_area ||
  listing.area ||
  "";

const areaSlug = normalizeArea(area);
---

<article
  class="card original-card"
  data-item-id={String(listing.id || listing.mls_number || "")}
  data-card-id={String(listing.id || listing.mls_number || "")}
  data-listing-id={String(listing.id || listing.mls_number || "")}
  data-price={price}
  data-raw-price={String(listing.price || 0)}
  data-address={address}
  data-meta={`${beds || "-"} bed · ${baths || "-"} bath`}
  data-image={image}
data-images={JSON.stringify(images)} data-beds={String(beds || "")}
  data-baths={String(baths || "")}
  data-sqft={String(sqft || "")}
  data-description={listing.description || ""}
  data-property-type={listing.property_type || listing.normalized_type || "Home"}
  data-type={listing.normalized_type || listing.property_type || "Home"}
data-area={areaSlug}
  data-liked-tags="[]"
  data-is-favourite="false"
  data-decision=""
  data-lat={listing.lat || ""}
  data-lng={listing.lng || ""}
  data-city={city}
  data-mls={listing.mls_number || ""}
>
  <div class="card-image-wrap">
       <img
src={image}
  alt={address}
  loading={priority ? "eager" : "lazy"}
  fetchpriority={priority ? "high" : "auto"}
  decoding="async"
/>
  </div>

  <div class="card-body">
 <div class="price-row">
  <div class="price">{price}</div>
  <div class="card-decision-badge" hidden></div>
</div>

<div class="address">{address}</div>

    <div class="card-city">{cityLabel}, BC</div>

    <div class="meta">
 <span>{beds || "-"} bd</span>
<span>{baths || "-"} ba</span>
{sqft && <span>{Number(sqft).toLocaleString()} sq ft</span>}</div>

    
  </div>
</article>

<style>
.card {
  position: relative;
  display: flex;
  height: 100%;
  flex-direction: column;
  overflow: hidden;
  border: 1px solid var(--line-warm);
  border-radius: 6px;
  background: #fff;
  color: inherit;
  cursor: pointer;
  box-shadow: 0 2px 16px rgba(28, 25, 23, 0.04);
  transition:
    box-shadow 0.24s ease,
    border-color 0.24s ease;
}

.card:hover {
  border-color: var(--accent-light);
  box-shadow: 0 14px 38px rgba(28, 25, 23, 0.11);
}

.card-image-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 4 / 3;
  overflow: hidden;
  background: #eee8df;
}

.card-image-wrap img {
  position: absolute;
  inset: -12px;
  display: block;
  width: calc(100% + 20px);
  height: calc(100% + 20px);
  object-fit: cover;
  object-position: center;
  transition: transform 0.35s ease;
}

.card:hover .card-image-wrap img {
  transform: scale(1.025);
}

.card-body {
  position: relative;
  display: flex;
  min-height: 138px;
  flex: 1;
  flex-direction: column;
  padding: 14px 16px;
  background: #fff;
}

.price {
  font-size: 1.34rem;
  line-height: 1.1;
  font-weight: 700;
  letter-spacing: -0.035em;
}

.address {
  margin-bottom: 2px;
  color: var(--ink);
  line-height: 1.35;
  font-size: 0.9rem;
  font-weight: 600;
}

  .card-city {
    margin-bottom: 14px;
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 700;
  }

 .meta {
  display: flex;
  align-items: center;
  gap: 18px;
  margin-top: auto;
  font-size: 0.86rem;
  color: var(--ink-soft);
  font-weight: 600;
}

  .meta span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }

.card-decision-badge {
  position: static;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  width: fit-content;
  margin: 0;
  padding: 5px 9px;
  border-radius: 999px;
  font-size: 0.66rem;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  white-space: nowrap;
}

  .card-decision-badge[hidden] {
    display: none;
  }

.card-decision-badge.is-love {
    background: #ff3b30;
    color: #fff;
  }

  .card-decision-badge.is-maybe {
    background: #f59e0b;
    color: #fff;
  }

  .card-decision-badge.is-pass {
    background: rgba(24, 22, 20, 0.08);
    color: rgba(24, 22, 20, 0.56);
  }

  .price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 8px;
}
</style>