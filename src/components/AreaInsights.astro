---
const {
  title = "Neighbourhood Insights",
  copy = "A quick read on the area using market activity, neighbourhood profile data, and visible listings.",
  profile = {},
  stats = {},
  compact = false,
} = Astro.props;

const pick = (...values) =>
  values.find((value) => value !== null && value !== undefined && value !== "");

const formatMoney = (value) =>
  Number(value || 0) > 0 ? `$${Number(value).toLocaleString()}` : "—";

const formatNumber = (value) =>
  Number(value || 0) > 0 ? Number(value).toLocaleString() : "—";

const formatPercent = (value) =>
  value !== null && value !== undefined && value !== ""
    ? `${Number(value).toFixed(2)}%`
    : "—";

const population = pick(
  profile.population,
  profile.total_population,
  profile.pop,
  profile.census_population
);

const populationChange = pick(
  profile.population_change,
  profile.population_change_percent,
  profile.pop_change,
  profile.growth_rate
);

const income = pick(
  profile.median_household_income,
  profile.household_income,
  profile.median_income,
  profile.income
);
---

<section class={`area-insights ${compact ? "is-compact" : ""}`}>
  <div class="area-insights-head">
    <div>
      <strong>{title}</strong>
      <p>{copy}</p>
    </div>

    <span>{compact ? "Explorer snapshot" : "Neighbourhood snapshot"}</span>
  </div>

  <div class="area-insights-grid">
    <article>
      <strong>⚖️ {stats.marketTone || "Market snapshot"}</strong>
      <span>current market</span>
    </article>

    <article>
      <strong>🏠 {formatNumber(stats.homesForSale)}</strong>
      <span>homes for sale</span>
    </article>

    <article>
      <strong>{formatMoney(stats.medianPrice)}</strong>
      <span>median price</span>
    </article>

    <article>
      <strong>👥 {formatNumber(population)}</strong>
      <span>population</span>
    </article>

    <article>
      <strong>📈 {formatPercent(populationChange)}</strong>
      <span>population change</span>
    </article>

    <article>
      <strong>💰 {formatMoney(income)}</strong>
      <span>household income</span>
    </article>
  </div>
</section>

<style>
  .area-insights {
    display: grid;
    gap: 12px;
  }

  .area-insights-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-size: .82rem;
    font-weight: 950;
  }

  .area-insights-head span {
    color: var(--muted);
    font-size: .74rem;
    white-space: nowrap;
  }

  .area-insights-head p {
    max-width: 620px;
    margin: 6px 0 0;
    color: var(--muted);
    font-size: .84rem;
    font-weight: 500;
    line-height: 1.45;
  }

  .area-insights-grid {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: 12px;
  }

  .area-insights-grid article {
    flex: 0 0 190px;
    min-height: 86px;
    padding: 12px;
    border: 1px solid rgba(0,0,0,.07);
    border-radius: 16px;
    background: rgba(255,255,255,.82);
  }

  .area-insights-grid strong {
    display: block;
    font-size: .84rem;
    font-weight: 950;
    line-height: 1.25;
  }

  .area-insights-grid span {
    display: block;
    margin-top: 4px;
    color: var(--muted);
    font-size: .72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  .area-insights.is-compact .area-insights-grid {
    gap: 8px;
  }

  .area-insights.is-compact .area-insights-grid article {
    flex: 0 0 132px;
    min-height: 68px;
    padding: 9px 10px;
    border-radius: 13px;
  }

  .area-insights.is-compact .area-insights-grid strong {
    font-size: .76rem;
  }

  .area-insights.is-compact .area-insights-grid span {
    font-size: .62rem;
    letter-spacing: .06em;
  }

  @media (max-width: 900px) {
    .area-insights-head {
      display: grid;
    }

    .area-insights-grid article {
      flex: 0 0 190px;
      width: 190px;
    }

    .area-insights.is-compact .area-insights-grid article {
      flex: 0 0 132px;
      width: 132px;
    }
  }

  @media (max-width: 520px) {
    .area-insights-grid article {
      flex: 0 0 calc(50% - 6px);
      width: calc(50% - 6px);
    }

    .area-insights.is-compact .area-insights-grid article {
      flex: 0 0 calc(50% - 4px);
      width: calc(50% - 4px);
    }
  }
</style>