---
const { metric } = Astro.props;

function label(index) {
  if (index >= 0.8) return "🔥 Very Active";
  if (index >= 0.6) return "🟢 Active";
  if (index >= 0.4) return "🟡 Balanced";
  if (index >= 0.25) return "🔵 Slower";
  return "⚪ Quiet";
}
---

{metric && (
  <section class="market-snapshot">
    <div>
      <p class="eyebrow">Market Snapshot</p>
      <h2>{metric.market_name} Market Pulse</h2>
      <p class="summary">
        {metric.market_name} is currently showing a <strong>{label(metric.activity_index)}</strong> market,
        with <strong>{metric.active}</strong> active listings and <strong>{metric.pending}</strong> pending listings.
      </p>
    </div>

    <div class="snapshot-grid">
      <article><span>Active</span><strong>{metric.active}</strong></article>
      <article><span>Pending</span><strong>{metric.pending}</strong></article>
      <article><span>Sold</span><strong>{metric.sold}</strong></article>
      <article><span>Market</span><strong>{label(metric.activity_index)}</strong></article>
    </div>
  </section>
)}

<style>
  .market-snapshot {
    margin: 28px auto;
    padding: 22px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    background: #fff;
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.06);
  }

  .eyebrow {
    margin: 0 0 6px;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #64748b;
  }

  h2 {
    margin: 0 0 8px;
    font-size: clamp(1.35rem, 3vw, 2rem);
    letter-spacing: -0.04em;
  }

  .summary {
    margin: 0;
    max-width: 760px;
    color: #475569;
    line-height: 1.6;
  }

  .snapshot-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 18px;
  }

  .snapshot-grid article {
    padding: 16px;
    border-radius: 18px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
  }

  .snapshot-grid span {
    display: block;
    font-size: 0.78rem;
    font-weight: 800;
    color: #64748b;
  }

  .snapshot-grid strong {
    display: block;
    margin-top: 6px;
    font-size: 1.35rem;
  }

  @media (max-width: 760px) {
    .snapshot-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>