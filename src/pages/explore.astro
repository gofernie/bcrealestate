}
      function passesNavFilters(item) {
  if (item.layer !== "homes") return true;

  if (navFilters.location && !item.areaRaw.includes(navFilters.location)) return false;
  if (item.priceRaw < navFilters.priceMin || item.priceRaw > navFilters.priceMax) return false;
  if (navFilters.beds && item.bedsRaw < navFilters.beds) return false;
const selectedType = normalizeExplorerType(navFilters.type);
const itemType = normalizeExplorerType(item.typeRaw || item.propertyRaw);

const looksLikeLand =
