      View listing →
    </button>
  </article>
`, {
  maxWidth: 240,
  className: "listing-preview-popup"
});
marker.on("click", () => {
  item.marker?.openPopup();
  activeHomeItem = item;
  loadAmenities().then(() => {
    renderDrawer();
    drawerSections?.scrollTo({ top: 0, behavior: "smooth" });
  });
});

          item.marker = marker;
          layerGroups.homes.addLayer(marker);
          layerItems.homes.push(item);
        });
      }

      async function loadAmenities() {
        if (Object.keys(amenityCache).length) return;

const visibleHomes = layerItems.homes.filter((home) => passesNavFilters(home));

const centre = visibleHomes.length
  ? L.latLngBounds(visibleHomes.map((home) => [home.lat, home.lng])).getCenter()
  : map.getCenter();

const res = await fetch(
  `/api/osm-amenities?city=${encodeURIComponent(city)}&lat=${centre.lat}&lng=${centre.lng}&radius=5&limit=250`
);
        const json = await res.json();
        Object.assign(amenityCache, json.categories || {});

        Object.entries(layerMeta).forEach(([layerKey, meta]) => {
          if (!meta.apiKey) return;
          const rows = amenityCache[meta.apiKey] || [];

          layerItems[layerKey] = rows
            .map((place, index) => {
              const lat = Number(place.lat);
              const lng = Number(place.lng);
              if (!Number.isFinite(lat) || !Number.isFinite(lng)) return null;

              const item = {
                id: `${layerKey}-${index}-${String(place.name || place.osm_id || "place").replace(/[^a-z0-9]+/gi, "-")}`,
                layer: layerKey,
                title: place.name || place.osm_type || meta.title,
                subtitle: place.type || place.osm_type || meta.title,
                meta: place.distKm ? `${Number(place.distKm).toFixed(1)} km from centre` : meta.title,
                lat,
                lng,
                color: meta.color,
                marker: null,
              };

              const marker = L.circleMarker([lat, lng], {
                radius: 8,
                weight: 3,
                color: "#ffffff",
                fillColor: item.color,
                fillOpacity: 1,
              });

          marker.bindPopup(`
            <article class="map-preview-card">
              ${item.image ? `<img src="${escapeHtml(item.image)}" alt="">` : ""}
              <strong>${escapeHtml(item.title)}</strong>
              <span>${escapeHtml(item.subtitle)}</span>
              <em>${escapeHtml(item.meta)}</em>
              <button type="button" data-preview-listing-id="${escapeHtml(item.id)}">
                View listing →
              </button>
            </article>
          `);

          marker.on("click", () => {
            activeHomeItem = item;
            item.marker?.openPopup();

            loadAmenities().then(() => {
              renderDrawer();
              drawerSections?.scrollTo({ top: 0, behavior: "smooth" });
            });
          });

              item.marker = marker;
              layerGroups[layerKey].addLayer(marker);
              return item;
            })
            .filter(Boolean);
        });
      }

      function syncMapLayers() {
  Object.keys(activeLayers).forEach((layerKey) => {
    const group = layerGroups[layerKey];
    if (!group) return;

    if (activeLayers[layerKey] && !map.hasLayer(group)) group.addTo(map);
    if (!activeLayers[layerKey] && map.hasLayer(group)) map.removeLayer(group);
  });

  layerItems.homes.forEach((item) => {
    if (!item.marker) return;

    const shouldShow = activeLayers.homes && passesNavFilters(item);

    if (shouldShow && !layerGroups.homes.hasLayer(item.marker)) {
      layerGroups.homes.addLayer(item.marker);
    }

    if (!shouldShow && layerGroups.homes.hasLayer(item.marker)) {
      layerGroups.homes.removeLayer(item.marker);
    }
  });
}

      function updateToggleUi() {
        document.querySelectorAll(".explorer-layer[data-layer]").forEach((button) => {
          const layerKey = button.dataset.layer;
          button.classList.toggle("is-active", Boolean(activeLayers[layerKey]));
        });
      }

      function updateCounts() {
        Object.keys(layerItems).forEach((layerKey) => {
          const total = layerItems[layerKey].length;
          const visible = layerItems[layerKey].filter(isVisible).length;
          const el = document.querySelector(`[data-count="${layerKey}"]`);
if (el) el.textContent = total ? String(visible) : "—";
        });
      }

      function distanceKm(a, b) {
        const earthKm = 6371;
        const dLat = (b.lat - a.lat) * Math.PI / 180;
        const dLng = (b.lng - a.lng) * Math.PI / 180;
        const lat1 = a.lat * Math.PI / 180;
        const lat2 = b.lat * Math.PI / 180;
        const x = Math.sin(dLat / 2) ** 2 + Math.cos(lat1) * Math.cos(lat2) * Math.sin(dLng / 2) ** 2;
        return earthKm * 2 * Math.atan2(Math.sqrt(x), Math.sqrt(1 - x));
      }

      function nearestItem(home, layerKey) {
        const rows = layerItems[layerKey] || [];
        return rows
          .map((item) => ({ ...item, km: distanceKm(home, item) }))
          .filter((item) => Number.isFinite(item.km))
          .sort((a, b) => a.km - b.km)[0] || null;
      }

      function countWithin(home, layerKey, kmLimit) {
        return (layerItems[layerKey] || [])
          .filter((item) => distanceKm(home, item) <= kmLimit)
          .length;
      }

      function renderHomeIntelligence(home) {
        if (!home || home.layer !== "homes") return "";

        const rows = [
          { key: "parks", label: "Parks", icon: "🌳", radius: 1.5 },
          { key: "schools", label: "Schools", icon: "🎓", radius: 2.5 },
          { key: "restaurants", label: "Food", icon: "☕", radius: 1.5 },
          { key: "grocery", label: "Grocery", icon: "🛒", radius: 2.5 },
          { key: "medical", label: "Medical", icon: "🏥", radius: 3 },
        ];

        const cards = rows.map((row) => {
          const nearest = nearestItem(home, row.key);
          const count = countWithin(home, row.key, row.radius);
          const nearestText = nearest
            ? `${escapeHtml(nearest.title)} · ${nearest.km.toFixed(1)} km`
            : "No nearby data yet";

          return `
            <article class="intel-card">
              <strong>${row.icon} ${count} ${row.label}</strong>
              <span>within ${row.radius} km</span>
              <em>${nearestText}</em>
            </article>
          `;
        }).join("");

        return `
          <section class="drawer-section drawer-section-intel">
            <div class="drawer-section-title">
              <span>✨ Around this home</span>
              <span>${escapeHtml(home.subtitle || "Neighbourhood intelligence")}</span>
            </div>
            <div class="intel-grid">${cards}</div>
          </section>
        `;
      }

  function cardHtml(item) {
  if (item.layer === "homes") {
    return item.html || "";
  }

  return `
    <article class="place-card" data-layer="${escapeHtml(item.layer)}" data-item-id="${escapeHtml(item.id)}">
      <strong>${escapeHtml(item.title)}</strong>
      <span>${escapeHtml(item.subtitle || item.meta || "")}</span>
    </article>
  `;
}

      function renderDrawer() {
        const activeKeys = Object.keys(activeLayers).filter((key) => activeLayers[key]);
        const titleParts = [];

        const intelligenceHtml = activeHomeItem ? renderHomeIntelligence(activeHomeItem) : "";

        drawerSections.innerHTML = intelligenceHtml + activeKeys.map((layerKey) => {
          const meta = layerMeta[layerKey];
          const visibleItems = layerItems[layerKey].filter(isVisible);
          titleParts.push(`${visibleItems.length} ${meta.title}`);

          const body = visibleItems.length
            ? `<div class="drawer-row">${visibleItems.slice(0, 36).map(cardHtml).join("")}</div>`
            : `<div class="drawer-empty">No ${meta.title.toLowerCase()} visible in this map view.</div>`;

          return `
            <section class="drawer-section" data-drawer-layer="${layerKey}">
              <div class="drawer-section-title">
                <span>${meta.icon} ${meta.title}</span>
                <span>${visibleItems.length} in view</span>
              </div>
              ${body}
            </section>
          `;
        }).join("") || `<div class="drawer-empty">Turn on a layer to explore the map.</div>`;

        if (drawerTitle) drawerTitle.textContent = titleParts.length ? titleParts.join(" · ") : "Explorer layers";

        drawerSections.querySelectorAll("[data-item-id]").forEach((card) => {
          const layerKey = card.dataset.layer;
          const id = card.dataset.itemId;
          const item = layerItems[layerKey]?.find((row) => row.id === id);
          if (!item) return;

          card.addEventListener("click", () => focusItem(item, card));
          card.addEventListener("mouseenter", () => item.marker?.openPopup());
          card.addEventListener("mouseleave", () => {
            if (!card.classList.contains("is-active")) item.marker?.closePopup();
          });
        });
      }

      function refreshExplorer() {
        syncMapLayers();
        updateToggleUi();
        updateCounts();
        renderDrawer();
      }

      function fitActiveLayers() {
        const points = Object.keys(activeLayers)
          .filter((key) => activeLayers[key])
          .flatMap((key) => layerItems[key])
          .filter((item) => Number.isFinite(item.lat) && Number.isFinite(item.lng))
          .map((item) => [item.lat, item.lng]);

        if (points.length) {
          map.flyToBounds(points, { padding: [70, 70], duration: 0.45 });
        }
      }

      buildHomeLayer();
      layerGroups.homes.addTo(map);

      const homePoints = layerItems.homes.map((item) => [item.lat, item.lng]);
      if (homePoints.length) {
        map.fitBounds(homePoints, { padding: [40, 40] });
      } else {
        map.setView([49.1659, -123.9401], 11);
      }

      refreshExplorer();
      setTimeout(() => map.invalidateSize(), 100);

      document.querySelectorAll(".explorer-layer[data-layer]").forEach((button) => {
        button.addEventListener("click", async () => {
          const layerKey = button.dataset.layer;
          if (!layerKey) return;

          if (layerKey !== "homes") await loadAmenities();
          activeLayers[layerKey] = !activeLayers[layerKey];

          refreshExplorer();
        });
      });
           const lifestyleBundles = {
        family: ["schools", "parks"],
        daily: ["grocery", "medical"],
        food: ["restaurants"],
      };

      const bundleButtons = document.querySelectorAll(".explorer-layer[data-bundle]");

      bundleButtons.forEach((button) => {
        button.addEventListener("click", async () => {
          const bundleKey = button.dataset.bundle;
          const layers = lifestyleBundles[bundleKey] || [];

          await loadAmenities();

          const isAlreadyActive = button.classList.contains("is-active");

          Object.keys(activeLayers).forEach((layerKey) => {
            activeLayers[layerKey] = layerKey === "homes";
          });

          bundleButtons.forEach((btn) => btn.classList.remove("is-active"));

          if (!isAlreadyActive) {
            layers.forEach((layerKey) => {
              activeLayers[layerKey] = true;
            });

            button.classList.add("is-active");
          }

          refreshExplorer();
        });
      });
      map.on("moveend zoomend", async () => {
        await loadAmenities();
        updateCounts();
        renderDrawer();
      });
                      document.addEventListener("click", (event) => {
  const button = event.target.closest("[data-preview-listing-id]");
  if (!button) return;

  event.preventDefault();
  event.stopPropagation();

  const id = button.dataset.previewListingId;
  const item = layerItems.homes.find((home) => String(home.id) === String(id));

