function normalizeExplorerType(value = "") {
  const type = String(value).toLowerCase().trim();

  if (type.includes("townhouse") || type.includes("townhome") || type.includes("row")) return "townhouse";
  if (type.includes("condo") || type.includes("apartment")) return "condo";
  if (type.includes("manufactured") || type.includes("mobile")) return "mobile";
  if (type.includes("land") || type.includes("lot")) return "land";
  if (type.includes("house") || type.includes("single family") || type.includes("detached")) return "house";

