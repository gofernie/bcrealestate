function focusFilteredHomesOnMap() {
  const homes = layerItems.homes
    .filter((home) => passesNavFilters(home))
    .filter((home) => Number.isFinite(home.lat) && Number.isFinite(home.lng));

  if (!homes.length) return;

  const isMobile = window.matchMedia("(max-width: 760px)").matches;
  const bounds = L.latLngBounds(homes.map((home) => [home.lat, home.lng]));

  if (isMobile) {
    map.fitBounds(bounds, {
      padding: [36, 120],
      maxZoom: 14,
    });
    return;
  }

  const center = bounds.getCenter();

  map.flyTo(center, 13, { duration: 0.45 });

  window.setTimeout(() => {
    map.panBy([-130, 0], { animate: true, duration: 0.25 });
  }, 480);
}

document.querySelectorAll("[data-filter-location]").forEach((button) => {
