      const homeTemplate = document.getElementById("home-card-template");

      if (!explorer || !mapEl || !window.L || !drawerSections || !homeTemplate) return;

      const city = explorer.dataset.city || "nanaimo";
      const accent = getComputedStyle(document.documentElement).getPropertyValue("--accent").trim() || "#2f6f73";

      const activeLayers = {
        homes: true,
        parks: false,
        schools: false,
        restaurants: false,
        grocery: false,
        medical: false,
      };

      const layerMeta = {
        homes: { title: "Homes", icon: "🏠", color: accent, apiKey: null },
        parks: { title: "Parks", icon: "🌳", color: "#2f9e44", apiKey: "park" },
        schools: { title: "Schools", icon: "🎓", color: "#3b82f6", apiKey: "school" },
        restaurants: { title: "Restaurants", icon: "☕", color: "#b7791f", apiKey: "restaurant" },
        grocery: { title: "Grocery", icon: "🛒", color: "#0f766e", apiKey: "grocery" },
        medical: { title: "Medical", icon: "🏥", color: "#be123c", apiKey: "medical" },
      };

      const map = L.map(mapEl, {
        zoomControl: true,
        attributionControl: false,
        scrollWheelZoom: false,
      });

      window.explorerMap = map;
      window.explorerLayerState = activeLayers;

      L.tileLayer("https://tile.jawg.io/jawg-sunny/{z}/{x}/{y}{r}.png?access-token=b1s1QJemw8edeXxh4KJ8TlNOiv65lYOzNehwlDLXuuCmoOvTqxTmnl9aSmIQGu1R", {
        maxZoom: 22,
        attribution: '&copy; <a href="https://jawg.io">Jawg</a> &copy; <a href="https://www.openstreetmap.org">OpenStreetMap</a>',
      }).addTo(map);

      const layerGroups = Object.fromEntries(
        Object.keys(activeLayers).map((key) => [key, L.layerGroup()])
      );

      const layerItems = {
        homes: [],
        parks: [],
        schools: [],
        restaurants: [],
        grocery: [],
        medical: [],
      };

      const amenityCache = {};
   let activeHomeItem = null;

const navFilters = {
  location: "",
  priceMin: 0,
  priceMax: Infinity,
  beds: 0,
  type: "",
};

      function escapeHtml(value = "") {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      }

      function passesNavFilters(item) {
  if (item.layer !== "homes") return true;

  if (navFilters.location && !item.areaRaw.includes(navFilters.location)) return false;
  if (item.priceRaw < navFilters.priceMin || item.priceRaw > navFilters.priceMax) return false;
  if (navFilters.beds && item.bedsRaw < navFilters.beds) return false;
  if (navFilters.type && !item.typeRaw.includes(navFilters.type)) return false;

  return true;
}

function isVisible(item) {
  if (!Number.isFinite(item.lat) || !Number.isFinite(item.lng)) return false;
  if (!passesNavFilters(item)) return false;
  return map.getBounds().contains([item.lat, item.lng]);
}

      function setMarkerActive(item, active) {
        if (!item.marker?.setStyle) return;
        item.marker.setStyle({
          radius: active ? 13 : 8,
          weight: active ? 4 : 3,
          color: "#ffffff",
          fillColor: active ? "#0f2f4a" : item.color,
          fillOpacity: 1,
        });
      }

         function clearActiveCards() {
        document.querySelectorAll(".explorer-card.is-active, .place-card.is-active")
          .forEach((card) => card.classList.remove("is-active"));

        Object.values(layerItems).flat().forEach((item) => setMarkerActive(item, false));
      }

function openListingFromExplorerItem(item, sourceCard = null) {
  if (!item) return;

  const id = String(item.id || "").trim();
  if (!id) return;

  let card = sourceCard;

  if (!card) {
    card = Array.from(
      document.querySelectorAll(`.original-card[data-item-id="${CSS.escape(id)}"]`)
    ).find((el) => !el.closest("template"));
  }

  if (!card && item.html) {
    const wrap = document.createElement("div");
    wrap.innerHTML = item.html.trim();
    card = wrap.firstElementChild;
    card.style.position = "fixed";
    card.style.left = "-9999px";
    card.style.top = "-9999px";
    document.body.appendChild(card);
  }

  if (!card) {
    console.warn("No listing card found for modal", id);
    return;
  }

  card.classList.add("card", "original-card");
  card.dataset.itemId = id;
  card.dataset.cardId = id;
  card.dataset.listingId = id;

if (typeof window.openSheet === "function") {
  window.openSheet(card);

requestAnimationFrame(() => {
  document.body.classList.add("sheet-open");

  const overlay =
    document.querySelector("#sheet-overlay") ||
    document.querySelector(".sheet-overlay");

  if (overlay) {
    Object.assign(overlay.style, {
      zIndex: "99990",
      filter: "none",
      backdropFilter: "blur(10px)",
    });
  }

  const sheet =
    document.querySelector("#preview-sheet") ||
    document.querySelector(".preview-sheet") ||
    document.querySelector(".listing-sheet") ||
    document.querySelector(".intent-sheet");

  if (!sheet) return;

  // FIX: anchor the modal to the top of the screen on the explore page
  // instead of vertically centering it. `top` is now a fixed offset from
  // the viewport top instead of "50%", and the transform only needs to
  // handle horizontal centering (translateX(-50%)) since `left: 50%` sets
  // the panel's LEFT EDGE to the horizontal midpoint — the -50% X
  // translation is still required to actually center it, but there's no
  // longer a -50% Y component pulling it back down to vertical center.
  // maxHeight is adjusted so it still fits within the viewport with equal
  // breathing room top and bottom now that it starts near the top.
  Object.assign(sheet.style, {
    position: "fixed",
    top: "0",
    left: "50%",
    right: "auto",
    bottom: "auto",
    transform: "translateX(-50%)",
    width: "min(760px, calc(100vw - 44px))",
    maxWidth: "760px",
    maxHeight: "calc(100dvh - 24px)",
    overflow: "auto",
    zIndex: "100000",
    filter: "none",
    backdropFilter: "none",
  });
});

  return;
}

  card.dispatchEvent(new MouseEvent("click", {
    bubbles: true,
    cancelable: true,
    view: window
  }));
}

          function openHomeModal(item, card) {
        if (!item || item.layer !== "homes" || !card) return;

        const modalCard = card.cloneNode(true);

        modalCard.classList.add("card", "original-card");
        modalCard.dataset.cardId = item.id;
        modalCard.dataset.listingId = item.id;
        modalCard.dataset.itemId = item.id;

        modalCard.style.position = "fixed";
        modalCard.style.left = "-9999px";
        modalCard.style.top = "-9999px";

        document.body.appendChild(modalCard);

        modalCard.dispatchEvent(new MouseEvent("click", {
          bubbles: true,
          cancelable: true,
          view: window
        }));

        window.setTimeout(() => modalCard.remove(), 250);
      }

      async function focusItem(item, card) {
        clearActiveCards();
        card?.classList.add("is-active");
        setMarkerActive(item, true);
        item.marker?.openPopup();

                           if (item.layer === "homes") {
          activeHomeItem = item;
          await loadAmenities();
          renderDrawer();

          requestAnimationFrame(() => {
            const freshCard = document.querySelector(
              `.original-card[data-item-id="${CSS.escape(item.id)}"]`
            );

           openListingFromExplorerItem(item, freshCard);
          });
        }

        if (Number.isFinite(item.lat) && Number.isFinite(item.lng)) {
          map.flyTo([item.lat, item.lng], Math.max(map.getZoom(), 14), { duration: 0.45 });
        }

        drawerSections?.scrollTo({
          top: 0,
          behavior: "smooth"
        });

        if (item.layer !== "homes") {
          card?.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
        }
      }

      function buildHomeLayer() {
        const fragment = homeTemplate.content.cloneNode(true);
        const cards = Array.from(fragment.querySelectorAll(".explorer-card"));

        cards.forEach((card, index) => {
          const lat = Number(card.dataset.lat);
          const lng = Number(card.dataset.lng);
          if (!Number.isFinite(lat) || !Number.isFinite(lng)) return;

          const item = {
            id: card.dataset.id || `home-${index}`,
            layer: "homes",
            title: card.dataset.price || "Home",
            subtitle: card.dataset.address || "",
           meta: card.dataset.meta || "",
lat,
lng,
priceRaw: Number(card.dataset.rawPrice || 0),
bedsRaw: Number(card.dataset.beds || 0),
typeRaw: String(card.dataset.type || "").toLowerCase(),
areaRaw: String(card.dataset.area || "").toLowerCase(),
color: accent,
html: card.outerHTML,
image: card.dataset.image || "",
