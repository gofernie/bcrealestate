    // Single source of truth for closing the listing sheet. Calls
    // window.closeSheet() (now fixed to fully reset its own inline styles
    // and classes) and cleans up explorer-page-specific state.
    //
    // FIX: this used to ALSO call .remove() on #preview-sheet/#sheet-overlay
    // as a defensive fallback from before closeSheet() itself was fixed.
    // That was destructive: .remove() deletes those elements from the DOM
    // entirely, not just hides them. IntentModalController.astro's
    // initIntentReviewModal() captures `sheet`/`overlay` as closured
    // variables ONCE at page load — once the real nodes were removed from
    // the document, those variables still pointed at the (now detached,
    // invisible) old nodes, so every subsequent openSheet(card) call kept
    // manipulating an element no longer attached to the page. Nothing
    // errored, nothing appeared: the modal opened once and then silently
    // never came back. Removed the .remove() calls entirely — closeSheet()
    // no longer needs a nuke-it-from-orbit fallback now that it correctly
    // resets its own inline styles and classes.
    function closeAnyOpenSheet() {
      if (typeof window.closeSheet === "function") {
        window.closeSheet();
      }

      // FIX: closing the listing sheet didn't close the Leaflet marker
      // popup (the small "$X — address — View listing →" card that
      // appears when clicking a map pin). That popup is a separate widget
      // owned by the map, not by the sheet, so closeSheet() has no way to
      // know about it. map.closePopup() is Leaflet's built-in method for
      // closing whatever popup is currently open on that map instance.
      window.explorerMap?.closePopup();

      document.body.classList.remove("sheet-open", "modal-open");
    }

    function initExplorerV2() {
      const explorer = document.querySelector(".explorer");
      const mapEl = document.getElementById("explorer-map");
      const drawer = document.getElementById("explorer-drawer");
      const drawerSections = document.getElementById("drawer-sections");
