---
import { createClient } from "@supabase/supabase-js";
import Layout from "../layouts/Layout.astro";
import { getSite } from "../lib/getSite";
import IntentModalController from "../components/IntentModalController.astro";
export const prerender = false;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const city = Astro.url.searchParams.get("city") || "nanaimo";
const area = Astro.url.searchParams.get("area") || "";

const site = await getSite(Astro.url.hostname, city);
const accentColor = site?.accent_color || "#2f6f73";

let query = supabase
  .from("listing_rows")
  .select("*")
  .eq("status", "A")
  .eq("normalized_city", city)
.order("listed_at", { ascending: false })
.limit(1000);

if (area) {
  query = query.or(`normalized_area.eq.${area},normalized_area.eq.${area.replace(/-/g, " ")}`);
}

const { data: listings = [] } = await query;

function formatPrice(price) {
  return `$${Number(price || 0).toLocaleString()}`;
}

function formatAddress(value) {
  if (!value) return "";
  let obj = value;

  if (typeof value === "string") {
    const trimmed = value.trim();
    if (!trimmed.startsWith("{")) return trimmed;
    try {
      obj = JSON.parse(trimmed);
    } catch {
      return "";
    }
  }

  return [
    obj.streetNumber,
    obj.streetName || obj.streetAddress,
    obj.streetSuffix,
    obj.unitNumber ? `#${obj.unitNumber}` : "",
  ].filter(Boolean).join(" ");
}

function normalizeImageUrl(url) {
  const value = String(url || "").trim();
  if (!value) return "";
  if (value.startsWith("http")) return value;
  if (value.startsWith("/")) return `https://cdn.repliers.io${value}`;
  return `https://cdn.repliers.io/${value}`;
}
const areaLabel = area
  ? area.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase())
  : city.replace(/\b\w/g, (c) => c.toUpperCase());


const areaOptions = Array.from(
  new Set(
    listings
      .map((listing) => listing.normalized_area || listing.area)
      .filter(Boolean)
      .map((value) => String(value).trim())
  )
).sort((a, b) => a.localeCompare(b));
