  if (!card || !img) return;

  let images = [];

  try {
    images = JSON.parse(card.dataset.popupImages || "[]").filter(Boolean);
  } catch {}

if (!images.length) return;

images.forEach((src) => {
  const preload = new Image();
  preload.src = src;
});

  let index = Number(card.dataset.popupIndex || 0);
  index += nav.matches("[data-popup-next]") ? 1 : -1;

  if (index < 0) index = images.length - 1;
  if (index >= images.length) index = 0;

  card.dataset.popupIndex = String(index);
  img.src = images[index];
}, true);
document.addEventListener("click", (event) => {
  const closeButton = event.target.closest(
    "#sheet-close, [data-close-sheet], [aria-label='Close'], .sheet-close, .modal-close, button[aria-label='Close']"
  );

  if (!closeButton) return;

  event.preventDefault();
  event.stopImmediatePropagation();
  closeAnyOpenSheet();
}, true);

// Clicking the backdrop/overlay itself (outside the sheet content) also
// closes the modal.
document.addEventListener("click", (event) => {
  const overlay = event.target.closest("#sheet-overlay, .sheet-overlay");
  if (!overlay) return;
  // Only close if the click was on the overlay itself, not something
  // inside the sheet that happens to sit visually above it.
  if (event.target !== overlay) return;

  closeAnyOpenSheet();
});

document.addEventListener("keydown", (event) => {
  if (event.key !== "Escape") return;
  closeAnyOpenSheet();
});
function closeMenus() {
  document.querySelectorAll(".explorer-menu.is-open")
    .forEach((menu) => menu.classList.remove("is-open"));
}

function slugify(value = "") {
  return String(value)
    .trim()
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function updateGuideLink(label = "") {
  const guideLink = document.querySelector("[data-guide-link]");
  if (!guideLink) return;

  const areaSlug = slugify(label || document.getElementById("nav-location-label")?.textContent || "");
  guideLink.href = areaSlug ? `/${city}/${areaSlug}` : `/${city}`;
}

updateGuideLink();

document.querySelectorAll("[data-menu-trigger]").forEach((button) => {
  button.addEventListener("click", (event) => {
    event.preventDefault();
    event.stopPropagation();

    const key = button.dataset.menuTrigger;
    const menu = document.querySelector(`.explorer-menu[data-menu="${key}"]`);
    const wasOpen = menu?.classList.contains("is-open");

    closeMenus();

    if (menu && !wasOpen) menu.classList.add("is-open");
  });
});

document.addEventListener("click", (event) => {
  if (event.target.closest(".explorer-top")) return;
  closeMenus();
});
document.addEventListener("click", (event) => {
  if (!drawer) return;

  const isMobile =
    window.matchMedia("(max-width: 760px)").matches;

  /*
   * Desktop uses a permanent right panel.
   * Only mobile should collapse when clicking outside.
   */
  if (!isMobile) return;

  if (
    event.target.closest(".explorer-drawer") ||
    event.target.closest(".explorer-top") ||
    event.target.closest(".leaflet-popup")
  ) {
    return;
  }

  drawer.classList.remove(
    "is-expanded",
    "is-homes-mode",
    "is-places-mode",
    "is-insights-mode"
  );

  if (drawerState) {
    drawerState.textContent = "";
  }

refreshMapSize();
});

function focusFilteredHomesOnMap() {
  const homes = layerItems.homes
    .filter((home) => passesNavFilters(home))
    .filter((home) => Number.isFinite(home.lat) && Number.isFinite(home.lng));

  if (!homes.length) return;

  const isMobile = window.matchMedia("(max-width: 760px)").matches;
  const bounds = L.latLngBounds(homes.map((home) => [home.lat, home.lng]));

  if (isMobile) {
    map.fitBounds(bounds, {
      padding: [36, 120],
      maxZoom: 14,
    });
    return;
  }

  const center = bounds.getCenter();

  map.flyTo(center, 13, { duration: 0.45 });

  window.setTimeout(() => {
    map.panBy([-130, 0], { animate: true, duration: 0.25 });
  }, 480);
}

document.querySelectorAll("[data-filter-location]").forEach((button) => {
  button.addEventListener("click", async () => {
    navFilters.location = button.dataset.filterLocation || "";

    const label = navFilters.location ? button.textContent.trim() : "Nanaimo";

    document.getElementById("nav-location-label").textContent = label;
updateGuideLink(label);
drawAreaBoundary(label);

const sidebarTitle = document.querySelector(".explorer-sidebar h1");
if (sidebarTitle) sidebarTitle.textContent = label;

activeHomeItem = null;

    Object.keys(amenityCache).forEach((key) => delete amenityCache[key]);

    Object.keys(layerItems).forEach((key) => {
      if (key !== "homes") {
        layerGroups[key]?.clearLayers();
        layerItems[key] = [];
      }
    });

closeMenus();

/*
 * Preserve the user's current Explorer mode.
 * Example: Restaurants in all Nanaimo becomes
 * Restaurants in Uplands, rather than returning to Homes.
 */
const activePlaceLayer = Object.keys(activeLayers).find(
  (key) => key !== "homes" && activeLayers[key]
);

const placesTabIsActive = Boolean(
  document.querySelector(
    '.drawer-tab[data-drawer-tab="places"].is-active'
  )
);

const insightsTabIsActive = Boolean(
  document.querySelector(
    '.drawer-tab[data-drawer-tab="insights"].is-active'
  )
);

await loadAmenities();
refreshExplorer();

if (placesTabIsActive && activePlaceLayer) {
  document
    .querySelectorAll("[data-mobile-layer]")
    .forEach((layerButton) => {
      const buttonLayer = layerButton.dataset.mobileLayer;

      layerButton.classList.toggle(
        "is-active",
        buttonLayer === activePlaceLayer
      );

      layerButton.setAttribute(
        "aria-pressed",
        buttonLayer === activePlaceLayer ? "true" : "false"
      );
    });

  syncMapLayers();

  if (boundaryLayer) {
    map.fitBounds(boundaryLayer.getBounds(), {
      padding: [32, 32],
      maxZoom: 14,
      animate: false,
    });
  }
} else if (insightsTabIsActive) {
  if (boundaryLayer) {
    map.fitBounds(boundaryLayer.getBounds(), {
      padding: [32, 32],
      maxZoom: 14,
      animate: false,
    });
  }
} else {
  focusFilteredHomesOnMap();
}
  });
});

function switchToHomesTab() {
  const homesTabButton = document.querySelector('.drawer-tab[data-drawer-tab="homes"]');
  if (homesTabButton && !homesTabButton.classList.contains("is-active")) {
    homesTabButton.click();
  }
}

document.querySelectorAll("[data-filter-price]").forEach((button) => {
 button.addEventListener("click", async () => {
    const value = button.dataset.filterPrice || "";
    const [min, max] = value.split("-").map(Number);

    navFilters.priceMin = Number.isFinite(min) ? min : 0;
    navFilters.priceMax = Number.isFinite(max) ? max : Infinity;

    document.getElementById("nav-price-label").textContent = button.textContent.trim();
    closeMenus();
    switchToHomesTab();
    refreshExplorer();
  });
});

document.querySelectorAll("[data-filter-beds]").forEach((button) => {
  button.addEventListener("click", () => {
    navFilters.beds = Number(button.dataset.filterBeds || 0);
    document.getElementById("nav-beds-label").textContent = button.textContent.trim();
    closeMenus();
    switchToHomesTab();
    refreshExplorer();
  });
});

document.querySelectorAll("[data-filter-type]").forEach((button) => {
  button.addEventListener("click", () => {
    navFilters.type = button.dataset.filterType || "";
    document.getElementById("nav-type-label").textContent =
      button.textContent.trim();

    activeHomeItem = null;
    map.closePopup();

    closeMenus();
    switchToHomesTab();
    refreshExplorer();
  });
});

document
  .getElementById("drawer-order")
  ?.addEventListener("change", (event) => {
    navFilters.order = event.target.value || "recommended";
    refreshExplorer();
  });

document.querySelector("[data-filter-reset]")?.addEventListener("click", () => {
  navFilters.location = "";
  navFilters.priceMin = 0;
  navFilters.priceMax = Infinity;
  navFilters.beds = 0;
  navFilters.type = "";

  document.getElementById("nav-location-label").textContent = "Nanaimo";
  document.getElementById("nav-price-label").textContent = "Any price";
  document.getElementById("nav-beds-label").textContent = "Beds";
  document.getElementById("nav-type-label").textContent = "Type";

  closeMenus();
  refreshExplorer();
});
   document.querySelectorAll("#drawer-toggle, #drawer-head-toggle").forEach((trigger) => {
  trigger.addEventListener("click", () => {
    if (!drawer) return;

    const isOpen =
      drawer.classList.contains("is-expanded") ||
      drawer.classList.contains("is-homes-mode") ||
      drawer.classList.contains("is-places-mode") ||
      drawer.classList.contains("is-insights-mode");

    if (isOpen) {
      drawer.classList.remove(
        "is-expanded",
        "is-homes-mode",
        "is-places-mode",
        "is-insights-mode"
      );
    } else {
      const activeTab =
        document.querySelector(".drawer-tab.is-active")?.dataset.drawerTab ||
        "homes";

      drawer.classList.add(
        "is-expanded",
        `is-${activeTab}-mode`
      );
    }

    if (drawerState) {
      drawerState.textContent = "";
    }

  refreshMapSize();
  });
});
document.querySelectorAll(".drawer-tab").forEach((button) => {
  button.addEventListener("click", async () => {
    const wasActive = button.classList.contains("is-active");
const currentMode = `is-${button.dataset.drawerTab}-mode`;

if (wasActive && drawer?.classList.contains(currentMode)) {
  drawer.classList.remove(
    "is-expanded",
    "is-homes-mode",
    "is-places-mode",
    "is-insights-mode"
  );
  return;
}
    document.querySelectorAll(".drawer-tab").forEach((tab) => {
      tab.classList.remove("is-active");
    });

    button.classList.add("is-active");
button.dataset.userSelected = "true";
button.classList.remove("should-shimmer");
if (!button.dataset.shimmerDone && !button.dataset.userSelected) {
      button.classList.add("should-shimmer");
      button.dataset.shimmerDone = "true";

      window.setTimeout(() => {
        button.classList.remove("should-shimmer");
      }, 14000);
    }

drawer?.classList.add("is-expanded");

    if (drawerState) drawerState.textContent = "";

   refreshMapSize();

 drawerSections.hidden = true;
drawerPlaces.hidden = true;
drawerInsights.hidden = true;

if (drawerHomesHeader) drawerHomesHeader.hidden = true;
if (drawerPlacesHeader) drawerPlacesHeader.hidden = true;
if (drawerInsightsHeader) drawerInsightsHeader.hidden = true;

 const shouldCollapse =
  wasActive &&
  (
    drawer?.classList.contains("is-insights-mode") ||
    drawer?.classList.contains("is-homes-mode") ||
    drawer?.classList.contains("is-places-mode")
  );

drawer?.classList.remove("is-insights-mode", "is-homes-mode", "is-places-mode");

switch (button.dataset.drawerTab) {
case "homes":
  drawerSections.hidden = false;

  if (drawerHomesHeader) {
    drawerHomesHeader.hidden = false;
  }

  /*
   * Homes mode is listings-only.
   * Turn off every OSM amenity layer.
   */
  Object.keys(activeLayers).forEach((key) => {
    activeLayers[key] = key === "homes";
  });

  document
    .querySelectorAll("[data-mobile-layer]")
    .forEach((layerButton) => {
      layerButton.classList.remove("is-active");
      layerButton.setAttribute("aria-pressed", "false");
    });

  activeHomeItem?.marker?.closePopup?.();
  activeHomeItem = null;

  map.closePopup();
  clearActiveCards();

  syncMapLayers();
  updateToggleUi();

  if (!shouldCollapse) {
    drawer?.classList.add("is-homes-mode");
  }

  break;

case "places":
  drawerPlaces.hidden = false;

  if (drawerPlacesHeader) {
    drawerPlacesHeader.hidden = false;
  }

  drawer?.classList.remove(
    "is-homes-mode",
    "is-insights-mode"
  );

  if (!shouldCollapse) {
    drawer?.classList.add(
      "is-expanded",
      "is-places-mode"
    );
  }

  // Clear the listing state left behind by the home modal/map popup.
  activeHomeItem?.marker?.closePopup?.();
  activeHomeItem = null;

  map.closePopup();
  clearActiveCards();

  if (
    !Object.keys(activeLayers).some(
      (key) => key !== "homes" && activeLayers[key]
    )
  ) {
    await loadAmenities();
    activeLayers.parks = true;
  }

  // Rebuild Places only after the drawer has the correct mode class.
  refreshExplorer();

  drawerPlaces.scrollTo({
    top: 0,
    behavior: "instant",
  });

  break;

case "insights":
  drawerInsights.hidden = false;

  if (drawerInsightsHeader) {
    drawerInsightsHeader.hidden = false;
  }

  if (!shouldCollapse) {
    drawer?.classList.add("is-insights-mode");
  }

  break;
}

refreshMapSize();
  });
});
document.addEventListener("click", (event) => {
  const button = event.target.closest("#homes-visibility-toggle");

  if (!button) return;

  activeLayers.homes = !activeLayers.homes;

  button.classList.toggle(
    "is-active",
    !activeLayers.homes
  );

  button.setAttribute(
    "aria-pressed",
    activeLayers.homes ? "true" : "false"
  );

  button.innerHTML = activeLayers.homes
    ? "👁 Hide homes"
    : "🏠 Show homes";

  syncMapLayers();
});
document.addEventListener("click", async (event) => {
  const button = event.target.closest("[data-mobile-layer]");

  if (!button) return;

  const layerKey = button.dataset.mobileLayer;

  if (
    !layerKey ||
    !(layerKey in activeLayers)
  ) {
    return;
  }

Object.keys(activeLayers).forEach((key) => {
  if (key !== "homes") {
    activeLayers[key] = false;
  }
});

activeLayers[layerKey] = true;

/*
 * Select the requested category before loading amenities,
 * so loadAmenities() fetches the correct place type.
 */
await loadAmenities();

/* Keep every copy of the selected amenity button in sync */
document
  .querySelectorAll("[data-mobile-layer]")
  .forEach((layerButton) => {
    const buttonLayer = layerButton.dataset.mobileLayer;

    layerButton.classList.toggle(
      "is-active",
      buttonLayer === layerKey
    );

    layerButton.setAttribute(
      "aria-pressed",
      buttonLayer === layerKey ? "true" : "false"
    );
  });

document
  .querySelectorAll(".drawer-tab")
  .forEach((tab) => {
      tab.classList.toggle(
        "is-active",
        tab.dataset.drawerTab === "places"
      );
    });

  drawerSections.hidden = true;
  drawerPlaces.hidden = false;
  drawerInsights.hidden = true;

  if (drawerHomesHeader) {
    drawerHomesHeader.hidden = true;
  }

  if (drawerPlacesHeader) {
    drawerPlacesHeader.hidden = false;
  }

  if (drawerInsightsHeader) {
    drawerInsightsHeader.hidden = true;
  }

  drawer?.classList.remove(
    "is-homes-mode",
    "is-insights-mode"
  );

  drawer?.classList.add(
    "is-expanded",
    "is-places-mode"
  );

refreshExplorer();

/* Ensure the selected category is rendered after loading */
renderDrawer();

 requestAnimationFrame(() => {
  drawerPlaces?.scrollTo({
    top: 0,
    behavior: "instant",
  });
});

refreshMapSize();
});
    }
  </script>
  <IntentModalController listings={listings} />
</Layout>
