  itemType === "lot" ||
  item.propertyRaw.includes("land") ||
  item.propertyRaw.includes("lot") ||
  (!item.bedsRaw && !item.bathsRaw && !item.sqftRaw);

if (selectedType && itemType !== selectedType) return false;

if (selectedType && selectedType !== "land" && looksLikeLand) return false;

  return true;
}

