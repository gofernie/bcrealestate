}, true);

// Close button now always closes, regardless of window.closeSheet's
// existence/timing, via the shared closeAnyOpenSheet() helper defined above.
document.addEventListener("click", (event) => {
  const closeButton = event.target.closest(
    "#sheet-close, [data-close-sheet], [aria-label='Close'], .sheet-close, .modal-close"
  );

  if (!closeButton) return;

  event.preventDefault();
  event.stopPropagation();
  closeAnyOpenSheet();
});

// Clicking the backdrop/overlay itself (outside the sheet content) also
// closes the modal.
document.addEventListener("click", (event) => {
  const overlay = event.target.closest("#sheet-overlay, .sheet-overlay");
  if (!overlay) return;
  // Only close if the click was on the overlay itself, not something
  // inside the sheet that happens to sit visually above it.
  if (event.target !== overlay) return;

  closeAnyOpenSheet();
});

document.addEventListener("keydown", (event) => {
  if (event.key !== "Escape") return;
  closeAnyOpenSheet();
});
function closeMenus() {
  document.querySelectorAll(".explorer-menu.is-open")
    .forEach((menu) => menu.classList.remove("is-open"));
}

document.querySelectorAll("[data-menu-trigger]").forEach((button) => {
  button.addEventListener("click", (event) => {
    event.preventDefault();
    event.stopPropagation();

    const key = button.dataset.menuTrigger;
    const menu = document.querySelector(`.explorer-menu[data-menu="${key}"]`);
    const wasOpen = menu?.classList.contains("is-open");

    closeMenus();

    if (menu && !wasOpen) menu.classList.add("is-open");
  });
});

document.addEventListener("click", (event) => {
  if (event.target.closest(".explorer-top")) return;
  closeMenus();
});

document.querySelectorAll("[data-filter-location]").forEach((button) => {
  button.addEventListener("click", async () => {
    navFilters.location = button.dataset.filterLocation || "";
    const label = navFilters.location ? button.textContent.trim() : "Nanaimo";

    document.getElementById("nav-location-label").textContent = label;

    const sidebarTitle = document.querySelector(".explorer-sidebar h1");
    if (sidebarTitle) sidebarTitle.textContent = label;

    Object.keys(amenityCache).forEach((key) => delete amenityCache[key]);

    Object.keys(layerItems).forEach((key) => {
      if (key !== "homes") {
        layerGroups[key]?.clearLayers();
        layerItems[key] = [];
      }
    });

    closeMenus();
    await loadAmenities();
    refreshExplorer();
  });
});

document.querySelectorAll("[data-filter-price]").forEach((button) => {
  button.addEventListener("click", () => {
    const value = button.dataset.filterPrice || "";
    const [min, max] = value.split("-").map(Number);

    navFilters.priceMin = Number.isFinite(min) ? min : 0;
    navFilters.priceMax = Number.isFinite(max) ? max : Infinity;

    document.getElementById("nav-price-label").textContent = button.textContent.trim();
    closeMenus();
    refreshExplorer();
  });
});

document.querySelectorAll("[data-filter-beds]").forEach((button) => {
  button.addEventListener("click", () => {
    navFilters.beds = Number(button.dataset.filterBeds || 0);
    document.getElementById("nav-beds-label").textContent = button.textContent.trim();
    closeMenus();
    refreshExplorer();
  });
});

document.querySelectorAll("[data-filter-type]").forEach((button) => {
  button.addEventListener("click", () => {
    navFilters.type = button.dataset.filterType || "";
    document.getElementById("nav-type-label").textContent = button.textContent.trim();
    closeMenus();
    refreshExplorer();
  });
});

document.querySelector("[data-filter-reset]")?.addEventListener("click", () => {
  navFilters.location = "";
  navFilters.priceMin = 0;
  navFilters.priceMax = Infinity;
  navFilters.beds = 0;
  navFilters.type = "";

  document.getElementById("nav-location-label").textContent = "Nanaimo";
  document.getElementById("nav-price-label").textContent = "Any price";
  document.getElementById("nav-beds-label").textContent = "Beds";
  document.getElementById("nav-type-label").textContent = "Type";

  closeMenus();
  refreshExplorer();
});
