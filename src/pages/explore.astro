// Close button now always closes, regardless of window.closeSheet's
// existence/timing, via the shared closeAnyOpenSheet() helper defined above.
document.addEventListener("click", (event) => {
  const nav = event.target.closest("[data-popup-prev], [data-popup-next]");
  if (!nav) return;

  event.preventDefault();
  event.stopPropagation();

  const card = nav.closest(".map-preview-card");
  const img = card?.querySelector("img");
  if (!card || !img) return;

  let images = [];

  try {
    images = JSON.parse(card.dataset.popupImages || "[]").filter(Boolean);
  } catch {}

if (!images.length) return;

images.forEach((src) => {
  const preload = new Image();
  preload.src = src;
});

  let index = Number(card.dataset.popupIndex || 0);
  index += nav.matches("[data-popup-next]") ? 1 : -1;

  if (index < 0) index = images.length - 1;
  if (index >= images.length) index = 0;

  card.dataset.popupIndex = String(index);
  img.src = images[index];
}, true);
document.addEventListener("click", (event) => {
  const closeButton = event.target.closest(
    "#sheet-close, [data-close-sheet], [aria-label='Close'], .sheet-close, .modal-close, button[aria-label='Close']"
  );

  if (!closeButton) return;

  event.preventDefault();
  event.stopImmediatePropagation();
  closeAnyOpenSheet();
}, true);

// Clicking the backdrop/overlay itself (outside the sheet content) also
// closes the modal.
document.addEventListener("click", (event) => {
  const overlay = event.target.closest("#sheet-overlay, .sheet-overlay");
  if (!overlay) return;
  // Only close if the click was on the overlay itself, not something
  // inside the sheet that happens to sit visually above it.
  if (event.target !== overlay) return;

  closeAnyOpenSheet();
});

document.addEventListener("keydown", (event) => {
  if (event.key !== "Escape") return;
  closeAnyOpenSheet();
});
function closeMenus() {
  document.querySelectorAll(".explorer-menu.is-open")
    .forEach((menu) => menu.classList.remove("is-open"));
}

function slugify(value = "") {
  return String(value)
    .trim()
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function updateGuideLink(label = "") {
  const guideLink = document.querySelector("[data-guide-link]");
  if (!guideLink) return;

  const areaSlug = slugify(label || document.getElementById("nav-location-label")?.textContent || "");
  guideLink.href = areaSlug ? `/${city}/${areaSlug}` : `/${city}`;
}

updateGuideLink();

document.querySelectorAll("[data-menu-trigger]").forEach((button) => {
  button.addEventListener("click", (event) => {
    event.preventDefault();
    event.stopPropagation();

    const key = button.dataset.menuTrigger;
    const menu = document.querySelector(`.explorer-menu[data-menu="${key}"]`);
    const wasOpen = menu?.classList.contains("is-open");

    closeMenus();

    if (menu && !wasOpen) menu.classList.add("is-open");
  });
});

document.addEventListener("click", (event) => {
  if (event.target.closest(".explorer-top")) return;
  closeMenus();
});
document.addEventListener("click", (event) => {
  if (!drawer) return;

  if (
    event.target.closest(".explorer-drawer") ||
    event.target.closest(".explorer-top") ||
    event.target.closest(".leaflet-popup")
  ) {
    return;
  }

  drawer.classList.remove(
    "is-expanded",
    "is-homes-mode",
    "is-places-mode",
    "is-insights-mode"
  );

  if (drawerState) drawerState.textContent = "";

