@media (min-width: 761px) {
  .explorer {
    --explorer-edge: 12px;
    --explorer-gap: 10px;
    --explorer-panel-width: 490px;

    padding: var(--explorer-edge);
    box-sizing: border-box;
    background: #f1eee8;
  }

  /* Left map card */
  .explorer-main {
    position: absolute !important;
    top: var(--explorer-edge) !important;
    left: var(--explorer-edge) !important;
    right: calc(
      var(--explorer-edge) +
      var(--explorer-panel-width) +
      var(--explorer-gap)
    ) !important;
    bottom: var(--explorer-edge) !important;

    width: auto !important;
    height: auto !important;

    overflow: hidden !important;
    border: 1px solid rgba(15, 23, 42, 0.07);
    border-radius: 14px;
    background: #e8e5df;
    box-shadow: 0 8px 28px rgba(15, 23, 42, 0.08);
