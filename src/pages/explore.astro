---
import { createClient } from "@supabase/supabase-js";
import Layout from "../layouts/Layout.astro";
import { getSite } from "../lib/getSite";
import IntentModalController from "../components/IntentModalController.astro";
import AreaInsights from "../components/AreaInsights.astro";
export const prerender = false;

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const city = Astro.url.searchParams.get("city") || "nanaimo";
const area = Astro.url.searchParams.get("area") || "";

const site = await getSite(Astro.url.hostname, city);
const accentColor = site?.accent_color || "#2f6f73";
const { data: boundaryRow } = area
  ? await supabase
      .from("area_boundaries")
      .select("polygon_geojson")
      .eq("city", city)
      .eq("area_slug", area)
      .maybeSingle()
  : { data: null };
const { data: boundaryRows = [] } = await supabase
  .from("area_boundaries")
  .select("area_slug, area_name, polygon_geojson, ai_insights")
  .eq("city", city);

const { data: areaInsightRowsRaw = [] } = await supabase
  .from("neighbourhood_census_data")
  .select("*")
  .eq("city", String(city).toLowerCase());

const areaInsightRows = Array.isArray(areaInsightRowsRaw)
  ? areaInsightRowsRaw
  : [];
let query = supabase
  .from("listing_rows")
  .select("*")
  .eq("status", "A")
  .eq("normalized_city", city)
.order("listed_at", { ascending: false })
.limit(1000);



const { data: listings = [] } = await query;

function formatPrice(price) {
  return `$${Number(price || 0).toLocaleString()}`;
}

function formatAddress(value) {
  if (!value) return "";
  let obj = value;

  if (typeof value === "string") {
    const trimmed = value.trim();
    if (!trimmed.startsWith("{")) return trimmed;
    try {
      obj = JSON.parse(trimmed);
    } catch {
      return "";
    }
  }

  return [
    obj.streetNumber,
    obj.streetName || obj.streetAddress,
    obj.streetSuffix,
    obj.unitNumber ? `#${obj.unitNumber}` : "",
  ].filter(Boolean).join(" ");
}

function normalizeImageUrl(url) {
  const value = String(url || "").trim();
  if (!value) return "";
  if (value.startsWith("http")) return value;
  if (value.startsWith("/")) return `https://cdn.repliers.io${value}`;
  return `https://cdn.repliers.io/${value}`;
}
const areaLabel = area
  ? area.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase())
  : city.replace(/\b\w/g, (c) => c.toUpperCase());

const visibleListingsForInsights = area
  ? listings.filter((listing) =>
      String(listing.normalized_area || listing.area || "")
        .toLowerCase()
        .trim() === areaLabel.toLowerCase().trim()
    )
  : listings;

const pricesForInsights = visibleListingsForInsights
  .map((listing) => Number(listing.price || 0))
  .filter((price) => price > 0)
  .sort((a, b) => a - b);

const medianPriceForInsights = pricesForInsights.length
  ? pricesForInsights[Math.floor(pricesForInsights.length / 2)]
  : 0;

const areaProfileForInsights = (areaInsightRows || []).find((row) => {
  const rowSlug = String(row.area_slug || "").toLowerCase().trim();
  const rowName = String(row.area_name || "").toLowerCase().trim();
  const currentSlug = String(area || "").toLowerCase().trim();
  const currentName = String(areaLabel || "").toLowerCase().trim();

  return rowSlug === currentSlug || rowName === currentName;
});


const { data: allAreaRows = [] } = await supabase
  .from("listing_rows")
  .select("normalized_area")
  .eq("status", "A")
  .eq("normalized_city", city)
  .not("normalized_area", "is", null);

const areaOptions = Array.from(
  new Set(
    allAreaRows
      .map((listing) => listing.normalized_area)
      .filter(Boolean)
      .map((value) => String(value).trim())
  )
).sort((a, b) => a.localeCompare(b));
