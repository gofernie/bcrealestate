    /* FIX: .drawer-row is built at runtime via a JS template literal in
       renderDrawer() (`<div class="drawer-row">...`), not cloned from any
       static Astro markup — so it never receives Astro's build-time scope
       attribute, and a normal scoped selector can never match it. Wrapped
       in :global() so these rules actually apply, matching the pattern
       already used below for other JS-injected elements
       (.map-preview-card, #preview-sheet, etc). */
 :global(.drawer-row) {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: 210px;
  gap: 10px;
  overflow-x: auto;
  padding-bottom: 4px;
  scrollbar-width: thin;
}

    :global(.explorer-drawer.is-expanded .drawer-row) {
      grid-auto-flow: row;
      /* repeat(auto-fill, minmax(...)) requires the browser to resolve a
         definite container width before it can decide how many columns
         fit. Nested here inside an absolutely-positioned drawer with its
         own grid ancestors, that resolution was collapsing to a single
         column instead of several, no matter how small the minmax floor
         was set. Switching to an explicit fixed column count sidesteps
         that ambiguity entirely — the browser no longer has to infer
         anything, it just divides the known container width by 4 (or
         fewer, per breakpoint below). */
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      overflow: visible;
    }

    @media (max-width: 1300px) {
      :global(.explorer-drawer.is-expanded .drawer-row) {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 980px) {
      :global(.explorer-drawer.is-expanded .drawer-row) {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    /* FIX: the base .explorer-card layout (88px thumbnail + 1fr text,
       side by side) is designed for the collapsed drawer's horizontal
       scroll strip, where each card is a short, wide row. Reusing that
       same layout in the expanded grid made every "column" render as a
       full-width list row instead of a compact card, since the text
       column still wants most of the card's width. This override, scoped
       to only the expanded grid, restacks each card: thumbnail full-width
       on top, details below — the shape people expect from a multi-column
       listing grid. */
    .explorer-drawer.is-expanded .explorer-card {
      display: flex;
      flex-direction: column;
      min-width: 0;
    }

    .explorer-drawer.is-expanded .explorer-card img {
