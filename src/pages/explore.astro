}

.drawer-tabs{
    display:flex;
    justify-content:center;
    gap:8px;
    margin:8px 0 10px;
    padding:0 8px;
}

.drawer-tab{
    flex:0 0 160px;
    max-width:160px;
    height:32px;

    border:0;
    border-radius:999px;

    background:#eef2f4;
    color:#4b5563;

    font:inherit;
    font-size:.8rem;
    font-weight:850;

    cursor:pointer;
    transition:.18s ease;
}

.drawer-tab:hover{
    background:#e5eaee;
}

.drawer-tab.is-active{
    background:#123a5a;
    color:#fff;
}

.drawer-tab.is-active{
  position:relative;
  overflow:hidden;
}

.drawer-tab.should-shimmer::after{
  content:"";
  position:absolute;
  inset:0;
  transform:translateX(-120%);
  background:linear-gradient(
    90deg,
    transparent,
    rgba(255,255,255,.28),
    transparent
  );
  animation:drawerTabShimmer 2.8s ease-in-out 5;
}

@keyframes drawerTabShimmer{
  0%, 45%{
    transform:translateX(-120%);
  }

  70%, 100%{
    transform:translateX(120%);
  }
}

