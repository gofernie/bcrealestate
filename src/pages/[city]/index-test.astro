---
import Site from "../../layouts/Site.astro";

export function getStaticPaths() {
  return [
    { params: { city: "nanaimo" } },
    { params: { city: "parksville" } },
    { params: { city: "whistler" } },
    { params: { city: "fernie" } },
  ];
}

const { city } = Astro.params;

const cityName = String(city || "")
  .replace(/-/g, " ")
  .replace(/\b\w/g, (c) => c.toUpperCase());
---

<Site title={`${cityName} Real Estate`}>
  <main style="padding: 80px 24px; max-width: 1100px; margin: 0 auto;">
    <p style="font-size: 13px; letter-spacing: .12em; text-transform: uppercase;">
      BC Real Estate
    </p>

    <h1 style="font-size: clamp(42px, 7vw, 82px); line-height: .95; margin: 0;">
      {cityName} Real Estate
    </h1>

    <p style="font-size: 20px; max-width: 680px; margin-top: 24px;">
      This is the new city-powered Locus-style page for {cityName}.
    </p>
  </main>
</Site>