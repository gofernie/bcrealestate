              <path d="m20 20-3.5-3.5"></path>
            </svg>

            <input
              id="parks-search-input"
              type="search"
              placeholder="Search by park name or address"
              autocomplete="off"
            />

            <button
              id="parks-search-clear"
              type="button"
              aria-label="Clear park search"
              hidden
            >
              ×
            </button>
          </span>
        </label>

        <span
          class="parks-filter-label parks-filter-label--pills"
        >
          Show me
        </span>

        <div
          class="parks-filter-buttons"
          role="group"
          aria-label="Filter parks"
        >
          {
            filters.map((filter, index) => (
              <button
                type="button"
                class:list={[
                  "parks-filter-button",
                  {
                    "is-active": index === 0,
