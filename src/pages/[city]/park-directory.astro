  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  />

  <script
    is:inline
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  ></script>
  <SiteNav
    city="nanaimo"
    site={site}
    showAreaNav={false}
    intentPages={navIntentPages}
  />
