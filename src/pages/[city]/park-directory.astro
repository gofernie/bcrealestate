              making a purchase.
            </p>
          </div>
        </section>
      </main>
    </div>
<script is:inline>
 function initializeOverviewMap() {
  if (!window.L) return;

  const element = document.getElementById(
    "parks-overview-map"
  );

  if (
    !element ||
    element.dataset.mapInitialized === "true"
  ) {
    return;
  }

  let parks = [];

  try {
    parks = JSON.parse(
      element.dataset.parks || "[]"
    );
  } catch (error) {
    console.error(
      "Could not read park map locations.",
      error
    );
    return;
  }

  const validParks = parks.filter(
    (park) =>
      Number.isFinite(Number(park.lat)) &&
      Number.isFinite(Number(park.lng))
  );

  if (!validParks.length) {
    element.classList.add(
      "parks-overview-map--missing"
    );
    return;
  }

  const placeholder = element.querySelector(
    ".parks-overview-placeholder"
  );

  if (placeholder) {
    placeholder.remove();
  }

  const map = window.L.map(element, {
  zoomControl: true,
  scrollWheelZoom: false,
}).setView([49.17, -123.94], 11);

  window.L.tileLayer(
"https://tile.openstreetmap.org/{z}/{x}/{y}.png",
    {
      maxZoom: 19,
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    }
  ).addTo(map);

  const markerRecords = validParks.map((park) => {
    const lat = Number(park.lat);
    const lng = Number(park.lng);

    const defaultStyle = {
      radius: 8,
      weight: 3,
      color: "#ffffff",
      fillColor: "#58736a",
      fillOpacity: 1,
    };

    const activeStyle = {
      radius: 12,
      weight: 4,
      color: "#ffffff",
      fillColor: "#1f4f52",
      fillOpacity: 1,
    };

    const marker = window.L.circleMarker(
      [lat, lng],
      defaultStyle
    );

    marker.bindTooltip(
      `
        <div class="parks-map-tooltip">
          <strong>${park.name}</strong>
          <span>${park.address}</span>
          <small>${park.age}</small>
          <em>View park details →</em>
        </div>
      `,
      {
        direction: "top",
        offset: [0, -7],
        opacity: 1,
      }
    );

    const highlightCard = () => {
      const card = document.getElementById(
        `park-${park.slug}`
      );

      if (!card || card.hidden) return;

      card.classList.add(
        "park-card--map-highlight"
      );
    };

    const unhighlightCard = () => {
      const card = document.getElementById(
        `park-${park.slug}`
      );

      card?.classList.remove(
        "park-card--map-highlight"
      );
    };

    marker.on("mouseover", () => {
      marker.setStyle(activeStyle);
      marker.bringToFront();
      highlightCard();
    });

    marker.on("mouseout", () => {
      marker.setStyle(defaultStyle);
      unhighlightCard();
    });

    marker.on("click", () => {
      window.location.href =
        `/parks/${park.slug}`;
    });

    marker.addTo(map);

    return {
      park,
      marker,
      lat,
      lng,
      defaultStyle,
      activeStyle,
    };
  });

  const findMarkerRecord = (slug) =>
    markerRecords.find(
      (record) => record.park.slug === slug
    );

  window.addEventListener(
    "parks:card-hover",
    (event) => {
      const slug = event.detail?.slug;
      const active = event.detail?.active;

      const record = findMarkerRecord(slug);

      if (!record || !map.hasLayer(record.marker)) {
        return;
      }

      if (active) {
        record.marker.setStyle(
          record.activeStyle
        );

        record.marker.bringToFront();
        record.marker.openTooltip();
      } else {
        record.marker.setStyle(
          record.defaultStyle
        );

        record.marker.closeTooltip();
      }
    }
  );

  const updateMapMarkers = ({
    filter = "all",
    search = "",
  } = {}) => {
    const normalizedSearch =
      String(search).trim().toLowerCase();

    const visibleBounds = [];

    markerRecords.forEach((record) => {
      const {
        park,
        marker,
        lat,
        lng,
      } = record;

      const matchesFilter =
        filter === "all" ||
        park.category === filter ||
        (
          filter === "pets" &&
          park.petType !== "none"
        );

      const searchText = [
        park.name,
        park.address,
        park.age,
      ]
        .join(" ")
        .toLowerCase();

      const matchesSearch =
        !normalizedSearch ||
        searchText.includes(normalizedSearch);

      const matches =
        matchesFilter && matchesSearch;

      if (matches) {
        if (!map.hasLayer(marker)) {
          marker.addTo(map);
        }

        visibleBounds.push([lat, lng]);
      } else if (map.hasLayer(marker)) {
        map.removeLayer(marker);
      }
    });

    if (visibleBounds.length === 1) {
      map.flyTo(visibleBounds[0], 15, {
        duration: 0.55,
      });
    } else if (visibleBounds.length > 1) {
      map.flyToBounds(visibleBounds, {
        padding: [35, 35],
        maxZoom: 13,
        duration: 0.55,
      });
    }

    const mapCount = document.querySelector(
      ".parks-map-count"
    );

    if (mapCount) {
      mapCount.textContent =
        `${visibleBounds.length} ${
          visibleBounds.length === 1
            ? "location"
            : "locations"
        }`;
    }

    window.setTimeout(() => {
      map.invalidateSize();
    }, 50);
  };

  window.addEventListener(
    "parks:results-change",
    (event) => {
      updateMapMarkers({
        filter:
          event.detail?.filter || "all",
        search:
          event.detail?.search || "",
      });
    }
  );

  updateMapMarkers();

  element.dataset.mapInitialized = "true";

  window.setTimeout(() => {
    map.invalidateSize();
  }, 100);
}
  function initializeParkMaps() {
  if (!window.L) return;

  const mapElements = Array.from(
    document.querySelectorAll(".park-map")
  );

  const createParkMap = (element) => {
    if (
      element.dataset.mapInitialized === "true"
    ) {
      return;
    }

    const lat = Number(element.dataset.lat);
    const lng = Number(element.dataset.lng);
    const name =
      element.dataset.name ||
      "Mobile home park";

    if (
      !Number.isFinite(lat) ||
      !Number.isFinite(lng) ||
      lat === 0 ||
      lng === 0
    ) {
      element.classList.add(
        "park-map--missing"
      );
      return;
    }

    const placeholder =
      element.querySelector(
        ".park-map-placeholder"
      );

    const map = window.L.map(element, {
      zoomControl: false,
      attributionControl: false,
      dragging: false,
      scrollWheelZoom: false,
      doubleClickZoom: false,
      boxZoom: false,
      keyboard: false,
      touchZoom: false,
    }).setView([lat, lng], 15);

    window.L.tileLayer(
"https://tile.openstreetmap.org/{z}/{x}/{y}.png",
      {
        maxZoom: 19,
      }
    ).addTo(map);

    window.L.circleMarker(
      [lat, lng],
      {
        radius: 9,
        weight: 3,
        color: "#ffffff",
        fillColor: "#58736a",
        fillOpacity: 1,
      }
    )
      .addTo(map)
      .bindTooltip(name, {
        direction: "top",
        offset: [0, -7],
      });

    element.dataset.mapInitialized = "true";

    window.setTimeout(() => {
      map.invalidateSize();

      if (placeholder) {
        placeholder.remove();
      }
    }, 150);
  };

  if (!("IntersectionObserver" in window)) {
    mapElements.forEach(createParkMap);
    return;
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        createParkMap(entry.target);
        observer.unobserve(entry.target);
      });
    },
    {
      rootMargin: "300px 0px",
      threshold: 0.01,
    }
  );

  mapElements.forEach((element) => {
    if (
      element.dataset.mapInitialized !== "true"
    ) {
      observer.observe(element);
    }
  });
}

  function initializeParkFilters() {
  const buttons = Array.from(
    document.querySelectorAll(
      ".parks-filter-button"
    )
  );

  const cards = Array.from(
    document.querySelectorAll(".park-card")
  );

  const searchInput =
    document.getElementById(
      "parks-search-input"
    );

  const clearButton =
    document.getElementById(
      "parks-search-clear"
    );

  const count =
    document.getElementById(
      "parks-visible-count"
    );

  const label =
    document.getElementById(
      "parks-visible-label"
    );

  const empty =
    document.getElementById("parks-empty");

  const summaryTotal =
    document.getElementById("summary-total");

  const summaryTotalLabel =
    document.getElementById(
      "summary-total-label"
    );

  const summaryFiftyFive =
    document.getElementById("summary-55");

  const summaryFamily =
    document.getElementById(
      "summary-family"
    );

  const summaryPets =
    document.getElementById(
      "summary-pets"
    );

  if (!buttons.length || !cards.length) {
    return;
  }

  let activeFilter = "all";
  let activeSearch = "";

  const matchesCard = (card) => {
    const category =
      card.dataset.category || "";

    const petType =
      card.dataset.petType || "";

    const matchesFilter =
      activeFilter === "all" ||
      category === activeFilter ||
      (
        activeFilter === "pets" &&
        petType !== "none"
      );

    const searchText = [
      card.dataset.name,
      card.dataset.address,
      card.textContent,
    ]
      .join(" ")
      .toLowerCase();

    const matchesSearch =
      !activeSearch ||
      searchText.includes(activeSearch);

    return matchesFilter && matchesSearch;
  };

  const updateHeroStats = (
    visibleCards
  ) => {
    const visibleTotal =
      visibleCards.length;

    const visibleFiftyFive =
      visibleCards.filter(
        (card) =>
          card.dataset.category ===
          "55-plus"
      ).length;

    const visibleFamily =
      visibleCards.filter(
        (card) =>
          card.dataset.category === "family"
      ).length;

    const visiblePets =
      visibleCards.filter(
        (card) =>
          card.dataset.petType !== "none"
      ).length;

    if (summaryTotal) {
      summaryTotal.textContent =
        String(visibleTotal);
    }

    if (summaryTotalLabel) {
      summaryTotalLabel.textContent =
        visibleTotal === 1
          ? "Matching park"
          : activeFilter === "all" &&
              !activeSearch
            ? "Nanaimo parks"
            : "Matching parks";
    }

    if (summaryFiftyFive) {
      summaryFiftyFive.textContent =
        String(visibleFiftyFive);
    }

    if (summaryFamily) {
      summaryFamily.textContent =
        String(visibleFamily);
    }

    if (summaryPets) {
      summaryPets.textContent =
        String(visiblePets);
    }
  };

  const applyResults = () => {
    const visibleCards = [];

    cards.forEach((card) => {
      const matches = matchesCard(card);

      card.hidden = !matches;

      if (matches) {
        visibleCards.push(card);
      }
    });

    buttons.forEach((button) => {
      const active =
        button.dataset.filter ===
        activeFilter;

      button.classList.toggle(
        "is-active",
        active
      );

      button.setAttribute(
        "aria-pressed",
        String(active)
      );
    });

    if (count) {
      count.textContent =
        String(visibleCards.length);
    }

    if (label) {
      label.textContent =
        visibleCards.length === 1
          ? "park shown"
          : "parks shown";
    }

    if (empty) {
      empty.hidden =
        visibleCards.length !== 0;
    }

    if (clearButton) {
      clearButton.hidden =
        activeSearch.length === 0;
    }

    updateHeroStats(visibleCards);

    const url = new URL(
      window.location.href
    );

    if (activeFilter === "all") {
      url.searchParams.delete("type");
    } else {
      url.searchParams.set(
        "type",
        activeFilter
      );
    }

    if (activeSearch) {
      url.searchParams.set(
        "search",
        activeSearch
      );
    } else {
      url.searchParams.delete("search");
    }

    window.history.replaceState(
      {},
      "",
      `${url.pathname}${url.search}${url.hash}`
    );

    window.dispatchEvent(
      new CustomEvent(
        "parks:results-change",
        {
          detail: {
            filter: activeFilter,
            search: activeSearch,
          },
        }
      )
    );
  };

  buttons.forEach((button) => {
    button.addEventListener(
      "click",
      () => {
        activeFilter =
          button.dataset.filter || "all";

        applyResults();
      }
    );
  });

  searchInput?.addEventListener(
    "input",
    () => {
      activeSearch = searchInput.value
        .trim()
        .toLowerCase();

      applyResults();
    }
  );

  clearButton?.addEventListener(
    "click",
    () => {
      activeSearch = "";

      if (searchInput) {
        searchInput.value = "";
        searchInput.focus();
      }

      applyResults();
    }
  );

  cards.forEach((card) => {
    const slug = card.dataset.slug || "";

    card.addEventListener(
      "mouseenter",
      () => {
        window.dispatchEvent(
          new CustomEvent(
            "parks:card-hover",
            {
              detail: {
                slug,
                active: true,
              },
            }
          )
        );
      }
    );

    card.addEventListener(
      "mouseleave",
      () => {
        window.dispatchEvent(
          new CustomEvent(
            "parks:card-hover",
            {
              detail: {
                slug,
                active: false,
              },
            }
          )
        );
      }
    );
  });

  const params = new URLSearchParams(
    window.location.search
  );

  const requestedFilter =
    params.get("age") === "55-plus"
      ? "55-plus"
      : params.get("type") || "all";

  activeFilter = buttons.some(
    (button) =>
      button.dataset.filter ===
      requestedFilter
  )
    ? requestedFilter
    : "all";

  activeSearch =
    (params.get("search") || "")
      .trim()
      .toLowerCase();

  if (searchInput) {
    searchInput.value = activeSearch;
  }

  applyResults();
}
function initializeParksPage() {
  initializeOverviewMap();
  initializeParkFilters();
  initializeParkMaps();
}

if (document.readyState === "loading") {
  document.addEventListener(
    "DOMContentLoaded",
    initializeParksPage,
    { once: true }
  );
} else {
  initializeParksPage();
}

document.addEventListener(
  "astro:page-load",
  initializeParksPage
);
    </script>
