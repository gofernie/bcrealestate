---

<Layout
  title="Mobile Home Parks in Nanaimo | Nanaimo Mobile Homes"
  description="Compare mobile home parks in Nanaimo by age restrictions, pet policies, location and community features."
  accentColor={site?.accent_color || "#58736a"}
  city="nanaimo"
