import { createClient } from "@supabase/supabase-js";
import Layout from "../../layouts/Layout.astro";
import ListingCard from "../../components/ListingCard.astro";
import ShortlistReviewModal from "../../components/ShortlistReviewModal.astro";
import IntentModalController from "../../components/IntentModalController.astro";
import SiteNav from "../../components/SiteNav.astro";
import { getSite } from "../../lib/getSite";
import "../../styles/area-page.css";
import "../../styles/page-hero.css";
import "../../styles/intent-modal.css";
import { getNavIntentPages } from "../../lib/getNavIntentPages";

export const prerender = false;
const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const city =
  String(
    Astro.url.searchParams.get("city") ||
    Astro.params.city ||
    "nanaimo"
  )
    .toLowerCase()
    .trim();

const site = await getSite(Astro.url.hostname, city);

    console.log({
  hostname: Astro.url.hostname,
  paramCity: Astro.params.city,
  siteCity: site?.city,
  finalCity: city,
});



const cityLabel = city.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());

const agentPageSlug =
  site?.city?.toLowerCase() === "parksville"
    ? "parksville"
    : "chris-crump";

const { data: agentPage } = await supabase
  .from("agent_pages")
  .select("data")
  .eq("slug", agentPageSlug)
  .maybeSingle();

const accentColor =
  site?.accent_color ||
  "#2f6f73";

console.log("COLOUR SOURCE DEBUG", {
  city,
  agentPageSlug,
  agentPageAccent: agentPage?.data?.accentColor,
  siteAccent: site?.accent_color,
  finalAccent: accentColor,
});

let listingsQuery = supabase
  .from("listing_rows")
  .select("*")
  .eq("normalized_city", city)
  .eq("status", "A");

const sitePrimaryType = String(
  site?.primaryType || ""
)
  .toLowerCase()
  .trim();

if (
  site?.isPropertyTypeSite &&
  sitePrimaryType
) {
  listingsQuery = listingsQuery.eq(
    "normalized_type",
    sitePrimaryType
  );
}

const {
  data: allListings = [],
  error,
} = await listingsQuery;

const { data: featuredIntentPages = [], error: featuredIntentError } =
  await supabase
    .from("intent_pages")
    .select("slug, hero_heading, intro_copy")
    .eq("city", city)
    .order("sort_order", { ascending: true })
    .limit(6);

console.log("FEATURED INTENT PAGES", {
  count: featuredIntentPages.length,
  rows: featuredIntentPages,
  error: featuredIntentError,
});

if (error) {
  console.error(`${cityLabel} market page error:`, error);
}

const normalizeListingImageUrl = (value: any) => {
  if (!value) return "";
  const raw =
    typeof value === "string"
      ? value
      : value.highRes ||
        value.mediumRes ||
        value.lowRes ||
        value.url ||
        value.src ||
        value.href ||
        value.path ||
        "";
  if (!raw) return "";
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  const cleaned = raw.startsWith("/") ? raw : `/${raw}`;
 return `https://cdn.repliers.io${cleaned}`;
};

const getListingImage = (listing: any) =>
  normalizeListingImageUrl(
    listing.image_url ||
      listing.image ||
      listing.photo ||
      listing.images?.[0] ||
      listing.images?.[1] ||
      listing.raw?.images?.[0] ||
      listing.raw?.images?.[1] ||
      listing.raw?.images?.[0]?.url ||
      listing.raw?.images?.[1]?.url ||
      listing.raw?.images?.[0]?.mediumRes ||
      listing.raw?.images?.[1]?.mediumRes ||
      listing.raw?.images?.[0]?.highRes ||
      listing.raw?.images?.[1]?.highRes
  );

const listings = [...allListings]
  .sort((a, b) => {
    const da = new Date(a.listed_at || a.updated_at || 0).getTime();
    const db = new Date(b.listed_at || b.updated_at || 0).getTime();
    return db - da;
  })
  .slice(0, 12);

const activeListings = allListings.length;

const prices = allListings
  .map((l) => Number(l.price || 0))
  .filter((p) => p > 0)
  .sort((a, b) => a - b);

const avgPrice =
  prices.length > 0
    ? Math.round(prices.reduce((sum, p) => sum + p, 0) / prices.length)
    : 0;

const medianPrice = prices.length > 0 ? prices[Math.floor(prices.length / 2)] : 0;

const condoCount    = allListings.filter((l) => l.normalized_type === "condo").length;
const houseCount    = allListings.filter((l) => l.normalized_type === "house").length;
const townhomeCount = allListings.filter((l) => l.normalized_type === "townhouse").length;

let areaCounts = allListings.reduce((acc, listing) => {
  const area = listing.normalized_area || "other";
  acc[area] = (acc[area] || 0) + 1;
  return acc;
}, {});

let topAreas = Object.entries(areaCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

const areaToSlug = (value) =>
  String(value || "")
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/\//g, "-")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const { data: areaMetaRows = [] } = await supabase
  .from("area_boundaries")
  .select("area_slug, area_name, short_description, polygon_geojson")
  .ilike("city", city);

const navAreaCountMap = Object.fromEntries(
  Object.entries(areaCounts).map(([label, count]) => [label.toLowerCase(), count])
);

const navAreas = areaMetaRows
  .map((r) => r.area_name || String(r.area_slug || "").replace(/-/g, " "))
  .filter(Boolean)
  .sort((a, b) => (navAreaCountMap[b.toLowerCase()] || 0) - (navAreaCountMap[a.toLowerCase()] || 0));

const navTypes = ["house", "condo", "townhouse", "land"];

const cleanAreaName = (value) =>
  String(value || "")
    .replace(/^pq[\s-]+/i, "")
    .split("-")
    .join(" ")
    .replace(/\s+/g, " ")
    .trim();

const labelize = (value) =>
  cleanAreaName(value)
    .replace(/\b\w/g, (c) => c.toUpperCase());

function areaHue(areaName, index) {
  let hash = 0;

  for (const char of String(areaName || "")) {
    hash = char.charCodeAt(0) + ((hash << 5) - hash);
  }

  const hues = [355, 18, 34, 48, 205, 178, 155, 285, 315, 12, 92, 230];
  return hues[Math.abs(hash + index * 7) % hues.length];
}

const priceBuckets = [
  { label: "Under $500k", min: 0, max: 500000 },
  { label: "$500k–$750k", min: 500000, max: 750000 },
  { label: "$750k–$1M", min: 750000, max: 1000000 },
  { label: "$1M–$1.5M", min: 1000000, max: 1500000 },
  { label: "$1.5M+", min: 1500000, max: Infinity },
];

const priceBucketCounts = priceBuckets.map((bucket) =>
  allListings.filter((listing) => {
    const price = Number(listing.price || 0);
    return price >= bucket.min && price < bucket.max;
  }).length
);





  const areaBoundariesBySlug = Object.fromEntries(
  areaMetaRows
    .filter((row) => row.polygon_geojson?.coordinates?.[0]?.length)
    .map((row) => [row.area_slug, row.polygon_geojson])
);

function pointInPolygon(point, polygon) {
  const [lng, lat] = point;
  let inside = false;

  for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
    const [xi, yi] = polygon[i];
    const [xj, yj] = polygon[j];

    const intersect =
      yi > lat !== yj > lat &&
      lng < ((xj - xi) * (lat - yi)) / (yj - yi) + xi;

    if (intersect) inside = !inside;
  }

  return inside;
}

areaCounts = Object.fromEntries(
  (areaMetaRows || []).map((row: any) => {
    const slug = areaToSlug(row.area_slug || row.area_name);
    const label = row.area_name || String(row.area_slug || "").replace(/-/g, " ");
    const polygon = row.polygon_geojson?.coordinates?.[0];

   const count = polygon?.length
  ? allListings.filter((listing) => {
      const lat = Number(listing.lat || 0);
      const lng = Number(listing.lng || 0);

      if (!lat || !lng) return false;

      return pointInPolygon([lng, lat], polygon);
    }).length
  : 0;

    return [label, count];
  })
);

topAreas = Object.entries(areaCounts)
  .sort((a, b) => Number(b[1]) - Number(a[1]));

function getAreaCardCount(area, fallbackCount) {
  const boundary = areaBoundariesBySlug[areaToSlug(area)];
  const polygon = boundary?.coordinates?.[0];

  if (!polygon?.length) {
    return fallbackCount;
  }

const normalizedAreaListings = allListings.filter(
  (listing) => areaToSlug(listing.normalized_area) === areaToSlug(area)
);

return normalizedAreaListings.length;
}

const availableAreas = topAreas
  .filter(([area, count]) => getAreaCardCount(area, count) > 0)
  .map(([area]) => area);

const areaDescriptions = Object.fromEntries(
  areaMetaRows.map((row) => [
    row.area_slug,
    row.short_description,
  ])
);



function areaTagIcon(tag: string) {
  const clean = String(tag || "").toLowerCase();

  if (clean.includes("ocean") || clean.includes("waterfront") || clean.includes("beach") || clean.includes("harbour")) return "🏖";
  if (clean.includes("shopping") || clean.includes("services") || clean.includes("convenience")) return "🛍";
  if (clean.includes("park") || clean.includes("trail") || clean.includes("recreation")) return "🌳";
  if (clean.includes("walk")) return "🚶";
  if (clean.includes("viu") || clean.includes("school")) return "🎓";
  if (clean.includes("investment") || clean.includes("value")) return "💰";
  if (clean.includes("family")) return "🏡";
  if (clean.includes("character")) return "🏛";
  if (clean.includes("rural") || clean.includes("space") || clean.includes("lots")) return "🌲";
  if (clean.includes("quiet")) return "🌿";
  if (clean.includes("condos")) return "🏢";
  if (clean.includes("ferry")) return "⛴️";

  return "📍";
}

const chartData = {
  priceLabels: priceBuckets.map((b) => b.label),
  priceCounts: priceBucketCounts,

  areaLabels: topAreas.map(([area]) =>
    labelize(area)
      .replace("North Nanaimo", "North")
      .replace("South Nanaimo", "South")
      .replace("Central Nanaimo", "Central")
      .replace("University District", "University")
      .replace("Departure Bay", "Departure")
      .replace("Pleasant Valley", "Pleasant")
  ),

  areaCounts: topAreas.map(([, count]) => count),
};

const navIntentPages = await getNavIntentPages(supabase, site?.id);

const areasHeroMapData = areaMetaRows
  .filter((row: any) => row.polygon_geojson)
  .map((row: any) => {
    const areaName =
      row.area_name ||
      String(row.area_slug || "").replace(/-/g, " ");

    const areaSlug =
      row.area_slug ||
      areaToSlug(areaName);

    return {
      name: labelize(areaName),
      slug: areaSlug,
      href: `/${city}/${areaSlug}`,
      count: Number(areaCounts[areaName] || 0),
      geojson: row.polygon_geojson,
    };
  });

