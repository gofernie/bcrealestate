<script
  is:inline
  define:vars={{
    areasHeroMapData,
    accentColor,
  }}
>
  document.addEventListener("DOMContentLoaded", () => {
    const select = document.getElementById("area-nav-select");

    select?.addEventListener("change", (event) => {
      const value = event.target?.value;

      if (value) {
        window.location.href = value;
      }
    });

    const mapElement = document.getElementById("areas-hero-map");

    if (!mapElement || mapElement.dataset.mapReady === "true") {
      return;
    }

    let leafletLoadStarted = false;

    const loadLeaflet = () => {
      if (window.L) {
        initializeAreasMap();
        return;
      }

      if (leafletLoadStarted) return;
      leafletLoadStarted = true;

      if (!document.querySelector('link[data-areas-leaflet="true"]')) {
        const stylesheet = document.createElement("link");

        stylesheet.rel = "stylesheet";
        stylesheet.href =
          "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
        stylesheet.dataset.areasLeaflet = "true";

        document.head.appendChild(stylesheet);
      }

      const script = document.createElement("script");

      script.src =
        "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
      script.async = true;
      script.dataset.areasLeaflet = "true";
      script.onload = initializeAreasMap;

      document.body.appendChild(script);
    };

    const initializeAreasMap = () => {
      if (
        !window.L ||
        !mapElement ||
        mapElement.dataset.mapReady === "true"
      ) {
        return;
      }

      mapElement.dataset.mapReady = "true";

      const map = window.L.map(mapElement, {
        zoomControl: false,
        attributionControl: false,
        scrollWheelZoom: false,
        doubleClickZoom: false,
        dragging: true,
        tap: true,
      });

      window.L.tileLayer(
        "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
        {
          maxZoom: 19,
        }
      ).addTo(map);

      window.L.control
        .zoom({
          position: "topright",
        })
        .addTo(map);

     const completeBounds = window.L.latLngBounds([]);
const areaLayers = [];

      (areasHeroMapData || []).forEach((area, index) => {
        if (!area?.geojson) return;

        const layer = window.L.geoJSON(area.geojson, {
       style: {
  stroke: false,
  color: accentColor,
  weight: 1.3,
  opacity: 0.78,
  fillColor: accentColor,
  fillOpacity: 0.1,
  lineJoin: "round",
  lineCap: "round",
},

          onEachFeature: (_feature, featureLayer) => {
            const listingText =
              Number(area.count) === 1
                ? "1 active listing"
                : `${Number(area.count || 0)} active listings`;

            featureLayer.bindTooltip(
              `
                <div class="areas-map-tooltip">
                  <strong>${area.name}</strong>
                  <span>${listingText}</span>
                </div>
              `,
              {
                sticky: true,
                direction: "top",
                opacity: 1,
              }
            );

            featureLayer.on({
            mouseover: () => {
  featureLayer.setStyle({
    stroke: true,
    color: accentColor,
    weight: 1.3,
    opacity: 0.95,
    fillOpacity: 0.24,
    lineJoin: "round",
    lineCap: "round",
  });

  featureLayer.bringToFront();
},

mouseout: () => {
  featureLayer.setStyle({
    stroke: false,
    weight: 1.3,
    opacity: 0.78,
    fillOpacity: 0.1,
  });
},

              click: () => {
                window.location.href = area.href;
              },
            });
          },
        }).addTo(map);
areaLayers.push(layer);
        const layerBounds = layer.getBounds();

        if (layerBounds?.isValid()) {
          completeBounds.extend(layerBounds);
        }
      });

      if (completeBounds.isValid()) {
       map.fitBounds(completeBounds, {
  paddingTopLeft: [90, 34],
  paddingBottomRight: [34, 34],
  maxZoom: 12,
});
      } else {
        map.setView([49.504, -115.063], 11);
      }

 window.setTimeout(() => {
  map.invalidateSize();

  const stepDelay = 70;
  const holdTime = 350;

  areaLayers.forEach((layer, index) => {
    window.setTimeout(() => {
      layer.setStyle({
        stroke: true,
        color: accentColor,
        weight: 1.8,
        opacity: 0.9,
        fillOpacity: 0.28,
      });
    }, index * stepDelay);
  });

  const allAreasVisibleAt =
    areaLayers.length * stepDelay + holdTime;

  areaLayers.forEach((layer, index) => {
    window.setTimeout(() => {
      layer.setStyle({
        stroke: false,
        weight: 1.3,
        opacity: 0.78,
        fillOpacity: 0.1,
      });
    }, allAreasVisibleAt + index * stepDelay);
  });
}, 150);
    };

    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(loadLeaflet, {
        timeout: 1000,
      });
    } else {
      window.setTimeout(loadLeaflet, 100);
    }
  });
</script>
