}

// --- State ---
const intentMapEl = document.getElementById("intent-map");
const gridEl = document.querySelector(".grid");
const listViewBtn = document.getElementById("list-view-btn");
const mapViewBtn = document.getElementById("map-view-btn");

let leafletMap = null;
let listingMarkers = [];
let amenityMarkers = [];
let polygonLayer = null;
let maskLayer = null;
let refinedLeafletMap = null;
let refinedMarkers = [];
let currentIntentMapBounds = null;

const searchAreaGeojson = JSON.parse(
  document.querySelector("[data-search-area-geojson]")?.dataset.searchAreaGeojson || "null"
);

const accentColor = getComputedStyle(document.documentElement)
  .getPropertyValue("--accent").trim() || "#2f6f73";

const amenityCategoryMap = {
  schools: "school",
  grocery: "grocery",
  transit: "transit",
  parks: "park",
  restaurants: "restaurant",
  medical: "medical",
};

// --- Helpers ---
function getCardLatLng(card) {
  const lat = Number(card.dataset.lat || "");
  const lng = Number(card.dataset.lng || "");
  if (!Number.isFinite(lat) || !Number.isFinite(lng) || !lat || !lng) return null;
  return [lat, lng];
}

function makeListingIcon() {
  return L.divIcon({
    className: "",
    html: `<div style="position:relative;width:28px;height:36px;">
      <svg viewBox="0 0 28 36" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:28px;height:36px;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.3));">
        <path d="M14 0C6.268 0 0 6.268 0 14c0 9.333 14 22 14 22S28 23.333 28 14C28 6.268 21.732 0 14 0z" fill="${accentColor}"/>
        <circle cx="14" cy="14" r="5" fill="white"/>
      </svg>
    </div>`,
    iconSize: [28, 36],
    iconAnchor: [14, 36],
    popupAnchor: [0, -36],
  });
}

function makeAmenityIcon() {
  return L.divIcon({
    className: "",
  html: `<div style="width:14px;height:14px;border-radius:50%;background:${accentColor};opacity:0.6;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,0.25);"></div>`,
iconSize: [14, 14],
iconAnchor: [7, 7],
  });
}

function buildListingPopup(card) {
  let imgs = [];
  try { imgs = JSON.parse(card.dataset.images || "[]").filter(Boolean); } catch {}
  if (!imgs.length && card.dataset.image) imgs = [card.dataset.image];
  const img = imgs[0] || "";

  return `
    <div style="width:200px;font-family:'DM Sans',system-ui,sans-serif;cursor:pointer;" onclick="document.querySelector('[data-listing-id=\\'${card.dataset.listingId || ""}\\']')?.click()">
      ${img ? `<img src="${img}" style="width:100%;height:120px;object-fit:cover;display:block;border-radius:4px 4px 0 0;" />` : ""}
      <div style="padding:10px 12px 12px;">
        <strong style="font-size:0.95rem;display:block;margin-bottom:2px;">${card.dataset.price || ""}</strong>
        <span style="font-size:0.8rem;color:#6b6560;display:block;margin-bottom:2px;">${card.dataset.address || ""}</span>
        <span style="font-size:0.76rem;color:#9c9590;display:block;">${card.dataset.beds || "-"} bd · ${card.dataset.baths || "-"} ba</span>
