    priceLabel,
  ].filter(Boolean).join(" · ");
}

function applyFilters() {
  const filters = getCurrentFilters();
  const cards = Array.from(document.querySelectorAll(".original-card"));
  const filteredCards = getFilteredCards();

  const filteredSet = new Set(filteredCards);

  cards.forEach((card) => {
