function jsTitleCase(value = "") {
  return String(value)
    .replace(/^pq\s+/i, "")
    .split(" ")
    .filter(Boolean)
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
}

  function getCardPrice(card) {
    return Number(card.dataset.rawPrice || "0");
  }
function getCurrentFilters() {
  return {
    area: (() => {
      const value = areaSelect?.value || "all";
      return value.startsWith("/") ? "all" : value;
    })(),
    price: priceSelect?.value || "all",
    type: String(typeSelect?.value || "all").toLowerCase(),
    beds: String(bedsSelect?.value || "all").toLowerCase(),
  };
}

function cardMatchesFilters(card, filters, options = {}) {
  const ignoreType = options.ignoreType === true;

  const cardArea = String(card.dataset.area || "").toLowerCase();
  const cardType = String(card.dataset.type || "").toLowerCase();
  const price = getCardPrice(card);
  const beds = Number(card.dataset.beds || 0);

  const matchesArea =
    filters.area === "all" || cardArea === filters.area;

  const matchesBeds =
    filters.beds === "all" || beds >= Number(filters.beds);

  const matchesType =
    ignoreType || filters.type === "all" || cardType === filters.type;

  const matchesPrice =
    filters.price === "all" ||
    (filters.price === "under-450" && price < 450000) ||
    (filters.price === "450-650" && price >= 450000 && price < 650000) ||
    (filters.price === "650-850" && price >= 650000 && price < 850000) ||
    (filters.price === "850-1100" && price >= 850000 && price < 1100000) ||
    (filters.price === "1100-plus" && price >= 1100000);

  return matchesArea && matchesBeds && matchesPrice && matchesType;
}

function getFilteredCards(options = {}) {
  const filters = getCurrentFilters();

  return Array.from(document.querySelectorAll(".original-card"))
    .filter((card) => !card.classList.contains("is-hidden-by-refine"))
    .filter((card) => cardMatchesFilters(card, filters, options));
}

function updatePropertyTypePills() {
  const cardsForCounts = getFilteredCards({ ignoreType: true });
  const pills = Array.from(document.querySelectorAll(".property-type-pill"));

  const counts = {
    house: 0,
    condo: 0,
    townhouse: 0,
    mobile: 0,
    land: 0,
  };

  cardsForCounts.forEach((card) => {
    const type = String(card.dataset.type || "").toLowerCase();
    if (type in counts) counts[type] += 1;
  });

  pills.forEach((pill) => {
    const type = pill.dataset.propertyType;
    const count = counts[type] || 0;

    pill.hidden = count === 0;

    if (count === 0) {
      pill.classList.remove("active");
    }

    const label =
      type === "house" ? "Homes" :
      type === "condo" ? "Condos" :
      type === "townhouse" ? "Townhomes" :
      type === "mobile" ? "Mobile Homes" :
      "Lot / Land";

    const icon =
      type === "house" ? "🏡" :
      type === "condo" ? "🏢" :
      type === "townhouse" ? "🏘️" :
      type === "mobile" ? "🏠" :
      "🌲";

    pill.innerHTML = `${icon} <strong>${count}</strong> ${label}`;
