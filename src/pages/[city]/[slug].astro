// --- Load Leaflet after the initial page paint ---
let leafletLoadStarted = false;

function loadLeaflet() {
  if (window.L || leafletLoadStarted) return;

  leafletLoadStarted = true;

  const link = document.createElement("link");
  link.rel = "stylesheet";
  link.href = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
  document.head.appendChild(link);

  const script = document.createElement("script");
  script.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
  script.async = true;

  script.onload = () => {
    window.__leafletReady = true;
  };

  document.body.appendChild(script);
}

function scheduleLeafletLoad() {
  const startLoading = () => {
    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(loadLeaflet, {
        timeout: 1500,
      });
    } else {
      window.setTimeout(loadLeaflet, 400);
    }
  };

  if (document.readyState === "complete") {
    startLoading();
  } else {
    window.addEventListener("load", startLoading, {
      once: true,
    });
  }
}

scheduleLeafletLoad();

function waitForLeaflet(callback) {
  if (window.L) {
    callback();
    return;
  }

  loadLeaflet();

  let attempts = 0;
  const maxAttempts = 200;

  const check = () => {
    if (window.L) {
      callback();
      return;
    }

    attempts += 1;

    if (attempts < maxAttempts) {
      window.setTimeout(check, 50);
    }
  };

  check();
}

function initTypeHeroMap() {
  const heroMapEl = document.getElementById("type-hero-map");

  if (!heroMapEl || heroMapEl.dataset.mapReady === "true") {
    return;
  }

  waitForLeaflet(() => {
    if (!document.body.contains(heroMapEl)) return;

    const listingCards = Array.from(
      document.querySelectorAll(".grid .card[data-lat][data-lng]")
    );

    const points = listingCards
      .map((card) => {
        const lat = Number(card.dataset.lat || "");
        const lng = Number(card.dataset.lng || "");

        if (
          !Number.isFinite(lat) ||
          !Number.isFinite(lng) ||
          !lat ||
          !lng
        ) {
          return null;
        }

        return {
          lat,
          lng,
          price:
            card.querySelector(".price")?.textContent?.trim() || "",
          address:
            card.querySelector(".address")?.textContent?.trim() || "",
        };
      })
      .filter(Boolean)
      .slice(0, 60);

    if (!points.length) {
      heroMapEl.innerHTML = `
        <div style="
          height:100%;
          display:grid;
          place-items:center;
          padding:24px;
          color:#6b7280;
          font-size:.85rem;
          text-align:center;
        ">
          Map locations are not available for these listings.
        </div>
      `;
      return;
    }

    heroMapEl.dataset.mapReady = "true";

    const heroMap = L.map(heroMapEl, {
      zoomControl: false,
      attributionControl: false,
      scrollWheelZoom: false,
      doubleClickZoom: false,
      dragging: true,
      tap: true,
    });

    L.tileLayer(
      "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
      {
        maxZoom: 19,
      }
    ).addTo(heroMap);

    L.control
      .zoom({
        position: "topright",
      })
      .addTo(heroMap);

    const heroMarkerIcon = L.divIcon({
      className: "",
      iconSize: [24, 24],
      iconAnchor: [12, 12],
      popupAnchor: [0, -10],
      html: `
        <div style="
          width:24px;
          height:24px;
          display:grid;
          place-items:center;
          border:3px solid rgba(255,255,255,.96);
          border-radius:50%;
          background:${accentColor};
          color:#fff;
          box-shadow:0 5px 14px rgba(18,58,90,.28);
          font-size:10px;
          font-weight:900;
        ">▥</div>
      `,
    });

    const bounds = L.latLngBounds([]);

    points.forEach((point) => {
      const marker = L.marker(
        [point.lat, point.lng],
        { icon: heroMarkerIcon }
      ).addTo(heroMap);

      marker.bindPopup(
        `
          <div style="
            min-width:140px;
            font-family:DM Sans,system-ui,sans-serif;
          ">
            ${
              point.price
                ? `<strong style="
                    display:block;
                    margin-bottom:3px;
                    color:#172033;
                    font-size:.9rem;
                  ">${point.price}</strong>`
                : ""
            }

            ${
              point.address
                ? `<span style="
                    display:block;
                    color:#687080;
                    font-size:.72rem;
                    line-height:1.35;
                  ">${point.address}</span>`
                : ""
            }
          </div>
        `,
        {
          closeButton: false,
          offset: [0, -5],
        }
      );

      bounds.extend([point.lat, point.lng]);
    });

    if (bounds.isValid()) {
      heroMap.fitBounds(bounds, {
        paddingTopLeft: [205, 34],
        paddingBottomRight: [34, 34],
        maxZoom: 13,
      });
    }

    setTimeout(() => {
      heroMap.invalidateSize();
    }, 150);
  });
}

if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", initTypeHeroMap, {
    once: true,
