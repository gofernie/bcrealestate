}

// --- Draw polygon ---
function drawSearchPolygon(map) {
  if (!searchAreaGeojson?.coordinates?.[0]) return null;

  const coords = searchAreaGeojson.coordinates[0].map(([lng, lat]) => [lat, lng]);

  // Mask (darken outside polygon)
  const worldCoords = [
    [[-85, -180], [-85, 180], [85, 180], [85, -180]],
    coords,
  ];
  maskLayer = L.polygon(worldCoords, {
    color: "none",
    fillColor: "#000",
    fillOpacity: 0.06,
    interactive: false,
  }).addTo(map);

  // Outline
  polygonLayer = L.polygon(coords, {
    color: accentColor,
    weight: 3,
    fillOpacity: 0.02,
    interactive: false,
  }).addTo(map);

  return L.latLngBounds(coords);
}

// --- Init main map ---
function initLeafletMap(mode = "all") {
  if (!intentMapEl) return;

  waitForLeaflet(() => {
    const selector = mode === "refined" ? ".refined-card" : ".original-card";
    const cards = Array.from(document.querySelectorAll(selector)).filter(
      (c) => !c.hidden && c.style.display !== "none" && c.dataset.lat && c.dataset.lng
    );

    const points = cards.map((c) => ({ card: c, latlng: getCardLatLng(c) })).filter((i) => i.latlng);

    // Init map if needed
    if (!leafletMap) {
    leafletMap = L.map(intentMapEl, {
  zoomControl: true,
  attributionControl: false,
  scrollWheelZoom: false,
});

      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: "© OpenStreetMap",
      }).addTo(leafletMap);

      L.control.attribution({ prefix: false }).addAttribution('© <a href="https://openstreetmap.org">OSM</a>').addTo(leafletMap);
    }

    // Clear existing markers
    listingMarkers.forEach((m) => m.remove());
    listingMarkers = [];
    amenityMarkers.forEach((m) => m.remove());
    amenityMarkers = [];
    if (polygonLayer) { polygonLayer.remove(); polygonLayer = null; }
    if (maskLayer) { maskLayer.remove(); maskLayer = null; }

    // Draw polygon
    const areaBounds = drawSearchPolygon(leafletMap);

    // Add listing markers
    points.forEach(({ card, latlng }) => {
      const marker = L.marker(latlng, { icon: makeListingIcon() }).addTo(leafletMap);

      const popup = L.popup({
        maxWidth: 210,
        closeButton: false,
        offset: [0, -4],
        className: "leaflet-listing-popup",
      }).setContent(buildListingPopup(card));

      marker.on("mouseover", () => marker.openPopup());
      marker.on("mouseout", () => setTimeout(() => marker.closePopup(), 200));
      marker.on("click", () => card.click());
      marker.bindPopup(popup);

      listingMarkers.push(marker);
    });

    // Fit bounds
    if (areaBounds) {
      leafletMap.fitBounds(areaBounds, { padding: [40, 40] });
    } else if (points.length) {
      const bounds = L.latLngBounds(points.map((p) => p.latlng));
      leafletMap.fitBounds(bounds, { padding: [40, 40] });
    }

    // Track bounds for refine
    leafletMap.on("moveend", () => {
      const b = leafletMap.getBounds();
      currentIntentMapBounds = {
        north: b.getNorth(),
        east: b.getEast(),
        south: b.getSouth(),
        west: b.getWest(),
      };
    });

