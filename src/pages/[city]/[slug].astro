  .from("city_census_data")
  .select("*")
  .eq("city", titleCaseCity)
  .maybeSingle();

const censusData = pageKind === "area"
  ? census
  : cityCensus;
// Pull centroid from area boundary polygon for OSM fetch
let osmLat = 0;
let osmLng = 0;

if (pageKind === "area" && page.polygon_geojson) {
  try {
    const geojson = page.polygon_geojson;
    const coords =
      geojson?.type === "Feature"
        ? geojson.geometry?.coordinates?.[0]
        : geojson?.type === "FeatureCollection"
          ? geojson.features?.[0]?.geometry?.coordinates?.[0]
          : geojson?.coordinates?.[0];

    if (Array.isArray(coords) && coords.length) {
      const lats = coords.map((c: number[]) => c[1]);
      const lngs = coords.map((c: number[]) => c[0]);
      osmLat = lats.reduce((a: number, b: number) => a + b, 0) / lats.length;
      osmLng = lngs.reduce((a: number, b: number) => a + b, 0) / lngs.length;
    }
  } catch (e) {
    // use 0,0 fallback
  }
}

// Fetch OSM amenities server-side for copy generation
let osmSummary = { schools: 0, parks: 0, transit: 0, grocery: 0, restaurants: 0, medical: 0 };

if (osmLat && osmLng) {
  try {
    const osmRes = await fetch(
      `${Astro.url.origin}/api/osm-amenities?city=${encodeURIComponent(city)}&lat=${osmLat}&lng=${osmLng}&radius=10&limit=200&maxDistKm=4`
    );
    const osmData = await osmRes.json();
    const cats = osmData.categories || {};
    osmSummary = {
      schools: (cats.school || []).filter((i: any) => Number(i.distKm || 0) <= 2).length,
      parks: (cats.park || []).filter((i: any) => Number(i.distKm || 0) <= 2).length,
      transit: (cats.transit || []).filter((i: any) => Number(i.distKm || 0) <= 2).length,
      grocery: (cats.grocery || []).filter((i: any) => Number(i.distKm || 0) <= 2).length,
      restaurants: (cats.restaurant || []).filter((i: any) => Number(i.distKm || 0) <= 2).length,
      medical: (cats.medical || []).filter((i: any) => Number(i.distKm || 0) <= 2).length,
    };
  } catch (e) {
    // silently fail
  }
}

// Auto-generate neighbourhood copy from live data
function generateAreaCopy(listings: any[], census: any, osm: typeof osmSummary, areaName: string, cityName: string) {
  const prices = listings.map((l) => Number(l.price || 0)).filter((p) => p > 0);
  const minPrice = prices.length ? Math.min(...prices) : 0;
  const maxPrice = prices.length ? Math.max(...prices) : 0;
  const medianPrice = prices.length ? [...prices].sort((a, b) => a - b)[Math.floor(prices.length / 2)] : 0;

  const typeCounts: Record<string, number> = {};
  listings.forEach((l) => {
    const t = String(l.normalized_type || "").toLowerCase();
    if (t) typeCounts[t] = (typeCounts[t] || 0) + 1;
  });

  const dominantTypes = Object.entries(typeCounts)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 2)
    .map(([type]) => type === "house" ? "houses" : `${type}s`);

  const fmt = (n: number) => `$${Math.round(n / 1000)}k`;
  const area = areaName || cityName;

  let about = `${area} has ${listings.length} active listing${listings.length !== 1 ? "s" : ""}`;
  if (minPrice && maxPrice) about += ` ranging from ${fmt(minPrice)} to ${fmt(maxPrice)}`;
  if (dominantTypes.length) about += `, predominantly ${dominantTypes.join(" and ")}`;
  about += ".";

  if (census?.pct_owned) about += ` With ${census.pct_owned}% owner-occupied households`;
  if (census?.median_age) about += ` and a median age of ${census.median_age}`;
  if (census?.median_household_income) about += `, the area attracts buyers with a median household income of $${Math.round(census.median_household_income / 1000)}k`;
  if (census?.pct_owned || census?.median_age || census?.median_household_income) about += ".";

  let market = `Median pricing sits at ${fmt(medianPrice)} across current listings.`;
  const osmParts = [];
  if (osm.schools > 0) osmParts.push(`${osm.schools} school${osm.schools !== 1 ? "s" : ""}`);
  if (osm.parks > 0) osmParts.push(`${osm.parks} park${osm.parks !== 1 ? "s" : ""}`);
  if (osm.transit > 0) osmParts.push(`${osm.transit} transit stop${osm.transit !== 1 ? "s" : ""}`);
  if (osmParts.length) market += ` Within 2km you'll find ${osmParts.join(", ")}.`;
  market += " Inventory and pricing can shift quickly — check back regularly for new listings.";

  return { about, market };
}


 

