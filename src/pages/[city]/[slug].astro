// --- Amenity radius (computed once from polygon size) ---
let amenityRadius = 8;
if (searchAreaGeojson?.coordinates?.[0]?.length) {
  const coords = searchAreaGeojson.coordinates[0];
  const lats = coords.map(c => c[1]);
  const lngs = coords.map(c => c[0]);
  const latSpan = Math.max(...lats) - Math.min(...lats);
  const lngSpan = Math.max(...lngs) - Math.min(...lngs);
  const spanKm = Math.max(latSpan, lngSpan) * 111;
  amenityRadius = Math.min(Math.max(spanKm * 0.7, 8), 30);
}

// --- Load amenities ---
async function loadAreaAmenities(category = "school") {
  if (!leafletMap) return;

  amenityMarkers.forEach((m) => m.remove());
  amenityMarkers = [];

  const osmCity = document.querySelector("[data-city]")?.dataset.city || "nanaimo";
  const areaEl = document.querySelector("[data-area-center-lat]");
  const osmLat = Number(areaEl?.dataset.areaCenterLat || 0);
  const osmLng = Number(areaEl?.dataset.areaCenterLng || 0);

  if (!osmLat || !osmLng) return;

  try {
    if (searchAreaGeojson?.coordinates?.[0]?.length) {
      const coords = searchAreaGeojson.coordinates[0];
      const lats = coords.map(c => c[1]);
      const lngs = coords.map(c => c[0]);
      const latSpan = Math.max(...lats) - Math.min(...lats);
      const lngSpan = Math.max(...lngs) - Math.min(...lngs);
      const spanKm = Math.max(latSpan, lngSpan) * 111;
      amenityRadius = Math.min(Math.max(spanKm * 0.7, 8), 30);
    }

    const res = await fetch(
      `/api/osm-amenities?city=${encodeURIComponent(osmCity)}&lat=${osmLat}&lng=${osmLng}&radius=10&limit=200&maxDistKm=${amenityRadius.toFixed(1)}`
    );
    const payload = await res.json();

    // Update chip counts
    document.querySelectorAll(".amenity-chip").forEach((chip) => {
      const key = amenityCategoryMap[chip.dataset.amenity] || chip.dataset.amenity;
      const items = payload.categories?.[key] || [];
const count = items.filter((i) => Number(i.distKm || 0) <= amenityRadius).length;
      const strong = chip.querySelector("strong");
      if (strong) strong.textContent = String(count);
    });

const rows = (payload.categories?.[category] || []).filter((i) => Number(i.distKm || 0) <= amenityRadius);

    // Update panel
    const activeChip = document.querySelector(".amenity-chip.active");
    const label = activeChip?.childNodes?.[0]?.textContent?.trim() || category;
    const panelTitle = document.querySelector("#area-amenity-panel h3");
    const panelCopy = document.querySelector("#area-amenity-panel p");
    const amenityList = document.querySelector("#amenity-list");

    if (panelTitle) panelTitle.textContent = label;
    if (panelCopy) panelCopy.textContent = `${rows.filter(i => i.name?.trim()).length} ${label.toLowerCase()} near ${document.querySelector("[data-slug]")?.dataset.slug?.replaceAll("-", " ") || "this area"}`;

  if (amenityList) {
  amenityList.innerHTML = rows
    .filter((item) => item.name && item.name.trim())
    .slice(0, 8)
    .map((item) => `
      <div
        class="amenity-row"
        data-amenity-name="${String(item.name || "").replace(/"/g, "&quot;")}"
      >
        <strong>${item.name}</strong>
        <span>${Number(item.distKm || 0).toFixed(1)} km away</span>
      </div>`)
    .join("") || `<div style="padding:14px 18px;color:#9c9590;font-size:0.88rem;">No named ${label.toLowerCase()} found nearby.</div>`;

  amenityList.querySelectorAll(".amenity-row").forEach((row) => {
    row.addEventListener("mouseenter", () => {
      if (window.matchMedia("(max-width: 800px)").matches) return;

      const name = row.dataset.amenityName || "";
      const marker = amenityMarkers.find((m) => m.__amenityName === name);

      row.style.background = "rgba(0,0,0,0.035)";

      if (marker) {
        marker.openPopup();
        marker.setZIndexOffset(1000);

        const el = marker.getElement();
        if (el) {
          el.style.transform += " scale(1.35)";
          el.style.transition = "transform 0.15s ease";
        }
      }
    });

    row.addEventListener("mouseleave", () => {
      const name = row.dataset.amenityName || "";
      const marker = amenityMarkers.find((m) => m.__amenityName === name);

      row.style.background = "";

      if (marker) {
        marker.closePopup();
        marker.setZIndexOffset(0);

        const el = marker.getElement();
        if (el) {
          el.style.transform = el.style.transform.replace(" scale(1.35)", "");
        }
      }
    });

    row.addEventListener("click", () => {
      const name = row.dataset.amenityName || "";
      const marker = amenityMarkers.find((m) => m.__amenityName === name);

      if (marker && leafletMap) {
        leafletMap.flyTo(marker.getLatLng(), Math.max(leafletMap.getZoom(), 15), {
          duration: 0.45,
        });
        marker.openPopup();
      }
    });
  });
}

    // Add amenity markers
    rows.forEach((item) => {
      const lat = Number(item.lat);
      const lng = Number(item.lng);
      if (!lat || !lng) return;

   const marker = L.marker([lat, lng], { icon: makeAmenityIcon() }).addTo(leafletMap);
const popupLabel = item.name?.trim() || label || category;
marker.bindPopup(`
  <div style="font-family:'DM Sans',system-ui,sans-serif;padding:8px 12px;font-size:0.88rem;">
    <strong style="display:block;font-weight:700;color:#1c1914;margin-bottom:2px;">${popupLabel}</strong>
    <span style="font-size:0.78rem;color:#9c9590;">${Number(item.distKm || 0).toFixed(1)} km away</span>
  </div>`, {
  closeButton: false,
  offset: [0, -7],
});
marker.on("click", () => marker.openPopup());
marker.__amenityName = String(item.name || "").trim();
marker.__amenityCategory = category;

amenityMarkers.push(marker);
    });

  } catch (e) {
    console.warn("Amenity load failed:", e);
  }
}

// --- Init refined map ---
function initRefinedLeafletMap() {
  const refinedMapEl = document.getElementById("refined-intent-map");
  if (!refinedMapEl) return;

  waitForLeaflet(() => {
    const cards = Array.from(document.querySelectorAll(".refined-card")).filter(
      (c) => c.style.display !== "none"
    );
    const points = cards.map((c) => ({ card: c, latlng: getCardLatLng(c) })).filter((i) => i.latlng);

    if (!points.length) {
      refinedMapEl.innerHTML = "<p style='padding:16px;color:#6b6560;'>No map locations available.</p>";
      return;
    }

    if (!refinedLeafletMap) {
      refinedLeafletMap = L.map(refinedMapEl, { zoomControl: true, attributionControl: false, scrollWheelZoom: false });
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", { maxZoom: 19 }).addTo(refinedLeafletMap);
    }

    refinedMarkers.forEach((m) => m.remove());
    refinedMarkers = [];

    points.forEach(({ card, latlng }) => {
      const marker = L.marker(latlng, { icon: makeListingIcon() }).addTo(refinedLeafletMap);
      marker.bindPopup(buildListingPopup(card), { maxWidth: 210, closeButton: false });
      marker.on("click", () => card.click());
      refinedMarkers.push(marker);
    });

    const bounds = L.latLngBounds(points.map((p) => p.latlng));
    refinedLeafletMap.fitBounds(bounds, { padding: [40, 40] });
    setTimeout(() => refinedLeafletMap.invalidateSize(), 100);
  });
}

