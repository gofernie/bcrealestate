---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import MobileHomeAreasPage from "../components/sites/MobileHomeAreasPage.astro";
import { getSite } from "../lib/getSite";
import "../styles/page-hero.css";
import "../styles/area-page.css";

export const prerender = false;

const site = await getSite(Astro.url.hostname);

const hostname = Astro.url.hostname
  .toLowerCase()
  .replace(/^www\./, "");

const siteDomain = String(site?.domain || "")
  .toLowerCase()
  .replace(/^www\./, "");

const isMobileHomeSite =
  hostname === "nanaimomobiles.com" ||
  siteDomain === "nanaimomobiles.com" ||
  site?.template === "mobile-homes";

const pageTitle = isMobileHomeSite
  ? "Nanaimo Mobile Home Areas"
  : "BC Real Estate Areas";

const pageDescription = isMobileHomeSite
  ? "Explore Nanaimo areas with mobile homes for sale, local park communities, and current mobile-home listings."
  : "Browse British Columbia real estate areas, communities, and neighbourhood guides.";

const cityLinks = [
  { label: "Nanaimo", href: "/nanaimo/areas" },
  { label: "Parksville", href: "/parksville/areas" },
  { label: "Tofino", href: "/tofino/areas" },
  { label: "Whistler", href: "/whistler/areas" },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  accentColor={site?.accent_color || "#58736a"}
>
  <SiteNav
    city={site?.city || "nanaimo"}
    site={site}
    activeSection="areas"
  />

  {
    isMobileHomeSite ? (
      <MobileHomeAreasPage site={site} />
    ) : (
      <>
        <section class="page-hero">
          <div class="page-hero__inner">
            <p class="page-hero__eyebrow">
              BC REAL ESTATE AREAS
            </p>

            <h1>
              Explore BC real estate by area.
            </h1>

            <p>
              Browse local markets, neighbourhoods,
              and community pages across British
              Columbia.
            </p>
          </div>
        </section>

        <main class="area-page">
          <section class="area-section">
            <h2>Browse by city</h2>

            <div class="area-card-grid">
              {
                cityLinks.map((city) => (
                  <a
                    class="area-card"
                    href={city.href}
                  >
                    <strong>{city.label}</strong>
                    <span>
                      View neighbourhoods →
                    </span>
                  </a>
                ))
              }
            </div>
          </section>
        </main>
      </>
    )
  }
</Layout>