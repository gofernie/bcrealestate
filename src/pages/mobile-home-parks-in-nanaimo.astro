const filters = [
  { value: "all", label: "All Nanaimo parks" },
  { value: "55-plus", label: "55+ communities" },
  { value: "adult", label: "Other adult communities" },
  { value: "family", label: "Family & all ages" },
  { value: "pets", label: "Pet friendly" },
];

const totalParks = parks.length;
const fiftyFiveCount = parks.filter(
  (park) => park.category === "55-plus"
).length;
const familyCount = parks.filter(
  (park) => park.category === "family"
).length;
const petFriendlyCount = parks.filter(
  (park) => park.petType !== "none"
).length;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>Mobile Home Parks in Nanaimo | Nanaimo Mobile Homes</title>

    <meta
      name="description"
      content="Compare mobile home parks in Nanaimo by age restrictions, pet policies, location and community features."
    />
  </head>

  <body>
    <div class="parks-page">
      <header class="parks-hero">
        <div class="parks-shell">
          <a class="parks-back" href="/">
            ← Nanaimo Mobile Homes
          </a>

          <div class="parks-hero-grid">
            <div>
              <div class="parks-eyebrow">
                Nanaimo park directory
              </div>

              <h1>Find the right mobile home park.</h1>

              <p class="parks-intro">
                Compare Nanaimo’s 55+, adult-oriented, family
                and all-ages manufactured home communities by
                age restrictions, pet policies and location.
              </p>
            </div>

            <aside class="parks-summary">
              <div>
                <strong>{totalParks}</strong>
                <span>Nanaimo parks</span>
              </div>

              <div>
                <strong>{fiftyFiveCount}</strong>
                <span>55+ communities</span>
              </div>

              <div>
                <strong>{familyCount}</strong>
                <span>Family or all ages</span>
              </div>

              <div>
                <strong>{petFriendlyCount}</strong>
                <span>Permit some pets</span>
              </div>
            </aside>
          </div>
        </div>
      </header>

      <main>
        <section class="parks-filter-section">
          <div class="parks-shell">
            <div class="parks-filter-card">
              <div>
                <span class="parks-filter-label">
                  Show me
                </span>

                <div
                  class="parks-filter-buttons"
                  role="group"
                  aria-label="Filter parks"
                >
                  {
                    filters.map((filter, index) => (
                      <button
                        type="button"
                        class:list={[
                          "parks-filter-button",
                          {
                            "is-active": index === 0,
                          },
                        ]}
                        data-filter={filter.value}
                      >
                        {filter.label}
                      </button>
                    ))
                  }
                </div>
              </div>

              <div class="parks-result-count">
                <strong id="parks-visible-count">
                  {totalParks}
                </strong>

                <span id="parks-visible-label">
                  parks shown
                </span>
              </div>
            </div>
          </div>
        </section>

        <section class="parks-directory">
          <div class="parks-shell">
            <div class="parks-heading-row">
              <div>
                <div class="parks-eyebrow">
                  Explore communities
                </div>

                <h2>Nanaimo mobile home parks</h2>
              </div>

              <a
                class="parks-listing-link"
                href="/nanaimo/mobile-homes"
              >
                View homes for sale →
              </a>
            </div>

            <div class="parks-grid" id="parks-grid">
              {
                parks.map((park) => (
                  <article
                    class="park-card"
                    data-category={park.category}
                    data-pet-type={park.petType}
                  >
                    <div class="park-card-top">
                      <span class="park-age-badge">
                        {park.age}
                      </span>

                      <span
                        class:list={[
                          "park-pet-badge",
                          {
                            "park-pet-badge--none":
                              park.petType === "none",
                          },
                        ]}
                      >
                        {
                          park.petType === "none"
                            ? "No pets"
                            : "Pets considered"
                        }
                      </span>
                    </div>

                    <div class="park-icon" aria-hidden="true">
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M3 11.5 12 4l9 7.5" />
                        <path d="M5.5 10v10h13V10" />
                        <path d="M9 20v-6h6v6" />
                      </svg>
                    </div>

                    <h3>{park.name}</h3>

                    <p class="park-address">
                      {park.address}
                    </p>

                    <p class="park-description">
                      {park.description}
                    </p>

                    <div class="park-details">
                      <div>
                        <span>Community</span>
                        <strong>{park.age}</strong>
                      </div>

                      <div>
                        <span>Pet policy</span>
                        <strong>{park.pets}</strong>
                      </div>
                    </div>

                    <div class="park-features">
                      {
                        park.features.map((feature) => (
                          <span>{feature}</span>
                        ))
                      }
                    </div>

                    <a
                      class="park-link"
                      href={`/parks/${park.slug}`}
                    >
                      View park details
                      <span aria-hidden="true">→</span>
                    </a>
                  </article>
                ))
              }
            </div>

            <div
              class="parks-empty"
              id="parks-empty"
              hidden
            >
              No parks match this filter.
            </div>
          </div>
        </section>

        <section class="parks-help-section">
          <div class="parks-shell">
            <div class="parks-help-card">
              <div>
                <div class="parks-eyebrow">
                  Not sure where to start?
                </div>

                <h2>Find a park that fits your lifestyle.</h2>

                <p>
                  Tell us whether you need a 55+ community,
                  room for a pet, access to transit or a
                  particular part of Nanaimo.
                </p>
              </div>

              <div class="parks-help-actions">
                <a
                  class="parks-primary-button"
                  href="/parks?finder=true"
                >
                  Find my park
                </a>

                <a
                  class="parks-secondary-button"
                  href="/nanaimo/mobile-homes"
                >
                  Browse available homes
                </a>
              </div>
            </div>
          </div>
        </section>

        <section class="parks-disclaimer-section">
          <div class="parks-shell">
            <p class="parks-disclaimer">
              Park rules, age restrictions and pet policies
              may change and can be subject to management
              approval. Buyers should confirm all current
              information directly with park management before
              making a purchase.
            </p>
          </div>
        </section>
      </main>
    </div>

    <script is:inline>
      function initializeParkFilters() {
        const buttons = Array.from(
          document.querySelectorAll(
            ".parks-filter-button"
          )
        );

        const cards = Array.from(
          document.querySelectorAll(".park-card")
        );

        const count = document.getElementById(
          "parks-visible-count"
        );

        const label = document.getElementById(
          "parks-visible-label"
        );

        const empty = document.getElementById(
          "parks-empty"
        );

        if (!buttons.length || !cards.length) return;

        const applyFilter = (filter) => {
          let visible = 0;

          cards.forEach((card) => {
            const category =
              card.dataset.category || "";

            const petType =
              card.dataset.petType || "";

            const matches =
              filter === "all" ||
              category === filter ||
              (
                filter === "pets" &&
                petType !== "none"
              );

            card.hidden = !matches;

            if (matches) {
              visible += 1;
            }
          });

          buttons.forEach((button) => {
            const active =
              button.dataset.filter === filter;

            button.classList.toggle(
              "is-active",
              active
            );

            button.setAttribute(
              "aria-pressed",
              String(active)
            );
          });

          if (count) {
            count.textContent = String(visible);
          }

          if (label) {
            label.textContent =
              visible === 1
                ? "park shown"
                : "parks shown";
          }

          if (empty) {
            empty.hidden = visible !== 0;
          }

          const url = new URL(
            window.location.href
          );

          if (filter === "all") {
            url.searchParams.delete("type");
          } else {
            url.searchParams.set(
              "type",
              filter
            );
          }

          window.history.replaceState(
            {},
            "",
            `${url.pathname}${url.search}${url.hash}`
          );
        };

        buttons.forEach((button) => {
          button.addEventListener(
            "click",
            () => {
              applyFilter(
                button.dataset.filter || "all"
              );
            }
          );
        });

        const params = new URLSearchParams(
          window.location.search
        );

        const requestedFilter =
          params.get("age") === "55-plus"
            ? "55-plus"
            : params.get("type") || "all";

        const validFilter = buttons.some(
          (button) =>
            button.dataset.filter ===
            requestedFilter
        )
          ? requestedFilter
          : "all";

        applyFilter(validFilter);
      }

      if (document.readyState === "loading") {
        document.addEventListener(
          "DOMContentLoaded",
          initializeParkFilters,
          { once: true }
        );
      } else {
        initializeParkFilters();
      }

      document.addEventListener(
        "astro:page-load",
        initializeParkFilters
      );
    </script>
  </body>
</html>

<style>
  :root {
    --parks-accent: #58736a;
    --parks-ink: #17201d;
    --parks-muted: #69736f;
    --parks-line: rgba(23, 32, 29, 0.12);
    --parks-soft: #f4f6f3;
    --parks-warm: #faf7f1;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    color: var(--parks-ink);
    background: #fff;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1,
  h2,
  h3 {
    font-family:
      Georgia,
      "Times New Roman",
      serif;
    font-weight: 500;
    letter-spacing: -0.04em;
  }

  .parks-shell {
    width: min(1380px, calc(100% - 64px));
    margin-inline: auto;
  }

  .parks-hero {
    padding: 34px 0 76px;
    border-bottom: 1px solid var(--parks-line);
    background:
      radial-gradient(
        circle at 82% 20%,
        rgba(88, 115, 106, 0.2),
        transparent 32%
      ),
      linear-gradient(
        115deg,
        var(--parks-warm),
        #eef4f0
      );
  }

  .parks-back {
    display: inline-flex;
    margin-bottom: 64px;
    color: var(--parks-accent);
    font-size: 0.78rem;
    font-weight: 750;
    text-decoration: none;
  }

  .parks-hero-grid {
    display: grid;
    grid-template-columns:
      minmax(0, 1.3fr)
      minmax(360px, 0.7fr);
    gap: 72px;
    align-items: end;
  }

  .parks-eyebrow,
  .parks-filter-label {
    margin-bottom: 16px;
    color: var(--parks-accent);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .parks-hero h1 {
    max-width: 850px;
    margin-bottom: 24px;
    font-size: clamp(3.3rem, 7vw, 6.8rem);
    line-height: 0.91;
  }

  .parks-intro {
    max-width: 720px;
    margin-bottom: 0;
    color: #52605b;
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.7;
  }

  .parks-summary {
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 24px 60px rgba(31, 49, 42, 0.1);
    backdrop-filter: blur(16px);
  }

  .parks-summary div {
    min-height: 126px;
    padding: 24px;
    border-right: 1px solid var(--parks-line);
    border-bottom: 1px solid var(--parks-line);
  }

  .parks-summary div:nth-child(even) {
    border-right: 0;
  }

  .parks-summary div:nth-child(n + 3) {
    border-bottom: 0;
  }

  .parks-summary strong,
  .parks-summary span {
    display: block;
  }

  .parks-summary strong {
    margin-bottom: 8px;
    font-family: Georgia, serif;
    font-size: 2rem;
    font-weight: 500;
  }

  .parks-summary span {
    color: var(--parks-muted);
    font-size: 0.73rem;
  }

  .parks-filter-section {
    position: relative;
    z-index: 2;
    margin-top: -26px;
  }

  .parks-filter-card {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 28px;
    padding: 25px;
    border: 1px solid var(--parks-line);
    border-radius: 22px;
    background: #fff;
    box-shadow: 0 18px 50px rgba(26, 39, 34, 0.08);
  }

  .parks-filter-label {
