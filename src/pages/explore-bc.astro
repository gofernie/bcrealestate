---
import {
  createClient,
} from "@supabase/supabase-js";

import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";

import {
  getSite,
} from "../lib/getSite";

export const prerender = false;

const supabase =
  createClient(
    import.meta.env
      .PUBLIC_SUPABASE_URL,
    import.meta.env
      .SUPABASE_SERVICE_ROLE_KEY
  );

const hostname =
  Astro.url.hostname
    .toLowerCase()
    .replace(/^www\./, "");

const site =
  await getSite(hostname);

const accentColor =
  site?.accent_color ||
  "#2f6f73";

const approvedCities = [
  "campbell river",
  "colwood",
  "comox",
  "duncan",
  "fernie",
  "french creek",
  "ladysmith",
  "lantzville",
  "nanaimo",
  "parksville",
  "port alberni",
  "saanich",
  "sparwood",
  "tofino",
  "whistler",
];

const approvedCityOrder =
  new Map(
    approvedCities.map(
      (city, index) => [
        city,
        index,
      ]
    )
  );

const titleCase = (
  value: unknown
) =>
  String(value || "")
    .replace(/[-_]/g, " ")
    .replace(/\s+/g, " ")
    .trim()
    .replace(
      /\b\w/g,
      (character) =>
        character.toUpperCase()
    );

const slugify = (
  value: unknown
) =>
  String(value || "")
    .toLowerCase()
    .trim()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const normalizeCityValue = (
  value: unknown
) => {
  if (!value) {
    return "";
  }

  if (
    typeof value === "object" &&
    !Array.isArray(value)
  ) {
    const objectValue =
      value as Record<
        string,
        unknown
      >;

    return String(
      objectValue.city ||
      objectValue.City ||
      ""
    )
      .toLowerCase()
      .trim();
  }

  const raw =
    String(value).trim();

  if (raw.startsWith("{")) {
    try {
      const parsed =
        JSON.parse(raw);

      return String(
        parsed?.city ||
        parsed?.City ||
        ""
      )
        .toLowerCase()
        .trim();
    } catch {
      return "";
    }
  }

  const normalized =
    raw
      .toLowerCase()
      .trim();

  if (
    normalized.includes("{") ||
    normalized.includes("}") ||
    normalized.includes(":") ||
    normalized.length > 80
  ) {
    return "";
  }

  return normalized;
};

/*
 * Supabase normally limits a query to
 * 1,000 rows, so retrieve active city
 * inventory in batches.
 */
const loadActiveCityRows =
  async () => {
    const batchSize = 1000;

    let from = 0;

    const rows: Array<{
      normalized_city?:
        string | null;
      city?: string | null;
    }> = [];

    while (true) {
      const {
        data,
        error,
      } = await supabase
        .from("listing_rows")
        .select(
          `
            normalized_city,
            city
          `
        )
        .eq("status", "A")
        .range(
          from,
          from +
            batchSize -
            1
        );

      if (error) {
        throw error;
      }

      const batch =
        data || [];

      rows.push(...batch);

      if (
        batch.length <
        batchSize
      ) {
        break;
      }

      from += batchSize;
    }

    return rows;
  };

let listingRows: Array<{
  normalized_city?:
    string | null;
  city?: string | null;
}> = [];

let listingError = "";

try {
  listingRows =
    await loadActiveCityRows();
} catch (error) {
  listingError =
    error instanceof Error
      ? error.message
      : "Unable to load cities.";

  console.error(
    "Explore BC city query failed:",
    error
  );
}

/*
 * Optional site metadata gives each city
 * its configured name and accent colour
 * where available.
 */
const {
  data: siteRows = [],
  error: sitesError,
} = await supabase
  .from("sites")
  .select(
    `
      city,
      site_name,
      accent_color
    `
  )
  .not("city", "is", null);

if (sitesError) {
  console.error(
    "Explore BC site metadata query failed:",
    sitesError
  );
}

const metadataByCity =
  (siteRows || []).reduce(
    (
      result: Record<
        string,
        any
      >,
      row: any
    ) => {
    const cityKey =
  normalizeCityValue(
    row.city
  );

      if (
        cityKey &&
        !result[cityKey]
      ) {
        result[cityKey] =
          row;
      }

      return result;
    },
    {}
  );

const cityCounts =
  listingRows.reduce(
    (
      result: Record<
        string,
        number
      >,
      row
    ) => {
    const cityKey =
  normalizeCityValue(
    row.normalized_city ||
    row.city
  );

      if (!cityKey) {
        return result;
      }

      result[cityKey] =
        (
          result[cityKey] ||
          0
        ) + 1;

      return result;
    },
    {}
  );

const cities =
  Object.entries(
    cityCounts
  )
    .filter(
      ([city]) =>
        approvedCityOrder.has(
          city
        )
    )
    .map(
      ([city, count]) => {
        const metadata =
          metadataByCity[
            city
          ];

        const label =
          titleCase(city);

        return {
          city,
          label,

          siteName:
            metadata
              ?.site_name ||
            `${label} Real Estate`,

          count,

          href:
            `/${slugify(
              city
            )}`,

          areasHref:
            `/${slugify(
              city
            )}/areas`,

          accent:
            metadata
              ?.accent_color ||
            accentColor,
        };
      }
    )
      .sort(
      (
        first,
        second
      ) =>
        (
          approvedCityOrder.get(
            first.city
          ) ?? 999
        ) -
        (
          approvedCityOrder.get(
            second.city
          ) ?? 999
        )
    );

const totalListings =
  cities.reduce(
    (
      total,
      city
    ) =>
      total +
      city.count,
    0
  );

const pageTitle =
  "Explore BC Real Estate by City";

const pageDescription =
  "Browse active real estate listings across British Columbia by city and community.";

const bcHeroImageUrl =
  "https://images.unsplash.com/photo-1581590212320-a1f693559160?auto=format&fit=crop&w=2200&q=90";
---

<Layout
  title={pageTitle}
  description={
    pageDescription
  }
  accentColor={
    accentColor
  }
  city="bc"
>
  <SiteNav
    mode="province"
    city="bc"
    site={site}
    showAreaNav={false}
  />

  <main
    class="bc-directory"
  >
    <section
      class="bc-directory__hero"
    >
     <div
  class="bc-directory__hero-image"
  style={`background-image: url("${bcHeroImageUrl}");`}
  role="img"
  aria-label="British Columbia mountain landscape"
></div>

      <div
        class="bc-directory__hero-shade"
        aria-hidden="true"
      ></div>

      <div
        class="bc-directory__hero-inner"
      >
        <div
          class="bc-directory__hero-copy"
        >
          <p
            class="bc-directory__eyebrow bc-directory__eyebrow--light"
          >
            Explore British Columbia
          </p>

          <h1>
            One province.
            <br />
            Every market.
          </h1>

          <p>
            Browse active real
            estate across BC,
            compare local
            inventory, and find
            the community that
            feels right.
          </p>

          <div
            class="bc-directory__hero-actions"
          >
            <a
              class="bc-directory__primary-action"
              href="#bc-markets"
            >
              Browse cities
              <span
                aria-hidden="true"
              >
                ↓
              </span>
            </a>

            <a
              class="bc-directory__secondary-action"
              href="/explore"
            >
              Open map
              <span
                aria-hidden="true"
              >
                →
              </span>
            </a>
          </div>
        </div>

        <div
          class="bc-directory__summary"
          aria-label="Province-wide listing summary"
        >
          <span>
            <strong>
              {
                cities.length.toLocaleString()
              }
            </strong>

            BC markets
          </span>

          <span>
            <strong>
              {
                totalListings.toLocaleString()
              }
            </strong>

            active listings
          </span>
        </div>

        <a
          class="bc-directory__photo-credit"
          href="https://unsplash.com/photos/s0RQI12tvTI"
          target="_blank"
          rel="noreferrer"
        >
          Photo: Sarah Schimschal / Unsplash
        </a>
      </div>
    </section>

    <section
      id="bc-markets"
      class="bc-directory__content"
    >
      <div
        class="bc-directory__heading"
      >
        <div>
          <p
            class="bc-directory__eyebrow"
          >
            Browse by city
          </p>

          <h2>
            BC real estate
            markets
          </h2>
        </div>

        <a
          href="/explore"
        >
          Explore listings
          on the map
          <span
            aria-hidden="true"
          >
            →
          </span>
        </a>
      </div>

      {
        listingError ? (
          <div
            class="bc-directory__empty"
          >
            <h3>
              Cities could not
              be loaded
            </h3>

            <p>
              {listingError}
            </p>
          </div>
        ) : cities.length > 0 ? (
          <div
            class="bc-directory__grid"
          >
            {
              cities.map(
                (
                  city,
                  index
                ) => (
                  <article
                    class="bc-city-card"
                    style={`--city-accent: ${city.accent};`}
                  >
                    <div
                      class="bc-city-card__number"
                    >
                      {
                        String(
                          index + 1
                        ).padStart(
                          2,
                          "0"
                        )
                      }
                    </div>

                    <div
                      class="bc-city-card__content"
                    >
                      <p>
                        {
                          city.count.toLocaleString()
                        }{" "}
                        active{" "}
                        {
                          city.count ===
                          1
                            ? "listing"
                            : "listings"
                        }
                      </p>

                      <h3>
                        {
                          city.label
                        }
                      </h3>

                      <span>
                        {
                          city.siteName
                        }
                      </span>
                    </div>

                    <div
                      class="bc-city-card__links"
                    >
                      <a
                        href={
                          city.href
                        }
                      >
                        View listings
                        <span
                          aria-hidden="true"
                        >
                          →
                        </span>
                      </a>

                      <a
                        href={
                          city.areasHref
                        }
                      >
                        Neighbourhoods
                      </a>
                    </div>
                  </article>
                )
              )
            }
          </div>
        ) : (
          <div
            class="bc-directory__empty"
          >
            <h3>
              No active cities
            </h3>

            <p>
              No active listing
              markets were found.
            </p>
          </div>
        )
      }
    </section>
  </main>
</Layout>

