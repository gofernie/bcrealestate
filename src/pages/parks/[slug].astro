---
import { createClient } from "@supabase/supabase-js";
import Layout from "../../layouts/Layout.astro";
import SiteNav from "../../components/SiteNav.astro";
import ListingCard from "../../components/ListingCard.astro";
import IntentModalController from "../../components/IntentModalController.astro";
import { getSite } from "../../lib/getSite";
import { getNavIntentPages } from "../../lib/getNavIntentPages";
import "../../styles/area-page.css";
import "../../styles/intent-modal.css";

import {
  getMobileHomePark,
  mobileHomeParks,
} from "../../data/mobileHomeParks";

export const prerender = false;

const slug = Astro.params.slug || "";
const park = getMobileHomePark(slug);

if (!park) {
  return Astro.redirect(
    "/mobile-home-parks-in-nanaimo",
    302
  );
}

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const city = "nanaimo";

const requestHostname = Astro.url.hostname
  .toLowerCase()
  .replace(/^www\./, "");

const siteHostname =
  requestHostname === "localhost" ||
  requestHostname === "127.0.0.1"
    ? "nanaimomobiles.com"
    : requestHostname;

const site = await getSite(siteHostname, city);

const accentColor =
  site?.accent_color ||
  "#58736a";

const navIntentPages =
  await getNavIntentPages(supabase, city);

const normalizeMatchText = (value: unknown) =>
  String(value || "")
    .toLowerCase()
    .replace(/\bstreet\b/g, "st")
    .replace(/\broad\b/g, "rd")
    .replace(/\bavenue\b/g, "ave")
    .replace(/\bdrive\b/g, "dr")
    .replace(/\blane\b/g, "ln")
    .replace(/\bplace\b/g, "pl")
    .replace(/\bcrescent\b/g, "cres")
    .replace(/\bhighway\b/g, "hwy")
    .replace(/[^a-z0-9]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const getListingAddressText = (listing: any) =>
  normalizeMatchText(
    listing?.address ||
    listing?.raw?.address?.addressKey ||
    ""
  );

const hasExactCivicAddress = (
  listing: any,
  address: string
) => {
  const listingAddress = getListingAddressText(listing);
  const normalizedAddress = normalizeMatchText(address);
  const streetNumber =
    normalizedAddress.match(/^\d+/)?.[0] || "";
  const streetWords = normalizedAddress
    .replace(/^\d+\s*/, "")
    .split(" ")
    .filter(Boolean);

  if (
    !listingAddress ||
    !streetNumber ||
    streetWords.length === 0
  ) {
    return false;
  }

  const addressTokens = listingAddress.split(" ");
  const numberIndex = addressTokens.indexOf(streetNumber);

  if (numberIndex === -1) return false;

  const wordsAfterNumber = addressTokens.slice(
    numberIndex + 1,
    numberIndex + 1 + streetWords.length
  );

  return streetWords.every(
    (word, index) => wordsAfterNumber[index] === word
  );
};

const hasExactParkCivicAddress = (listing: any) =>
  hasExactCivicAddress(listing, park.address);

const { data: allMobileListings = [], error: listingsError } =
  await supabase
    .from("listing_rows")
    .select("*")
    .eq("status", "A")
    .eq("normalized_city", "nanaimo")
    .eq("normalized_type", "mobile")
    .order("listed_at", { ascending: false });

if (listingsError) {
  console.error(
    `Unable to load listings for ${park.name}:`,
    listingsError
  );
}

const parkListings = allMobileListings.filter(
  (listing: any) => hasExactParkCivicAddress(listing)
);

const parkListingCount = parkListings.length;

const normalizeImageUrl = (value: unknown) => {
  const url = String(value || "").trim();

  if (!url) return "";

  if (
    url.startsWith("http://") ||
    url.startsWith("https://")
  ) {
    return url;
  }

  if (url.startsWith("/")) {
    return `https://cdn.repliers.io${url}`;
  }

  if (url.startsWith("vreb/")) {
    return `https://cdn.repliers.io/${url}`;
  }

  return url;
};

const getFirstListingImage = (listing: any) => {
  const images = Array.isArray(listing?.images)
    ? listing.images
    : [];

  const firstImage = images[0];

  return normalizeImageUrl(
    listing?.image_url ||
      firstImage?.highRes ||
      firstImage?.mediumRes ||
      firstImage?.lowRes ||
      firstImage?.url ||
      firstImage ||
      ""
  );
};

const heroListing = parkListings[0] || null;
const heroImage = getFirstListingImage(heroListing);

const heroPrice = heroListing?.price
  ? `$${Number(heroListing.price).toLocaleString()}`
  : "";

const hasParkCoordinates =
  typeof park.lat === "number" &&
  Number.isFinite(park.lat) &&
  typeof park.lng === "number" &&
  Number.isFinite(park.lng);

const parkListingIds = parkListings
  .map(
    (listing: any) =>
      listing.id ||
      listing.mls_number ||
      listing.mlsNumber
  )
  .filter(Boolean)
  .map(String)
  .join(",");

const parkExploreParams = new URLSearchParams({
  city: "nanaimo",
  focus: "park",
  park: park.slug,
  name: park.name,
  address: `${park.address}, ${park.city}, BC`,
});

if (hasParkCoordinates) {
  parkExploreParams.set(
    "lat",
    String(park.lat)
  );

  parkExploreParams.set(
    "lng",
    String(park.lng)
  );
}

if (parkListingIds) {
  parkExploreParams.set(
    "listings",
    parkListingIds
  );
}

const parkExploreHref =
  `/explore?${parkExploreParams.toString()}`;

const availabilityLabel =
  parkListingCount === 0
    ? "No homes currently listed"
    : parkListingCount === 1
      ? "1 home currently available"
      : `${parkListingCount} homes currently available`;

const relatedParks = mobileHomeParks
  .filter(
    (item) =>
      item.slug !== park.slug &&
      item.category === park.category
  )
  .slice(0, 3);

const comparisonParks = [park, ...relatedParks].map(
  (item) => ({
    ...item,
    listingCount: allMobileListings.filter(
      (listing: any) =>
        hasExactCivicAddress(listing, item.address)
    ).length,
  })
);

const buyerSummary =
  park.category === "55-plus"
    ? `${park.name} may appeal to buyers looking for a 55+ community with ${park.features
        .slice(0, 2)
        .join(" and ")
        .toLowerCase()}.`
    : park.category === "adult"
      ? `${park.name} may suit buyers looking for an adult-oriented community with ${park.features
          .slice(0, 2)
          .join(" and ")
          .toLowerCase()}.`
      : `${park.name} may suit buyers looking for an all-ages or family-oriented community with ${park.features
          .slice(0, 2)
          .join(" and ")
          .toLowerCase()}.`;

const categoryLabel =
  park.category === "55-plus"
    ? "55+ community"
    : park.category === "adult"
      ? "Adult-oriented community"
      : "Family or all-ages community";

const petLabel =
  park.petType === "none"
    ? "Pets not permitted"
    : park.petType === "approval"
      ? "Pets subject to approval"
      : park.petType === "restricted"
        ? "Pets permitted with restrictions"
        : "Pets permitted";



const pageTitle = `${park.name} | Nanaimo Mobile Home Parks`;

const pageDescription =
  `${park.name} is a ${categoryLabel.toLowerCase()} in Nanaimo. ` +
  `Review its age restriction, pet policy, location and community information.`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  accentColor={accentColor}
  city={city}
>
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  />

  <script
    is:inline
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  ></script>

  <SiteNav
    city={city}
    areas={[]}
    types={["mobile"]}
    intentPages={navIntentPages}
    showAreaNav={false}
  />

  <main class="park-page">
      <section class="park-hero">
        <div class="park-shell">
          <nav
            class="breadcrumbs"
            aria-label="Breadcrumb"
          >
            <a href="/">Home</a>

            <span>/</span>

            <a href="/mobile-home-parks-in-nanaimo">
              Mobile home parks
            </a>

            <span>/</span>

            <span>{park.name}</span>
          </nav>

          <div class="park-hero-grid">
            <div class="park-hero-copy">
              <div class="park-eyebrow">
                {categoryLabel}
              </div>

              <h1>{park.name}</h1>

              <p class="park-address">
                {park.address}, {park.city}, BC
              </p>

              <p class="park-intro">
                {park.description}
              </p>

              <div class="park-badges">
                <span>{park.age}</span>
                <span>{petLabel}</span>
              </div>

              <div class="park-hero-actions">
                <a
                  class="primary-button"
                  href={
                    parkListingCount > 0
                      ? "#homes-for-sale"
                      : "/#mobile-home-alerts"
                  }
                >
                  {
                    parkListingCount > 0
                      ? `View ${parkListingCount} ${
                          parkListingCount === 1
                            ? "home"
                            : "homes"
                        }`
                      : "Create a park alert"
                  }
                </a>

                <a
                  class="secondary-button"
                  href={parkExploreHref}
                >
                  View park in Explore
                </a>
              </div>
            </div>

            <aside class="park-hero-feature">
              {
                heroImage ? (
                  <a
                    class="park-hero-image"
                    href="#homes-for-sale"
                    aria-label={`View homes available in ${park.name}`}
                  >
                    <img
                      src={heroImage}
                      alt={`Mobile home currently listed in ${park.name}`}
                      width="900"
                      height="700"
                      loading="eager"
                      fetchpriority="high"
                    />

                    <div class="park-hero-image-overlay">
                      <span>Currently available</span>

                      <strong>
                        {heroPrice || availabilityLabel}
                      </strong>

                      <small>
                        {availabilityLabel}
                      </small>
                    </div>
                  </a>
                ) : (
                  <div class="park-hero-placeholder">
                    <div class="park-hero-placeholder-icon">
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.6"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M3 11.5 12 4l9 7.5" />
                        <path d="M5.5 10v10h13V10" />
                        <path d="M9 20v-6h6v6" />
                      </svg>
                    </div>

                    <span>Current availability</span>
                    <strong>{availabilityLabel}</strong>
                    <small>
                      New listings will appear here automatically.
                    </small>
                  </div>
                )
              }

              <div class="park-hero-facts">
                <div>
                  <span>Community</span>
                  <strong>{park.age}</strong>
                </div>

                <div>
                  <span>Pets</span>
                  <strong>{petLabel}</strong>
                </div>

                <div>
                  <span>Location</span>
                  <strong>{park.city}, BC</strong>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section
        class="park-snapshot-section"
        aria-label={`${park.name} at a glance`}
      >
        <div class="park-shell">
          <div class="park-snapshot-grid">
            <a
              class="park-snapshot-item park-snapshot-item--accent"
              href="#homes-for-sale"
            >
              <span>Current inventory</span>
              <strong>{availabilityLabel}</strong>
              <small>
                Updated from active Nanaimo mobile-home listings
              </small>
            </a>

            <div class="park-snapshot-item">
              <span>Age policy</span>
              <strong>{park.age}</strong>
              <small>{categoryLabel}</small>
            </div>

            <div class="park-snapshot-item">
              <span>Pet policy</span>
              <strong>{petLabel}</strong>
              <small>{park.pets}</small>
            </div>

            <div class="park-snapshot-item">
              <span>Monthly pad fee</span>
              <strong>Confirm with management</strong>
              <small>Fees and inclusions can change</small>
            </div>
          </div>
        </div>
      </section>

      <section class="park-content-section">
        <div class="park-shell park-content-grid">
          <div class="park-main-column">
            <section class="content-card">
              <div class="park-eyebrow">
                Why buyers like it
              </div>

              <h2>Why buyers consider {park.name}</h2>

              <p class="park-lead-copy">{buyerSummary}</p>

              <p>{park.description}</p>

              <p>
                Buyers should confirm current park rules,
                monthly pad fees, approval requirements and
                restrictions directly with park management.
              </p>
            </section>

            {
              hasParkCoordinates && (
                <section
                  class="content-card nearby-card"
                  id="nearby-places"
                  data-lat={park.lat}
                  data-lng={park.lng}
                >
                  <div class="park-eyebrow">
                    Around the park
                  </div>

                  <h2>Useful places nearby</h2>

                  <p>
                    Nearby parks, shops, medical services and
                    everyday amenities.
                  </p>

                  <div
                    class="nearby-grid"
                    id="nearby-grid"
                    aria-live="polite"
                  >
                    <div class="nearby-loading">
                      Loading nearby places…
                    </div>
                  </div>
                </section>
              )
            }

            <section class="content-card park-fit-card">
              <div class="park-fit-column">
                <div class="park-eyebrow">
                  Why buyers consider it
                </div>

                <h2>Could this park suit you?</h2>

                <div class="park-fit-list">
                  {
                    park.features.map((feature) => (
                      <div>
                        <span aria-hidden="true">✓</span>
                        <strong>{feature}</strong>
                      </div>
                    ))
                  }

                  <div>
                    <span aria-hidden="true">✓</span>
                    <strong>{categoryLabel}</strong>
                  </div>
                </div>
              </div>

              <div class="park-fit-column park-fit-column--warm">
                <div class="park-eyebrow">
                  Before you decide
                </div>

                <h2>Confirm the details that matter.</h2>

                <div class="park-consideration-list">
                  <div>
                    <span>01</span>
                    <p>
                      Ask for the current monthly pad fee
                      and what it includes.
                    </p>
                  </div>

                  <div>
                    <span>02</span>
                    <p>
                      Confirm the current age, pet and
                      occupancy rules directly with management.
                    </p>
                  </div>

                  <div>
                    <span>03</span>
                    <p>
                      Review the park approval process before
                      removing purchase conditions.
                    </p>
                  </div>
                </div>
              </div>
            </section>

            <section class="content-card">
              <div class="park-eyebrow">
                Park details
              </div>

              <h2>
                Rules and community information
              </h2>

              <div class="detail-list">
                <div class="detail-row">
                  <span>Age restriction</span>
                  <strong>{park.age}</strong>
                </div>

                <div class="detail-row">
                  <span>Pet policy</span>
                  <strong>{park.pets}</strong>
                </div>

                <div class="detail-row">
                  <span>Community type</span>
                  <strong>{categoryLabel}</strong>
                </div>

                <div class="detail-row">
                  <span>Address</span>

                  <strong>
                    {park.address}, {park.city}, BC
                  </strong>
                </div>

                <div class="detail-row">
                  <span>Monthly pad fee</span>

                  <strong>
                    Confirm with park management
                  </strong>
                </div>

                <div class="detail-row">
                  <span>Park approval</span>

                  <strong>
                    May be required before purchase
                  </strong>
                </div>
              </div>
            </section>

            <section class="content-card">
              <div class="park-eyebrow">
                Community highlights
              </div>

              <h2>What stands out</h2>

              <div class="feature-grid">
                {
                  park.features.map((feature) => (
                    <div class="feature-card">
                      <div
                        class="feature-icon"
                        aria-hidden="true"
                      >
                        <svg
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.7"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="m5 12 4 4L19 6" />
                        </svg>
                      </div>

                      <span>{feature}</span>
                    </div>
                  ))
                }
              </div>
            </section>

            <section class="content-card compare-card">
              <div class="park-eyebrow">
                Compare communities
              </div>

              <div class="compare-heading">
                <div>
                  <h2>How this park compares</h2>
                  <p>
                    A quick comparison with similar Nanaimo
                    communities.
                  </p>
                </div>

                <a href="/mobile-home-parks-in-nanaimo">
                  Compare all parks →
                </a>
              </div>

              <div class="compare-table-wrap">
                <table class="compare-table">
                  <thead>
                    <tr>
                      <th>Park</th>
                      <th>Age</th>
                      <th>Pets</th>
                      <th>Homes</th>
                    </tr>
                  </thead>

                  <tbody>
                    {
                      comparisonParks.map((item) => (
                        <tr class:list={{
                          "is-current": item.slug === park.slug,
                        }}>
                          <td>
                            <a href={`/parks/${item.slug}`}>
                              {item.name}
                            </a>
                          </td>
                          <td>{item.age}</td>
                          <td>
                            {item.petType === "none"
                              ? "No pets"
                              : item.petType === "approval"
                                ? "Approval"
                                : item.petType === "restricted"
                                  ? "Restrictions"
                                  : "Permitted"}
                          </td>
                          <td>{item.listingCount}</td>
                        </tr>
                      ))
                    }
                  </tbody>
                </table>
              </div>
            </section>

            <section
              class="content-card park-listings-card"
              id="homes-for-sale"
            >
              <div class="park-listings-heading">
                <div>
                  <div class="park-eyebrow">
                    Homes for sale
                  </div>

                  <h2>
                    Mobile homes currently available in
                    {park.name}
                  </h2>
                </div>

                {
                  parkListingCount > 0 && (
                    <span class="listing-count-badge">
                      {parkListingCount}
                      {parkListingCount === 1
                        ? " listing"
                        : " listings"}
                    </span>
                  )
                }
              </div>

              {
                parkListingCount > 0 ? (
                  <>
                    <p>
                      Showing active mobile-home listings
                      matched to this park using its exact civic
                      address.
                    </p>

                    <div class="listing-grid">
                      {parkListings.map((listing, index) => (
                        <div class="listing-card-wrap">
                          <ListingCard
                            listing={listing}
                            priority={index < 2}
                          />
                        </div>
                      ))}
                    </div>
                  </>
                ) : (
                  <div class="park-listings-empty">
                    <strong>
                      No homes are currently listed in this
                      park.
                    </strong>

                    <p>
                      New listings will appear here when
                      they become available.
                    </p>

                    <div class="empty-actions">
                      <a
                        class="primary-button"
                        href="/#mobile-home-alerts"
                      >
                        Create a park alert
                      </a>

                      <a
                        class="secondary-button"
                        href="/nanaimo/mobile-homes"
                      >
                        Browse all Nanaimo mobile homes
                      </a>
                    </div>
                  </div>
                )
              }
            </section>

            <section class="content-card">
              <div class="park-eyebrow">
                Buyer checklist
              </div>

              <h2>What to confirm before buying</h2>

              <ul class="checklist">
                <li>Current monthly pad fee</li>

                <li>
                  What is included in the pad fee
                </li>

                <li>Current age restrictions</li>

                <li>
                  Pet size, breed and approval
                  requirements
                </li>

                <li>
                  Park approval and application process
                </li>

                <li>
                  Rental and occupancy restrictions
                </li>

                <li>
                  Parking and visitor parking rules
                </li>

                <li>
                  Maintenance responsibilities
                </li>
              </ul>
            </section>
          </div>

          <aside class="park-sidebar">
            <div class="sidebar-card sidebar-location-card">
              <div class="park-eyebrow">
                Location
              </div>

              <h2>Find the park</h2>

              {
                hasParkCoordinates ? (
                  <div
                    id="park-location-map"
                    class="park-location-map"
                    data-lat={park.lat}
                    data-lng={park.lng}
                    data-name={park.name}
                    data-href={parkExploreHref}
                    data-listing-count={parkListingCount}
                    aria-label={`Map showing ${park.name}`}
                  >
                    <span>Loading map…</span>
                  </div>
                ) : null
              }

              <p class="sidebar-address">
                {park.address}, {park.city}, British Columbia
              </p>

              <a
                class="secondary-button sidebar-map-button"
                href={parkExploreHref}
              >
                Open interactive map
                <span aria-hidden="true">→</span>
              </a>
            </div>

            <div
              class="sidebar-card sidebar-card--accent"
            >
              <div class="park-eyebrow">
                Need help?
              </div>

              <h2>Compare this community</h2>

              <p>
                Get help comparing park rules,
                available homes, pad fees and
                locations across Nanaimo.
              </p>

              <a
                class="primary-button"
                href="/contact"
              >
                Ask about this park
              </a>
            </div>

            <div class="sidebar-card">
              <div class="park-eyebrow">
                Important note
              </div>

              <p class="small-copy">
                Park rules, pet policies, age
                restrictions and fees may change.
                Information should be confirmed with
                park management and reviewed as part
                of the buyer’s due diligence.
              </p>
            </div>
          </aside>
        </div>
      </section>

      {
        relatedParks.length > 0 && (
          <section class="related-section">
            <div class="park-shell">
              <div class="related-heading">
                <div>
                  <div class="park-eyebrow">
                    Similar communities
                  </div>

                  <h2>
                    Explore other Nanaimo parks
                  </h2>
                </div>

                <a href="/mobile-home-parks-in-nanaimo">
                  View all parks →
                </a>
              </div>

              <div class="related-grid">
                {relatedParks.map(
                  (relatedPark) => (
                    <a
                      class="related-card"
                      href={`/parks/${relatedPark.slug}`}
                    >
                      <div class="related-badges">
                        <span class="related-age">
                          {relatedPark.age}
                        </span>

                        <span class="related-pet">
                          {
                            relatedPark.petType === "none"
                              ? "No pets"
                              : "Pets considered"
                          }
                        </span>
                      </div>

                      <h3>
                        {relatedPark.name}
                      </h3>

                      <p>
                        {relatedPark.address},{" "}
                        {relatedPark.city}
                      </p>

                      <strong>
                        View park →
                      </strong>
                    </a>
                  )
                )}
              </div>
            </div>
          </section>
        )
      }
  </main>

  <IntentModalController listings={parkListings} />

  <script is:inline>
    function initializeParkLocationMap() {
      if (!window.L) return;

      const element = document.getElementById(
        "park-location-map"
      );

      if (
        !element ||
        element.dataset.mapInitialized === "true"
      ) {
        return;
      }

      const lat = Number(element.dataset.lat);
      const lng = Number(element.dataset.lng);
      const name =
        element.dataset.name || "Mobile home park";

      if (
        !Number.isFinite(lat) ||
        !Number.isFinite(lng)
      ) {
        return;
      }

      element.replaceChildren();

      const map = window.L.map(element, {
        zoomControl: false,
        attributionControl: false,
        dragging: false,
        scrollWheelZoom: false,
        doubleClickZoom: false,
        boxZoom: false,
        keyboard: false,
        touchZoom: false,
      }).setView([lat, lng], 15);

      window.L.tileLayer(
        "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
        { maxZoom: 19 }
      ).addTo(map);

      const href = element.dataset.href || "#";
      const listingCount = Number(
        element.dataset.listingCount || "0"
      );

      const marker = window.L.circleMarker([lat, lng], {
        radius: 9,
        weight: 3,
        color: "#ffffff",
        fillColor: "#58736a",
        fillOpacity: 1,
      }).addTo(map);

      marker.bindPopup(`
        <div class="park-map-popup">
          <strong>${name}</strong>
          <span>${
            listingCount === 1
              ? "1 home currently available"
              : `${listingCount} homes currently available`
          }</span>
          <a href="${href}">Open in Explore →</a>
        </div>
      `);

      marker.openPopup();

      element.addEventListener("click", () => {
        window.location.href = href;
      });

      element.dataset.mapInitialized = "true";

      window.setTimeout(() => {
        map.invalidateSize();
      }, 50);
    }

    async function initializeNearbyPlaces() {
      const section = document.getElementById(
        "nearby-places"
      );
      const grid = document.getElementById(
        "nearby-grid"
      );

      if (
        !section ||
        !grid ||
        section.dataset.loaded === "true"
      ) {
        return;
      }

      const lat = Number(section.dataset.lat);
      const lng = Number(section.dataset.lng);

      if (
        !Number.isFinite(lat) ||
        !Number.isFinite(lng)
      ) {
        return;
      }

      section.dataset.loaded = "true";

      try {
        const params = new URLSearchParams({
          city: "nanaimo",
          lat: String(lat),
          lng: String(lng),
          radius: "3500",
          limit: "40",
        });

        const response = await fetch(
          `/api/osm-amenities?${params.toString()}`
        );

        if (!response.ok) {
          throw new Error("Nearby places request failed");
        }

        const payload = await response.json();
        const places = Array.isArray(payload)
          ? payload
          : payload.amenities ||
            payload.places ||
            payload.data ||
            [];

        const preferred = [
          "grocery",
          "medical",
          "parks",
          "schools",
          "restaurants",
          "transit",
        ];

        const selected = [];
        const usedCategories = new Set();

        for (const category of preferred) {
          const match = places.find((place) => {
            const value = String(
              place.category || place.type || ""
            ).toLowerCase();

            return (
              !usedCategories.has(category) &&
              value.includes(category.slice(0, 5))
            );
          });

          if (match) {
            selected.push(match);
            usedCategories.add(category);
          }
        }

        for (const place of places) {
          if (selected.length >= 6) break;
          if (!selected.includes(place)) {
            selected.push(place);
          }
        }

        if (!selected.length) {
          grid.innerHTML = `
            <p class="nearby-empty">
              Nearby-place details are being prepared.
            </p>
          `;
          return;
        }

        grid.innerHTML = selected
          .slice(0, 6)
          .map((place) => {
            const name =
              place.name || "Nearby amenity";
            const category =
              place.category ||
              place.type ||
              "Nearby";
            const distance = Number(
              place.distance_m ||
              place.distance ||
              0
            );

            const distanceLabel =
              distance > 0
                ? distance < 1000
                  ? `${Math.round(distance)} m`
                  : `${(distance / 1000).toFixed(1)} km`
                : "";

            return `
              <div class="nearby-item">
                <span>${category}</span>
                <strong>${name}</strong>
                ${
                  distanceLabel
                    ? `<small>${distanceLabel} away</small>`
                    : ""
                }
              </div>
            `;
          })
          .join("");
      } catch (error) {
        console.error(error);
        grid.innerHTML = `
          <p class="nearby-empty">
            Nearby-place details are temporarily unavailable.
          </p>
        `;
      }
    }

    function initializeParkPage() {
      initializeParkLocationMap();
      initializeNearbyPlaces();
    }

    if (document.readyState === "loading") {
      document.addEventListener(
        "DOMContentLoaded",
        initializeParkPage,
        { once: true }
      );
    } else {
      initializeParkPage();
    }

    document.addEventListener(
      "astro:page-load",
      initializeParkPage
    );

      document.addEventListener("click", (event) => {
        const target = event.target;

        if (!(target instanceof Element)) return;

        const card = target.closest(
          ".listing-grid [data-listing-id]"
        );

        if (!card) return;

        if (typeof window.openSheet !== "function") {
          return;
        }

        event.preventDefault();
        window.openSheet(card);
      });
  </script>
</Layout>

