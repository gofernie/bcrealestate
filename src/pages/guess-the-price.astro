---
export const prerender = false;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Guess the Asking Price | BC Real Estate</title>
    <meta
      name="description"
      content="Test your BC real estate price knowledge using real active listings."
    />
    <style>
      :root {
        --bg: #f4f1eb;
        --card: #fff;
        --ink: #17212b;
        --muted: #65717c;
        --line: rgba(23, 33, 43, 0.12);
        --accent: #163b5d;
        --good: #1e7a4f;
        --warn: #9a6419;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        color: var(--ink);
        background:
          radial-gradient(circle at top, rgba(22, 59, 93, 0.08), transparent 32rem),
          var(--bg);
      }

      button, input, select { font: inherit; }

      .shell {
        width: min(1120px, calc(100% - 28px));
        margin: 0 auto;
        padding: 22px 0 54px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 22px;
      }

      .brand {
        color: inherit;
        text-decoration: none;
        font-weight: 850;
        letter-spacing: -0.03em;
      }

      .brand span { color: var(--accent); }

      .scoreboard {
        display: flex;
        gap: 8px;
      }

      .score-pill {
        min-width: 88px;
        padding: 9px 12px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255,255,255,.78);
        text-align: center;
        box-shadow: 0 8px 24px rgba(23,33,43,.05);
      }

      .score-pill small {
        display: block;
        color: var(--muted);
        font-size: .68rem;
        font-weight: 750;
        text-transform: uppercase;
        letter-spacing: .08em;
      }

      .score-pill strong { font-size: .95rem; }

      .game {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(300px, .8fr);
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 28px;
        background: var(--card);
        box-shadow: 0 24px 80px rgba(23,33,43,.10);
      }

      .listing-photo {
        position: relative;
        min-height: 660px;
        background: #dfe4e7;
      }

      .listing-photo img {
        width: 100%;
        height: 100%;
        min-height: 660px;
        object-fit: cover;
        display: block;
      }

      .photo-shade {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 50%, rgba(8,16,23,.72));
        pointer-events: none;
      }

      .listing-caption {
        position: absolute;
        left: 24px;
        right: 24px;
        bottom: 22px;
        color: #fff;
      }

      .listing-caption h2 {
        margin: 0 0 6px;
        font-size: clamp(1.35rem, 2.6vw, 2.1rem);
        line-height: 1.05;
        letter-spacing: -.03em;
      }

      .listing-caption p { margin: 0; opacity: .85; }

      .panel {
        display: flex;
        flex-direction: column;
        padding: clamp(24px, 4vw, 44px);
      }

      .eyebrow {
        margin: 0 0 10px;
        color: var(--accent);
        font-size: .75rem;
        font-weight: 850;
        text-transform: uppercase;
        letter-spacing: .12em;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3.6rem);
        line-height: .98;
        letter-spacing: -.055em;
      }

      .intro {
        margin: 18px 0 24px;
        color: var(--muted);
        line-height: 1.6;
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 26px;
      }

      .meta span {
        padding: 8px 11px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: #fafafa;
        font-size: .82rem;
        font-weight: 700;
      }

     .price-question {
  margin: 0 0 10px;
  color: var(--muted);
  font-size: .74rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .08em;
}

.timer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 7px;
  color: var(--muted);
  font-size: 0.74rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.07em;
}

.timer-row strong {
  color: var(--accent);
  font-size: 0.95rem;
}

.timer-track {
  height: 7px;
  margin-bottom: 15px;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(23, 33, 43, 0.09);
}

.timer-fill {
  width: 100%;
  height: 100%;
  border-radius: inherit;
  background: var(--accent);
  transform-origin: left center;
  transition:
    width 1s linear,
    background 0.2s ease;
}

.timer-fill.is-warning {
  background: var(--warn);
}

.timer-fill.is-danger {
  background: #b84a4a;
}

:global(.price-options) {
  display: grid;
  gap: 12px;
}

:global(.price-option) {
  position: relative;
  width: 100%;
  min-height: 62px;
  padding: 14px 18px;
  border: 1px solid rgba(23, 33, 43, 0.14);
  border-radius: 16px;
  background: #ffffff;
  color: var(--ink);
  cursor: pointer;
  font-size: 1.12rem;
  font-weight: 850;
  line-height: 1;
  text-align: center;
  letter-spacing: -0.02em;
  box-shadow: 0 8px 22px rgba(23, 33, 43, 0.05);
  transition:
    transform 0.14s ease,
    border-color 0.14s ease,
    background 0.14s ease,
    box-shadow 0.14s ease;
}

:global(.price-option)::after {
  content: "Choose";
  position: absolute;
  top: 50%;
  right: 16px;
  transform: translateY(-50%);
  color: var(--muted);
  font-size: 0.65rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  opacity: 0;
  transition: opacity 0.14s ease;
}

:global(.price-option:hover) {
  transform: translateY(-2px);
  border-color: var(--accent);
  background: rgba(22, 59, 93, 0.025);
  box-shadow: 0 12px 28px rgba(23, 33, 43, 0.1);
}

:global(.price-option:hover)::after {
  opacity: 1;
}

:global(.price-option:focus-visible) {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 4px rgba(22, 59, 93, 0.12);
}

:global(.price-option:disabled) {
  cursor: default;
  transform: none;
  opacity: 0.72;
}

:global(.price-option:disabled)::after {
  display: none;
}

:global(.price-option.is-correct) {
  border-color: var(--good);
  background: rgba(30, 122, 79, 0.1);
  color: var(--good);
  opacity: 1;
  box-shadow: 0 0 0 3px rgba(30, 122, 79, 0.12);
}

:global(.price-option.is-correct)::before {
  content: "✓";
  position: absolute;
  left: 17px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 1rem;
}

:global(.price-option.is-wrong) {
  border-color: #b84a4a;
  background: rgba(184, 74, 74, 0.08);
  color: #9f3535;
  opacity: 1;
}

:global(.price-option.is-wrong)::before {
  content: "×";
  position: absolute;
  left: 17px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 1.2rem;
}

:global(.price-option.is-answer) {
  border-color: var(--good);
  background: rgba(30, 122, 79, 0.08);
  color: var(--good);
  opacity: 1;
  box-shadow: 0 0 0 3px rgba(30, 122, 79, 0.12);
}

:global(.price-option.is-answer)::before {
  content: "✓";
  position: absolute;
  left: 17px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 1rem;
}

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 52px;
        padding: 0 20px;
        border: 0;
        border-radius: 14px;
        cursor: pointer;
        font-weight: 850;
      }

      .btn-primary { background: var(--accent); color: #fff; }
      .btn-secondary { background: #edf1f4; color: var(--ink); }
      .btn:disabled { opacity: .55; cursor: wait; }

      .result {
        display: none;
        margin-top: 18px;
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: #faf9f7;
      }

      .result.is-visible { display: block; animation: reveal .32s ease both; }

      @keyframes reveal {
        from { opacity: 0; transform: translateY(7px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .result-kicker {
        margin: 0 0 4px;
        color: var(--muted);
        font-size: .72rem;
        font-weight: 850;
        text-transform: uppercase;
        letter-spacing: .08em;
      }

      .result-price {
        margin: 0;
        font-size: 2rem;
        line-height: 1;
        letter-spacing: -.04em;
      }

      .result-copy {
        margin: 10px 0 16px;
        color: var(--muted);
      }

      .result-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }

      .loading {
        position: absolute;
        inset: 0;
        display: none;
        place-items: center;
        background: rgba(244,241,235,.84);
        backdrop-filter: blur(8px);
        z-index: 5;
        font-weight: 850;
      }

      .listing-photo.is-loading .loading { display: grid; }

      .error {
        display: none;
        margin-top: 16px;
        color: #a23939;
        font-weight: 700;
      }

      .error.is-visible { display: block; }
.quiz-panel,
.final-panel {
  width: 100%;
}

.quiz-panel.is-leaving {
  animation: panelOut 0.22s ease both;
}

.final-panel {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  animation: panelIn 0.42s cubic-bezier(.2,.8,.2,1) both;
}

.final-panel[hidden] {
  display: none;
}

@keyframes panelOut {
  to { opacity: 0; transform: translateY(-8px); }
}

@keyframes panelIn {
  from { opacity: 0; transform: translateY(14px); }
  to { opacity: 1; transform: translateY(0); }
}

.final-heading h2 {
  margin: 0;
  font-size: clamp(2.5rem, 5vw, 4.7rem);
  line-height: .92;
  letter-spacing: -.065em;
}

.final-rating {
  margin: 14px 0 0;
  color: var(--muted);
  font-size: 1rem;
  font-weight: 700;
}

.final-score-wrap {
  margin: 28px 0 20px;
  padding: 22px 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}

.final-score-wrap small {
  display: block;
  margin-bottom: 6px;
  color: var(--muted);
  font-size: .7rem;
  font-weight: 850;
  text-transform: uppercase;
  letter-spacing: .1em;
}

.final-score-wrap strong {
  display: block;
  font-size: clamp(3.2rem, 7vw, 6.2rem);
  line-height: .88;
  letter-spacing: -.07em;
}

.final-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.final-stats article {
  min-width: 0;
  padding: 14px 15px;
  border: 1px solid var(--line);
  border-radius: 16px;
  background: #faf9f7;
}

.final-stats small {
  display: block;
  margin-bottom: 5px;
  color: var(--muted);
  font-size: .65rem;
  font-weight: 850;
  text-transform: uppercase;
  letter-spacing: .08em;
}

.final-stats strong {
  display: block;
  overflow: hidden;
  font-size: 1.15rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-submit {
  margin-top: 14px;
  padding: 16px;
  border: 1px solid var(--line);
  border-radius: 18px;
  background: #fff;
}

.score-submit label {
  display: block;
  margin-bottom: 8px;
  font-size: .8rem;
  font-weight: 850;
}

.score-submit-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 8px;
}

.score-submit input {
  width: 100%;
  min-width: 0;
  min-height: 48px;
  padding: 0 14px;
  border: 1px solid var(--line);
  border-radius: 13px;
  background: #fff;
  color: var(--ink);
  outline: none;
}

.score-submit input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 4px rgba(22,59,93,.1);
}

#rankMessage {
  margin: 9px 0 0;
  color: var(--good);
  font-size: .84rem;
  font-weight: 750;
}

.leaderboard-card {
  position: relative;
  margin-top: 18px;
  padding: 20px 18px 16px;
  overflow: hidden;
  border: 4px solid #7cf7ff;
  border-radius: 10px;
  background:
    linear-gradient(rgba(124,247,255,.045) 1px, transparent 1px),
    linear-gradient(90deg, rgba(124,247,255,.045) 1px, transparent 1px),
    #050817;
  background-size: 18px 18px;
  color: #f7fbff;
  box-shadow:
    0 0 0 3px #151f47,
    0 0 24px rgba(124,247,255,.42),
    inset 0 0 34px rgba(88,80,255,.18);
  font-family: "Courier New", ui-monospace, monospace;
}

.leaderboard-card::before,
.leaderboard-card::after {
  content: "";
  position: absolute;
  top: 14px;
  width: 24px;
  height: 16px;
  background:
    linear-gradient(90deg, transparent 4px, #ff59d6 4px 8px, transparent 8px 16px, #ff59d6 16px 20px, transparent 20px),
    linear-gradient(90deg, #ff59d6 4px, transparent 4px 8px, #ff59d6 8px 16px, transparent 16px 20px, #ff59d6 20px);
  background-size: 24px 8px;
  image-rendering: pixelated;
  filter: drop-shadow(0 0 6px rgba(255,89,214,.8));
}

.leaderboard-card::before { left: 18px; }
.leaderboard-card::after { right: 18px; transform: scaleX(-1); }

.leaderboard-heading {
  display: block;
  margin: 0 34px 14px;
  text-align: center;
}

.leaderboard-heading .eyebrow {
  margin: 0 0 5px;
  color: #ffeb59;
  font-family: inherit;
  font-size: .67rem;
  letter-spacing: .18em;
  text-shadow: 0 0 8px rgba(255,235,89,.75);
}

.leaderboard-heading h3 {
  margin: 0;
  color: #7cf7ff;
  font-family: inherit;
  font-size: clamp(1.05rem, 3vw, 1.45rem);
  line-height: 1.1;
  letter-spacing: .12em;
  text-transform: uppercase;
  text-shadow: 3px 3px 0 #26316c, 0 0 12px rgba(124,247,255,.72);
}

.leaderboard-subhead {
  display: grid;
  grid-template-columns: 42px minmax(0, 1fr) auto;
  gap: 10px;
  padding: 8px 10px;
  border-top: 2px solid rgba(124,247,255,.5);
  border-bottom: 2px solid rgba(124,247,255,.5);
  color: #ff59d6;
  font-size: .64rem;
  font-weight: 900;
  letter-spacing: .14em;
  text-transform: uppercase;
}

#leaderboardRows {
  max-height: 270px;
  overflow: auto;
  scrollbar-color: #7cf7ff #0b1029;
}

.leaderboard-row {
  display: grid;
  grid-template-columns: 42px minmax(0, 1fr) auto;
  gap: 10px;
  align-items: center;
  min-height: 38px;
  padding: 8px 10px;
  border-bottom: 1px dashed rgba(124,247,255,.25);
  font-size: .86rem;
  letter-spacing: .06em;
}

.leaderboard-row:nth-child(1) {
  color: #ffeb59;
  text-shadow: 0 0 8px rgba(255,235,89,.5);
}

.leaderboard-row:nth-child(2) { color: #d9e4ff; }
.leaderboard-row:nth-child(3) { color: #ff9e65; }
.leaderboard-row:last-child { border-bottom: 0; }

.leaderboard-rank {
  color: #7cf7ff;
  font-weight: 900;
}

.leaderboard-name {
  overflow: hidden;
  font-weight: 900;
  text-overflow: ellipsis;
  text-transform: uppercase;
  white-space: nowrap;
}

.leaderboard-score {
  color: #8dff83;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 0 7px rgba(141,255,131,.55);
}

.leaderboard-empty {
  margin: 0;
  padding: 22px 10px 12px;
  color: #7cf7ff;
  text-align: center;
  text-transform: uppercase;
  letter-spacing: .08em;
}
.final-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 9px;
  margin-top: 14px;
}

.listing-photo.is-complete .photo-shade {
  background: linear-gradient(180deg, rgba(8,16,23,.18), rgba(8,16,23,.82));
}

.listing-photo.is-complete img {
  transform: scale(1.015);
  filter: saturate(.82);
  transition: transform .55s ease, filter .55s ease;
}

.completion-badge {
  display: none;
  align-items: center;
  gap: 8px;
  margin-top: 10px;
  font-size: .78rem;
  font-weight: 800;
  letter-spacing: .02em;
}

.listing-photo.is-complete .completion-badge {
  display: flex;
  animation: reveal .4s ease both;
}

@media (max-width: 700px) {
  .score-pill-accuracy { display: none; }
  .final-actions { grid-template-columns: 1fr; }
  .score-submit-row { grid-template-columns: 1fr; }
  #leaderboardRows { max-height: 240px; }
}
      @media (max-width: 820px) {
        .game { grid-template-columns: 1fr; }
        .listing-photo, .listing-photo img { min-height: 420px; }
        .panel { padding: 28px 22px 30px; }
      }

      @media (max-width: 520px) {
        .topbar { align-items: flex-start; }
        .scoreboard { gap: 5px; }
        .score-pill { min-width: 72px; padding: 8px; }
              .result-actions { grid-template-columns: 1fr; }
      }

     /* Compact completed-game layout */
.game:has(.final-panel:not([hidden])) {
  grid-template-columns: minmax(0, 1.25fr) minmax(370px, 0.75fr);
  min-height: 0;
}

.game:has(.final-panel:not([hidden])) {
  align-items: stretch;
}

.game:has(.final-panel:not([hidden])) .listing-photo {
  min-height: 0;
  height: 100%;
}

.game:has(.final-panel:not([hidden])) .listing-photo img {
  width: 100%;
  height: 100%;
  min-height: 100%;
  object-fit: cover;
}

.game:has(.final-panel:not([hidden])) .panel {
  padding: 28px 34px 26px;
}

.game:has(.final-panel:not([hidden])) .final-panel {
  justify-content: flex-start;
}

.game:has(.final-panel:not([hidden])) .final-heading .eyebrow {
  margin-bottom: 8px;
  font-size: 0.66rem;
}

.game:has(.final-panel:not([hidden])) .final-heading h2 {
  max-width: none;
  font-size: clamp(2.7rem, 4.4vw, 4rem);
  line-height: 0.92;
  letter-spacing: -0.065em;
}

.game:has(.final-panel:not([hidden])) .final-rating {
  margin-top: 10px;
  font-size: 0.84rem;
}

.game:has(.final-panel:not([hidden])) .final-score-wrap {
  margin: 18px 0 13px;
  padding: 15px 0;
}

.game:has(.final-panel:not([hidden])) .final-score-wrap small {
  margin-bottom: 5px;
  font-size: 0.62rem;
}

.game:has(.final-panel:not([hidden])) .final-score-wrap strong {
  font-size: clamp(3.5rem, 6vw, 5.2rem);
  line-height: 0.84;
}

.game:has(.final-panel:not([hidden])) .final-stats {
  gap: 8px;
}

.game:has(.final-panel:not([hidden])) .final-stats article {
  min-height: 55px;
  padding: 10px 12px;
  border-radius: 13px;
}

.game:has(.final-panel:not([hidden])) .final-stats small {
  margin-bottom: 4px;
  font-size: 0.56rem;
}

.game:has(.final-panel:not([hidden])) .final-stats strong {
  font-size: 0.96rem;
}

.game:has(.final-panel:not([hidden])) .score-submit {
  margin-top: 9px;
  padding: 12px;
  border-radius: 14px;
}

.game:has(.final-panel:not([hidden])) .score-submit label {
  margin-bottom: 6px;
  font-size: 0.7rem;
}

.game:has(.final-panel:not([hidden])) .score-submit-row {
  gap: 7px;
}

.game:has(.final-panel:not([hidden])) .score-submit input {
  min-height: 42px;
  padding: 0 11px;
  border-radius: 11px;
  font-size: 0.82rem;
}

.game:has(.final-panel:not([hidden])) .score-submit .btn {
  min-height: 42px;
  padding: 0 15px;
  border-radius: 11px;
  font-size: 0.8rem;
}

.game:has(.final-panel:not([hidden])) #rankMessage {
  margin-top: 6px;
  font-size: 0.72rem;
}

.game:has(.final-panel:not([hidden])) .leaderboard-card {
  max-height: none;
  margin-top: 9px;
  padding: 12px 12px 9px;
  border-width: 3px;
}

.game:has(.final-panel:not([hidden])) .leaderboard-card::before,
.game:has(.final-panel:not([hidden])) .leaderboard-card::after {
  top: 10px;
  transform: scale(0.75);
}

.game:has(.final-panel:not([hidden])) .leaderboard-card::after {
  transform: scaleX(-1) scale(0.75);
}

.game:has(.final-panel:not([hidden])) .leaderboard-heading {
  margin: 0 30px 8px;
}

.game:has(.final-panel:not([hidden])) .leaderboard-heading .eyebrow {
  margin-bottom: 3px;
  font-size: 0.54rem;
}

.game:has(.final-panel:not([hidden])) .leaderboard-heading h3 {
  font-size: 1.08rem;
}

.game:has(.final-panel:not([hidden])) .leaderboard-subhead {
  grid-template-columns: 36px minmax(0, 1fr) auto;
  gap: 7px;
  padding: 5px 7px;
  font-size: 0.5rem;
}

.game:has(.final-panel:not([hidden])) #leaderboardRows {
  max-height: 112px;
}

.game:has(.final-panel:not([hidden])) .leaderboard-row {
  grid-template-columns: 36px minmax(0, 1fr) auto;
  gap: 7px;
  min-height: 22px;
  padding: 3px 7px;
  font-size: 0.7rem;
  line-height: 1.1;
}

.game:has(.final-panel:not([hidden])) .final-actions {
  gap: 8px;
  margin-top: 9px;
}

.game:has(.final-panel:not([hidden])) .final-actions .btn {
  min-height: 42px;
  border-radius: 11px;
  font-size: 0.8rem;
}

/* Property facts shown on the completed photo */
.final-photo-facts {
  display: none;
}

.listing-photo.is-complete .final-photo-facts {
  display: flex;
  flex-wrap: wrap;
  gap: 9px 18px;
  margin-top: 13px;
  animation: reveal 0.4s ease both;
}

.final-photo-fact {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.76rem;
  font-weight: 800;
  white-space: nowrap;
}

.final-photo-fact svg {
  width: 16px;
  height: 16px;
  flex: 0 0 auto;
  fill: none;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 1.8;
}

@media (max-width: 900px) {
  .game:has(.final-panel:not([hidden])) {
    grid-template-columns: 1fr;
  }

  .game:has(.final-panel:not([hidden])) .listing-photo,
  .game:has(.final-panel:not([hidden])) .listing-photo img {
    height: 390px;
  }
}

@media (max-width: 520px) {
  .game:has(.final-panel:not([hidden])) .listing-photo,
  .game:has(.final-panel:not([hidden])) .listing-photo img {
    height: 310px;
  }

  .game:has(.final-panel:not([hidden])) .panel {
    padding: 24px 20px;
  }

  .listing-photo.is-complete .final-photo-facts {
    gap: 8px 13px;
  }

  .final-photo-fact {
    font-size: 0.7rem;
  }
}
    </style>
  </head>

  <body>
    <main class="shell">
      <header class="topbar">
        <a class="brand" href="/">bc.<span>realestate</span></a>
        <div class="scoreboard" aria-label="Game score">
          <div class="score-pill">
            <small>Round</small>
            <strong id="roundValue">1 / 10</strong>
          </div>
          <div class="score-pill">
            <small>Score</small>
            <strong id="scoreValue">0</strong>
          </div>
          <div class="score-pill score-pill-accuracy">
            <small>Accuracy</small>
            <strong id="accuracyValue">0%</strong>
          </div>
        </div>
      </header>

     <section class="game" id="gameScreen" aria-live="polite">
        <div class="listing-photo is-loading" id="listingPhoto">
          <div class="loading">Finding a home…</div>
          <img id="listingImage" alt="Active BC real estate listing" />
          <div class="photo-shade"></div>
         <div class="listing-caption">
  <h2 id="listingArea">Loading…</h2>
  <p id="listingType"></p>
<div class="completion-badge" id="completionBadge">
  <span>✓</span>
  <span>10 homes priced</span>
</div>

<div
  class="final-photo-facts"
  id="finalPhotoFacts"
  aria-label="Property details"
></div>
</div>
        </div>

        <div class="panel">
          <div class="quiz-panel" id="quizPanel">
            <p class="eyebrow">Real Estate IQ</p>
            <h1>Guess the asking price.</h1>
            <p class="intro">Study the home, make your call, and see how close you are. Every round uses a real active listing.</p>

            <div class="meta" id="listingMeta"></div>

            <div id="guessForm">
              <p class="price-question">Which is the asking price?</p>
              <div class="timer-row">
                <span>Time remaining</span>
                <strong id="timerValue">10</strong>
              </div>

              <div class="timer-track" aria-hidden="true">
                <div class="timer-fill" id="timerFill"></div>
              </div>

              <div
                class="price-options"
                id="priceOptions"
                aria-label="Choose the asking price"
              ></div>
            </div>

            <div class="result" id="resultCard">
              <p class="result-kicker">Listed for</p>
              <h3 class="result-price" id="actualPrice">$0</h3>
              <p class="result-copy" id="resultCopy"></p>
              <p class="result-copy" id="revealedAddress"></p>

              <div class="result-actions">
                <button class="btn btn-primary" id="nextButton" type="button">Next home</button>
                <a class="btn btn-secondary" id="viewListingButton" href="/explore">View listings</a>
              </div>
            </div>

            <p class="error" id="errorMessage"></p>
          </div>

          <div class="final-panel" id="finalPanel" hidden>
            <div class="final-heading">
              <p class="eyebrow">Challenge complete</p>
              <h2>Your Price IQ</h2>
              <p class="final-rating" id="reviewRating">You know the market.</p>
            </div>

            <div class="final-score-wrap">
              <small>Final score</small>
              <strong id="reviewScore">0</strong>
            </div>

            <div class="final-stats">
              <article>
                <small>Accuracy</small>
                <strong id="reviewCorrect">0 / 10</strong>
              </article>
              <article>
                <small>Close calls</small>
                <strong id="reviewClose">0</strong>
              </article>
              <article>
                <small>Average time</small>
                <strong id="reviewTime">0 sec</strong>
              </article>
              <article>
                <small>Homes priced</small>
                <strong>10</strong>
              </article>
            </div>

            <div class="score-submit">
              <label for="playerName">Add your score</label>
              <div class="score-submit-row">
                <input id="playerName" type="text" maxlength="24" autocomplete="nickname" placeholder="Your name" />
                <button class="btn btn-primary" id="submitScoreButton" type="button">Join leaderboard</button>
              </div>
              <p id="rankMessage"></p>
            </div>

            <div class="leaderboard-card">
              <div class="leaderboard-heading">
                <p class="eyebrow">Nanaimo High Scores</p>
                <h3>Price Invaders</h3>
              </div>
              <div class="leaderboard-subhead" aria-hidden="true">
                <span>Rank</span>
                <span>Player</span>
                <span>Score</span>
              </div>
              <div id="leaderboardRows"><p class="leaderboard-empty">Loading high scores…</p></div>
            </div>

            <div class="final-actions">
              <button class="btn btn-primary" id="playAgainButton" type="button">Play again</button>
              <a class="btn btn-secondary" href="/explore">Explore listings</a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <script is:inline>
 const state = {
  listing: null,
  round: 1,
  maxRounds: 10,
  score: 0,
  timeLeft: 10,
  timerId: null,
  answered: false,

  correctAnswers: 0,
  closeAnswers: 0,
  totalSecondsUsed: 0,
  answers: [],
  city: "nanaimo",
};

      const $ = (selector) => document.querySelector(selector);
      const listingPhoto = $("#listingPhoto");
      const listingImage = $("#listingImage");
 const listingArea = $("#listingArea");
const listingType = $("#listingType");
const listingMeta = $("#listingMeta");
const priceOptions = $("#priceOptions");
const resultCard = $("#resultCard");
const actualPrice = $("#actualPrice");
const resultCopy = $("#resultCopy");
const revealedAddress = $("#revealedAddress");
   const nextButton = $("#nextButton");
const errorMessage = $("#errorMessage");
const roundValue = $("#roundValue");
const scoreValue = $("#scoreValue");
const accuracyValue = $("#accuracyValue");
const timerValue = $("#timerValue");
const timerFill = $("#timerFill");

const gameScreen = $("#gameScreen");
const quizPanel = $("#quizPanel");
const finalPanel = $("#finalPanel");
const reviewRating = $("#reviewRating");
const reviewScore = $("#reviewScore");
const reviewCorrect = $("#reviewCorrect");
const reviewClose = $("#reviewClose");
const reviewTime = $("#reviewTime");
const playerName = $("#playerName");
const submitScoreButton = $("#submitScoreButton");
const rankMessage = $("#rankMessage");
const leaderboardRows = $("#leaderboardRows");
const playAgainButton = $("#playAgainButton");
const finalPhotoFacts = $("#finalPhotoFacts");

      const money = new Intl.NumberFormat("en-CA", {
        style: "currency",
        currency: "CAD",
        maximumFractionDigits: 0,
      });

      function showError(message = "") {
        errorMessage.textContent = message;
        errorMessage.classList.toggle("is-visible", Boolean(message));
      }

      function updateScoreboard() {
        const answeredRounds = state.answers.length;
        const accuracy = answeredRounds > 0
          ? Math.round((state.correctAnswers / answeredRounds) * 100)
          : 0;

        roundValue.textContent = `${state.round} / ${state.maxRounds}`;
        scoreValue.textContent = state.score.toLocaleString("en-CA");
        accuracyValue.textContent = `${accuracy}%`;
      }

  

    function stopTimer() {
  if (state.timerId) {
    window.clearInterval(state.timerId);
    state.timerId = null;
  }
}

function renderTimer() {
  timerValue.textContent = String(state.timeLeft);
  timerFill.style.width = `${state.timeLeft * 10}%`;

  timerFill.classList.toggle(
    "is-warning",
    state.timeLeft <= 5 && state.timeLeft > 2
  );

  timerFill.classList.toggle(
    "is-danger",
    state.timeLeft <= 2
  );
}

function startTimer() {
  stopTimer();

  state.timeLeft = 10;
  state.answered = false;
  renderTimer();

  state.timerId = window.setInterval(() => {
    state.timeLeft -= 1;
    renderTimer();

    if (state.timeLeft <= 0) {
      stopTimer();
      revealAnswer(null, true);
    }
  }, 1000);
}

function renderListing(listing) {
  state.listing = listing;

  const titleCase = (value) =>
    String(value || "")
      .replaceAll("_", " ")
      .replaceAll("-", " ")
      .replace(/\b\w/g, (letter) => letter.toUpperCase());

  const areaName = titleCase(listing.area) || "BC";
  const cityName = titleCase(listing.city);
  const typeName = titleCase(listing.type) || "Active listing";

  listingArea.textContent = [areaName, cityName]
    .filter(Boolean)
    .join(", ");

  listingType.textContent = typeName;

const currentYear = new Date().getFullYear();

const yearBuilt =
  Number(listing.yearBuilt) >= 1800 &&
  Number(listing.yearBuilt) <= currentYear
    ? Number(listing.yearBuilt)
    : null;

const propertyAge = yearBuilt
  ? currentYear - yearBuilt
  : null;

const finalFacts = [
  listing.beds
    ? {
        icon: `
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 18v-7"></path>
            <path d="M21 18v-5a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v5"></path>
            <path d="M7 15H3"></path>
            <path d="M3 18h18"></path>
            <path d="M7 11V8a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3"></path>
          </svg>
        `,
        value: `${listing.beds} beds`,
      }
    : null,

  listing.baths
    ? {
        icon: `
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 13h16"></path>
            <path d="M5 13v2a4 4 0 0 0 4 4h6a4 4 0 0 0 4-4v-2"></path>
            <path d="M7 13V6a2 2 0 0 1 4 0"></path>
            <path d="M9 19v2"></path>
            <path d="M17 19v2"></path>
          </svg>
        `,
        value: `${listing.baths} baths`,
      }
    : null,

  listing.sqft
    ? {
        icon: `
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="5" y="3" width="14" height="18" rx="1"></rect>
            <path d="M9 7h2"></path>
            <path d="M9 11h2"></path>
            <path d="M9 15h2"></path>
            <path d="M9 19h2"></path>
          </svg>
        `,
        value: `${Number(listing.sqft).toLocaleString("en-CA")} sqft`,
      }
    : null,

  yearBuilt
    ? {
        icon: `
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="5" width="18" height="16" rx="2"></rect>
            <path d="M16 3v4"></path>
            <path d="M8 3v4"></path>
            <path d="M3 10h18"></path>
          </svg>
        `,
        value: `Built ${yearBuilt}${
          propertyAge !== null
            ? ` (${propertyAge} yrs)`
            : ""
        }`,
      }
    : null,

  cityName
    ? {
        icon: `
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z"></path>
            <circle cx="12" cy="10" r="2"></circle>
          </svg>
        `,
        value: cityName,
      }
    : null,
].filter(Boolean);

finalPhotoFacts.innerHTML = finalFacts
  .map(
    (fact) => `
      <span class="final-photo-fact">
        ${fact.icon}
        <span>${fact.value}</span>
      </span>
    `
  )
  .join("");

  listingImage.src = listing.image;
  listingImage.alt = `Active ${typeName.toLowerCase()} listing in ${areaName}`;

  const facts = [
    listing.beds ? `${listing.beds} beds` : "",
    listing.baths ? `${listing.baths} baths` : "",
    listing.sqft
      ? `${Number(listing.sqft).toLocaleString("en-CA")} sqft inside`
      : "",
    typeName,
  ].filter(Boolean);

  listingMeta.innerHTML = facts
    .map((fact) => `<span>${fact}</span>`)
    .join("");

  const shuffledOptions = [...(listing.options || [])];

  for (let index = shuffledOptions.length - 1; index > 0; index -= 1) {
    const randomIndex = Math.floor(Math.random() * (index + 1));
    [shuffledOptions[index], shuffledOptions[randomIndex]] = [
      shuffledOptions[randomIndex],
      shuffledOptions[index],
    ];
  }

  priceOptions.innerHTML = shuffledOptions
    .map(
      (price) => `
        <button
          class="price-option"
          type="button"
          data-price="${Number(price)}"
        >
          ${money.format(Number(price))}
        </button>
      `
    )
    .join("");

  resultCard.classList.remove("is-visible");
  actualPrice.textContent = "$0";
  resultCopy.textContent = "";
revealedAddress.textContent = "";
showError();

if (listingImage.complete && listingImage.naturalWidth > 0) {
  startTimer();
} else {
  listingImage.onload = () => {
    startTimer();
  };

  listingImage.onerror = () => {
    startTimer();
  };
}
}

      async function loadListing() {
        listingPhoto.classList.add("is-loading");
        const exclude = state.listing?.id ? `&exclude=${encodeURIComponent(state.listing.id)}` : "";

        try {
          const response = await fetch(`/api/price-game?city=nanaimo${exclude}`);
          const json = await response.json();
          if (!response.ok || !json.ok) throw new Error(json.error || "Could not load a listing.");
          renderListing(json.listing);
        } catch (error) {
          showError(error.message || "Could not load a listing.");
        } finally {
          listingPhoto.classList.remove("is-loading");
        }
      }

    async function revealAnswer(selectedButton = null, timedOut = false) {
  if (state.answered || !state.listing?.id) return;

  state.answered = true;
  stopTimer();
  showError();

  const guess = selectedButton
    ? Number(selectedButton.dataset.price)
    : 0;

  const buttons = Array.from(
    priceOptions.querySelectorAll(".price-option")
  );

  buttons.forEach((item) => {
    item.disabled = true;
  });

  try {
    const response = await fetch("/api/price-game", {
      method: "POST",
      headers: {
        "content-type": "application/json",
      },
      body: JSON.stringify({
        listingId: state.listing.id,
        guess,
        secondsRemaining: state.timeLeft,
        timedOut,
      }),
    });

    const json = await response.json();

    if (!response.ok || !json.ok) {
      throw new Error(
        json.error || "Could not reveal the price."
      );
    }

    const result = json.result;
const secondsUsed = Math.max(
  0,
  10 - Number(result.secondsRemaining || 0)
);

state.totalSecondsUsed += secondsUsed;

if (result.isCorrect) {
  state.correctAnswers += 1;
} else if (!result.timedOut && result.percentError <= 10) {
  state.closeAnswers += 1;
}

state.answers.push({
  round: state.round,
  askingPrice: result.askingPrice,
  guess: result.guess,
  isCorrect: result.isCorrect,
  timedOut: result.timedOut,
  points: result.points,
  secondsUsed,
  area: result.area,
  address: result.address,
});
    state.score += result.points;
    updateScoreboard();

    buttons.forEach((item) => {
      const optionPrice = Number(item.dataset.price);

      if (optionPrice === result.askingPrice) {
        item.classList.add("is-answer");
      }
    });

    if (result.timedOut) {
      resultCopy.textContent =
        "Time's up. No points this round.";
    } else if (result.isCorrect) {
      selectedButton.classList.add("is-correct");

      resultCopy.textContent =
        `Correct with ${result.secondsRemaining} seconds left. ` +
        `+${result.points.toLocaleString("en-CA")} points.`;
    } else {
      selectedButton.classList.add("is-wrong");

      resultCopy.textContent =
        `${result.rating}. You were ` +
        `${money.format(result.difference)} ${result.direction}. ` +
        `+${result.points.toLocaleString("en-CA")} points.`;
    }

    actualPrice.textContent =
      money.format(result.askingPrice);

    revealedAddress.textContent = result.address
      ? `${result.address} · ${[
          result.area,
          result.city,
        ].filter(Boolean).join(", ")}`
      : "";

    resultCard.classList.add("is-visible");

    nextButton.textContent =
      state.round >= state.maxRounds
        ? "See my score"
        : "Next home";
  } catch (error) {
    state.answered = false;

    buttons.forEach((item) => {
      item.disabled = false;
    });

    showError(
      error.message || "Could not reveal the price."
    );
  }
}

priceOptions.addEventListener("click", (event) => {
  const button = event.target.closest(".price-option");

  if (!button) return;

  revealAnswer(button, false);
});
function getReviewRating() {
  if (state.correctAnswers >= 8) {
    return "Market expert";
  }

  if (state.correctAnswers >= 6) {
    return "Sharp pricing instincts";
  }

  if (state.correctAnswers >= 4) {
    return "Strong market knowledge";
  }

  if (state.correctAnswers >= 2) {
    return "Getting a feel for the market";
  }

  return "The market still has some surprises";
}

function escapeHtml(value = "") {
  return String(value)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");
}

async function loadLeaderboard() {
  leaderboardRows.innerHTML =
    '<p class="leaderboard-empty">Loading high scores…</p>';

  try {
    const response = await fetch(
      `/api/price-game-leaderboard?city=${encodeURIComponent(state.city)}`
    );

    const json = await response.json();

    if (!response.ok || !json.ok) {
      throw new Error(
        json.error || "Could not load leaderboard."
      );
    }

    if (!json.scores.length) {
      leaderboardRows.innerHTML =
        '<p class="leaderboard-empty">No pilots yet. Claim the first high score.</p>';
      return;
    }

    leaderboardRows.innerHTML = json.scores
      .map(
        (entry, index) => `
          <div class="leaderboard-row">
            <span class="leaderboard-rank">
              ${String(index + 1).padStart(2, "0")}
            </span>

            <span class="leaderboard-name">
              ${escapeHtml(entry.player_name)}
            </span>

            <span class="leaderboard-score">
              ${Number(entry.score).toLocaleString("en-CA")}
            </span>
          </div>
        `
      )
      .join("");
  } catch (error) {
    leaderboardRows.innerHTML =
      `<p class="leaderboard-empty">${escapeHtml(error.message || "Could not load leaderboard.")}</p>`;
  }
}

async function showFinalReview() {
  stopTimer();

  const averageSeconds = state.answers.length > 0
    ? state.totalSecondsUsed / state.answers.length
    : 0;

  reviewScore.textContent = state.score.toLocaleString("en-CA");
  reviewCorrect.textContent = `${state.correctAnswers} / ${state.maxRounds}`;
  reviewClose.textContent = String(state.closeAnswers);
  reviewTime.textContent = `${averageSeconds.toFixed(1)} sec`;
  reviewRating.textContent = getReviewRating();

  listingPhoto.classList.add("is-complete");
  quizPanel.classList.add("is-leaving");

  window.setTimeout(() => {
    quizPanel.hidden = true;
    quizPanel.classList.remove("is-leaving");
    finalPanel.hidden = false;
  }, 210);

  await loadLeaderboard();
}
   nextButton.addEventListener("click", async () => {
  if (state.round >= state.maxRounds) {
    await showFinalReview();
    return;
  }

  state.round += 1;
  updateScoreboard();
  await loadListing();
});

submitScoreButton.addEventListener("click", async () => {
  const name = playerName.value.trim();

  if (!name) {
    rankMessage.textContent =
      "Enter a name for the leaderboard.";
    return;
  }

  submitScoreButton.disabled = true;
  submitScoreButton.textContent = "Saving…";
  rankMessage.textContent = "";

  const averageSeconds =
    state.answers.length > 0
      ? state.totalSecondsUsed / state.answers.length
      : 0;

  try {
    const response = await fetch(
      "/api/price-game-leaderboard",
      {
        method: "POST",
        headers: {
          "content-type": "application/json",
        },
        body: JSON.stringify({
          playerName: name,
          city: state.city,
          score: state.score,
          correctAnswers: state.correctAnswers,
          closeAnswers: state.closeAnswers,
          averageSeconds,
        }),
      }
    );

    const json = await response.json();

    if (!response.ok || !json.ok) {
      throw new Error(
        json.error || "Could not save score."
      );
    }

    rankMessage.textContent = json.rank
      ? `You're currently #${json.rank} in ${state.city}.`
      : "Score saved.";

    playerName.disabled = true;
    submitScoreButton.disabled = true;
    submitScoreButton.textContent = "Score saved ✓";

    await loadLeaderboard();
  } catch (error) {
    submitScoreButton.disabled = false;
    submitScoreButton.textContent = "Join leaderboard";

    rankMessage.textContent =
      error.message || "Could not save score.";
  }
});

playAgainButton.addEventListener("click", async () => {
  stopTimer();

  state.listing = null;
  state.round = 1;
  state.score = 0;
  state.timeLeft = 10;
  state.timerId = null;
  state.answered = false;

  state.correctAnswers = 0;
  state.closeAnswers = 0;
  state.totalSecondsUsed = 0;
  state.answers = [];

  playerName.disabled = false;
  playerName.value = "";

  submitScoreButton.disabled = false;
  submitScoreButton.textContent = "Join leaderboard";

  rankMessage.textContent = "";

  finalPanel.hidden = true;
  quizPanel.hidden = false;
  listingPhoto.classList.remove("is-complete");

  updateScoreboard();
  await loadListing();
});

      updateScoreboard();
      loadListing();
    </script>
  </body>
</html>
